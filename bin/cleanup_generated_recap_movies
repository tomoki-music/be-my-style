#!/usr/bin/env bash
set -euo pipefail

APP_ROOT="${APP_ROOT:-/var/www/be-my-style/current}"
BUNDLE_BIN="${BUNDLE_BIN:-${HOME:-/home/deploy}/.rbenv/shims/bundle}"

cd "$APP_ROOT"

timestamp() {
  date '+%Y-%m-%d %H:%M:%S %z'
}

echo "[$(timestamp)] cleanup_generated_recap_movies start app_root=$APP_ROOT bundle_bin=$BUNDLE_BIN"

if RAILS_ENV=production DISABLE_SPRING=1 "$BUNDLE_BIN" exec rails runner \
  'Singing::CleanupGeneratedRecapMoviesJob.perform_now'; then
  echo "[$(timestamp)] cleanup_generated_recap_movies finish exit_status=0"
else
  status=$?
  echo "[$(timestamp)] cleanup_generated_recap_movies failed exit_status=$status" >&2
  exit "$status"
fi
