body {
  font-family: "Source Sans Pro", "Hiragino Kaku Gothic ProN", Meiryo, Arial, sans-serif;
  word-wrap: break-word;
  overflow-wrap: break-word;
}

.list-style-none li{
  list-style: none;
  margin-right: 10px;
}

.text-red{
  color: red; 
}

.w100{
  width: 100%;
}

.center{
  text-align: center;
}

.block{
  display: block;
}

.hide{
  display: none;
}

.keep-right{
  text-align: right;
}

.cursor-pointer{
  cursor: pointer;
}

.pagination{
  margin: auto;
  width: 90%;
  display: flex;
  justify-content: center;
}
.pagination span{
  background-color: rgba(158, 158, 158, 0.4);
  text-align: center;
  width: 50px;
  border: solid 1px #344963;
  color: rgb(197, 20, 159);
  transition: .3s;
  -webkit-transform: scale(1);
  transform: scale(1);
}
.pagination span:hover{
  transition: .3s;
  -webkit-transform: scale(1.1);
  transform: scale(1.1);
}
.pagination span a:hover{
  transition: .3s;
  -webkit-transform: scale(1.1);
  transform: scale(1.1);
}

.notifications {
  animation-name: smooth-fadein-out;
  animation-duration: 10s;
  animation-timing-function: ease;
  animation-delay: 0s;
  animation-iteration-count: 1;
  animation-direction: alternate;
  opacity: 0;
  z-index: 10;
  position: fixed;
  top: 200px;
  right: 10px;
  color: $white;
  font-size: 20px;
  text-align: center;
  width: 350px;
  height: 200px;
  border-radius: 10px;
  margin: 0 auto;
  pointer-events: none;
  .notice {
    background-color: #17a2b8;
    border-radius: 10px;
  }
  .alert {
    background-color: red;
    border-radius: 10px;
  }
}

@keyframes smooth-fadein-out {
  0% {opacity: 1;}
  100% {opacity: 0;}
}

.devise-login-container{
  width: 90%;
  margin: 0 auto;
  h2 {
    display: block;
    width: 100%;
    margin-left: 100px;
  }
}

.devise-password-container{
  width: 50%;
  margin: 0 auto;
  h2 {
    display: block;
    width: 100%;
    margin-left: 100px;
  }
}

.devise-container{
  width: 90%;
  margin: 0 auto;
  h2 {
    display: block;
    width: 100%;
    margin-left: 100px;
  }
}

.devise-sign-up-header{
  width: 90%;
  .shared-link{
    position: fixed;
    top: 30px;
    right: 30px;
    background-color: lightblue;
    padding: 20px;
    color: white;
    border-radius: 10px;
  }
}

.registration-table{
  border: thick double lightblue;
  margin-bottom: 100px;
  input[type="text"] {
  width: 185px;
  height: 40px;
  }
}

.registration-btn{
  position: fixed;
  bottom: 30px;
  right: 30px;
  display: block;
  width: 200px;
  margin-left: auto;
  text-align: center;
  font-size: 20px;
  color: white;
  border-radius: 10px;
}

.registration-img{
  width: 300px;
  object-fit: cover;
  border-radius: 10px;
  padding: 5px;
}

.stamp-picker{
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 10px;
}

.stamp-picker-form{
  display: inline-block;
  margin: 0;
}

.stamp-button{
  border: 1px solid #d8dee9;
  background: #fff7ed;
  color: #7c2d12;
  border-radius: 999px;
  padding: 6px 12px;
  font-size: 14px;
  cursor: pointer;
}

.avatar-with-badge {
  position: relative;
  display: inline-block;
  line-height: 0;
}

.avatar-role-badge {
  position: absolute;
  right: -6px;
  bottom: -4px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 84px;
  min-height: 18px;
  padding: 2px 7px;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.92);
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: 0.02em;
  box-shadow: 0 8px 16px rgba(15, 23, 42, 0.16);
  white-space: nowrap;
  text-align: center;
}

.avatar-role-badge--admin {
  background: linear-gradient(135deg, #ef4444, #b91c1c);
}

.avatar-role-badge--owner {
  background: linear-gradient(135deg, #fb923c, #ea580c);
}

.stamp-badge{
  display: inline-block;
  background: #fff7ed;
  color: #7c2d12;
  border: 1px solid #fed7aa;
  border-radius: 999px;
  padding: 6px 12px;
  font-weight: 600;
}

.directory-search{
  width: 90%;
  margin: 12px auto 20px;
  padding: 16px;
  background: #f8fbff;
  border: 1px solid #d7e7f7;
  border-radius: 14px;
}

.directory-search__form{
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  align-items: center;
}

.directory-search__input,
.directory-search__select{
  min-height: 42px;
  border: 1px solid #c9d7e6;
  border-radius: 10px;
  padding: 0 12px;
  background: #fff;
}

.directory-search__input{
  flex: 1 1 260px;
}

.directory-search__select{
  flex: 0 1 220px;
}

.directory-search__submit,
.directory-search__reset{
  min-height: 42px;
  border-radius: 10px;
}

@media (max-width: 600px) {
  .directory-search__input,
  .directory-search__select,
  .directory-search__submit,
  .directory-search__reset{
    width: 100%;
  }
}

.session-table{
  border: thick double lightblue;
}

.session-btn{
  position: fixed;
  bottom: 30px;
  right: 30px;
  display: block;
  width: 200px;
  margin-left: auto;
  text-align: center;
  font-size: 20px;
  color: white;
  border-radius: 10px;
}

.password-table{
  border: thick double lightblue;
}

.password-btn{
  position: fixed;
  bottom: 30px;
  right: 30px;
  display: block;
  width: 200px;
  margin-left: auto;
  text-align: center;
  font-size: 20px;
  color: white;
  border-radius: 10px;
}

input[type="text"] {
  width: 90%;
  height: 40px;
}

.error-message{
  text-align: center;
  padding: 10px;
  border: solid 1px;
  border-radius: 10px;
  color: red;
  ul{
    list-style: none;
  }
}

.feature-gate {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 16px 18px;
  border-radius: 16px;
  background: linear-gradient(135deg, #fff8ee, #f4f8ff);
  border: 1px solid rgba(46, 84, 162, 0.16);
  box-shadow: 0 10px 24px rgba(31, 48, 77, 0.08);

  &__meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  &__badge {
    display: inline-flex;
    width: fit-content;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(35, 71, 201, 0.1);
    color: #2347c9;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  &__title {
    font-size: 16px;
    color: #1d2a3d;
  }

  &__message {
    margin: 0;
    color: #5f6b7c;
    font-size: 13px;
  }

  &__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    padding: 10px 16px;
    border-radius: 999px;
    background: linear-gradient(135deg, #f07b4a, #da5635);
    color: #fff;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 12px 24px rgba(218, 86, 53, 0.18);
  }

  &__link:hover {
    color: #fff;
    text-decoration: none;
  }
}

.feature-gate--inline {
  margin: 12px 0 20px;
}

.directory-page-heading {
  max-width: 820px;
  margin: 0 auto;
  text-align: center;
}

.directory-page-heading__eyebrow {
  display: inline-flex;
  margin: 0 0 8px;
  padding: 5px 12px;
  border-radius: 999px;
  background: rgba(35, 71, 201, 0.08);
  color: #2347c9;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.directory-page-heading h2 {
  margin: 0;
  color: #1d2a3d;
  font-weight: 800;
  letter-spacing: 0;
}

.directory-page-heading__lead {
  max-width: 640px;
  margin: 10px auto 0;
  color: #5f6b7c;
  font-size: 14px;
  line-height: 1.8;
}

.directory-page-action {
  margin-top: 18px;
  text-align: center;
}

.directory-upgrade-panel {
  width: calc(100% - 24px);
  max-width: 760px;
  margin: 18px auto 0;
}

.directory-upgrade-panel .feature-gate--inline {
  margin: 0;
}

.feature-gate--table {
  margin: 4px 0;
  padding: 12px 14px;

  .feature-gate__title {
    font-size: 14px;
  }

  .feature-gate__message {
    font-size: 12px;
  }

  .feature-gate__link {
    padding: 8px 12px;
    font-size: 12px;
  }
}

.menu-lock-note {
  display: inline-flex;
  margin-left: 8px;
  padding: 2px 8px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.2);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.02em;
}

.menu-btn-locked,
.menu-sp-btn-locked {
  position: relative;
  opacity: 0.95;
}

.plan-badge-inline {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 72px;
  padding: 4px 10px;
  border-radius: 999px;
  background: linear-gradient(135deg, #edf4ff, #fff4ea);
  border: 1px solid rgba(35, 71, 201, 0.14);
  color: #2347c9;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.04em;
  position: relative;
  overflow: hidden;
  isolation: isolate;
  vertical-align: middle;
}

.plan-badge-inline::after {
  content: "";
  position: absolute;
  inset: 0;
  transform: translateX(-130%);
  background: linear-gradient(110deg, transparent 20%, rgba(255, 255, 255, 0.64) 46%, transparent 72%);
  z-index: -1;
}

.plan-badge-inline--light {
  background: linear-gradient(135deg, #eef7ff, #dff0ff 52%, #ffffff);
  color: #0f69b4;
  border: 1px solid rgba(88, 178, 255, 0.36);
  box-shadow:
    0 8px 18px rgba(67, 164, 255, 0.18),
    inset 0 1px 0 rgba(255, 255, 255, 0.9);
}

.plan-badge-inline--light::after {
  animation: planBadgeSweep 3.8s ease-in-out infinite;
}

.plan-badge-inline--core {
  background: linear-gradient(135deg, #ff4f39, #ff8a2a 48%, #ffd166);
  color: #fff;
  border: 1px solid rgba(255, 120, 42, 0.5);
  text-shadow: 0 1px 8px rgba(120, 32, 0, 0.28);
  box-shadow:
    0 10px 24px rgba(239, 84, 37, 0.3),
    0 0 0 3px rgba(255, 178, 71, 0.14),
    inset 0 1px 0 rgba(255, 255, 255, 0.55);
}

.plan-badge-inline--core::after {
  animation: planBadgeSweep 3s ease-in-out infinite;
}

.plan-badge-inline--premium {
  background: linear-gradient(135deg, #17141f 0%, #3b2a5b 34%, #c9a646 68%, #fff2b7 100%);
  color: #fff9d8;
  border: 1px solid rgba(232, 205, 112, 0.72);
  text-shadow: 0 1px 10px rgba(0, 0, 0, 0.45);
  box-shadow:
    0 12px 28px rgba(67, 45, 105, 0.32),
    0 0 0 3px rgba(214, 183, 83, 0.16),
    inset 0 1px 0 rgba(255, 255, 255, 0.38);
}

.plan-badge-inline--premium::before {
  content: "";
  width: 6px;
  height: 6px;
  margin-right: 7px;
  border-radius: 999px;
  background: #fff2b7;
  box-shadow:
    0 0 8px rgba(255, 242, 183, 0.95),
    0 0 16px rgba(201, 166, 70, 0.65);
}

.plan-badge-inline--premium::after {
  animation: planBadgeSweep 2.8s ease-in-out infinite;
}

.plan-badge-inline--free {
  background: #eef2f7;
  color: #667085;
}

@keyframes planBadgeSweep {
  0%, 24% {
    transform: translateX(-130%);
  }
  56%, 100% {
    transform: translateX(130%);
  }
}

.subscription-manager {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 14px;
  border-radius: 16px;
  background: linear-gradient(135deg, #fbfdff, #fff6ef);
  border: 1px solid rgba(35, 71, 201, 0.1);

  &__header {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  &__status {
    color: #64748b;
    font-size: 12px;
    font-weight: 600;
  }

  &__copy {
    margin: 0;
    color: #475569;
    font-size: 13px;
  }

  &__plans {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 10px;
  }

  &__plan {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 12px;
    border-radius: 12px;
    background: #fff;
    border: 1px solid rgba(35, 71, 201, 0.08);
  }

  &__plan strong {
    text-transform: lowercase;
    color: #2347c9;
  }

  form {
    margin: 0;
  }

  &__cta {
    width: fit-content;
  }
}

.menu-upgrade-item {
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-upgrade-cta {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 11px 18px;
  border-radius: 999px;
  border: 1px solid rgba(255, 194, 53, 0.5);
  background:
    radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.95), transparent 18%),
    radial-gradient(circle at 80% 30%, rgba(255, 245, 170, 0.9), transparent 20%),
    linear-gradient(135deg, #ffe97a 0%, #ffbf3c 38%, #ff8c32 100%);
  color: #5c2d00;
  font-weight: 900;
  letter-spacing: 0.03em;
  text-decoration: none;
  box-shadow:
    0 10px 24px rgba(255, 161, 47, 0.34),
    0 0 0 3px rgba(255, 236, 153, 0.25),
    inset 0 1px 0 rgba(255, 255, 255, 0.85);
  overflow: hidden;
  isolation: isolate;
  animation: sparklePulse 2.2s ease-in-out infinite;
}

.lp-btn-disabled {
  opacity: 0.65;
  pointer-events: none;
}

.menu-upgrade-cta::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(120deg, transparent 20%, rgba(255, 255, 255, 0.6) 48%, transparent 72%);
  transform: translateX(-120%);
  animation: sparkleSweep 3.4s linear infinite;
  z-index: -1;
}

.menu-upgrade-cta:hover {
  color: #4a2400;
  text-decoration: none;
  transform: translateY(-1px) scale(1.02);
  box-shadow:
    0 14px 28px rgba(255, 147, 41, 0.4),
    0 0 0 4px rgba(255, 224, 114, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.92);
}

.menu-upgrade-cta__label {
  white-space: nowrap;
}

.menu-upgrade-cta__spark {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.95);
  text-shadow: 0 0 10px rgba(255, 255, 255, 0.95);
}

.menu-upgrade-cta--compact {
  padding: 9px 15px;
  font-size: 12px;
}

@keyframes sparklePulse {
  0%, 100% {
    filter: saturate(1) brightness(1);
  }
  50% {
    filter: saturate(1.08) brightness(1.04);
  }
}

@keyframes sparkleSweep {
  0% {
    transform: translateX(-120%);
  }
  100% {
    transform: translateX(120%);
  }
}

@media (max-width: 768px) {
  .feature-gate {
    flex-direction: column;
    align-items: flex-start;

    &__link {
      width: 100%;
    }
  }

  .directory-page-heading {
    text-align: left;
  }

  .directory-page-heading__lead {
    margin-top: 8px;
    font-size: 13px;
  }

  .directory-page-action {
    text-align: left;
  }

  .directory-page-action .btn {
    width: 100%;
  }

  .directory-upgrade-panel {
    width: 100%;
    margin-top: 16px;
  }

  .menu-upgrade-item {
    width: 100%;
  }

  .menu-upgrade-cta {
    width: 220px;
  }
}
