!!!
%html
  %head
    %meta{:content => "text/haml; charset=UTF-8mb4", "http-equiv" => "Content-Type"}/
    %meta{:content => "width=device-width,initial-scale=1", :name => "viewport"}/
    - page_description = content_for?(:og_description) ? yield(:og_description) : "好きで繋がった仲間は一生もの。音楽人の為のコミュニティアプリです。"
    %meta{:content => page_description, :name => "description"}/
    %title= content_for?(:title) ? yield(:title) : "BeMyStyle"
    %meta{ property: "og:type", content: "website" }/
    %meta{ property: "og:title", content: content_for?(:og_title) ? yield(:og_title) : (content_for?(:title) ? yield(:title) : "BeMyStyle") }/
    %meta{ property: "og:description", content: page_description }/
    - if content_for?(:og_image)
      %meta{ property: "og:image", content: yield(:og_image) }/
    = favicon_link_tag'favicon.ico'
    = csrf_meta_tags
    = csp_meta_tag
    = include_gon
    = stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload'
    %link{rel: "preconnect", href: "https://fonts.googleapis.com"}/
    %link{rel: "preconnect", href: "https://fonts.gstatic.com", crossorigin: "anonymous"}/
    %link{href: "https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700;800&family=Playfair+Display:wght@700&display=swap", rel: "stylesheet"}/
    %link{
      rel: "stylesheet",
      href: "https://use.fontawesome.com/releases/v5.15.4/css/all.css",
      crossorigin: "anonymous"
    }
    %link{rel: "stylesheet", href: "https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"}
    %link{:href => "//cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css", :rel => "stylesheet", :type => "text/css"}/
    %link{:href => "//cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css", :rel => "stylesheet", :type => "text/css"}/
    = javascript_include_tag 'application', 'data-turbolinks-track': 'reload'
    %script{:type => "text/javascript", :src => "//cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"}
    %script{:type => "text/javascript", :src => "https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"}
  %body
    .notifications
      - flash.each do |key, value|
        = content_tag(:div, value, class: key)
    = yield
