.header_container.sticky-top
  .header-menu
    .row
      .col-8
        .top-message
          = link_to public_homes_top_path, class: 'top-message-link', data: { 'turbolinks': false } do
            = image_tag 'mmm.jpg' ,class:"top-message-image"
            %h1 be My Style
          %p あなたの「やりたい！」を叶える場所！」
          %p 利用可能時間【6:00~26:00】
      .col-4
        %ul.list-style-none.header-sign-in-list
          - if customer_signed_in?
            %li
              %div{"data-turbolinks" => "false"}
                = link_to(public_notifications_path) do
                  - if current_customer.present? && unchecked_notifications.any?
                    %span.fa-stack
                      %i.far.fa-bell.fa-lg.fa-stack-2x
                      %i.fas.fa-circle.n-circle.fa-stack-1x
                      %i.count-circle
                        - notifications = current_customer.passive_notifications
                        = notifications.where(checked: false).count
                  - else 
                    %i.far.fa-bell.fa-lg
          %li#open
            %span
              = customer_avatar_tag(current_customer, class_name: "icon_mini sp-menu-open")

  .customer-menu-sp
    #close
      %span.fa.fa-times.close-icon
        閉じる
    %ul.list-style-none
      - if customer_signed_in?
        %li
          = link_to "Topページ", public_homes_top_path, data: { 'turbolinks': false }, class: "btn btn-info menu-sp-btn"
        %li
          = link_to "BeMyStyleとは？", public_homes_about_path, data: { 'turbolinks': false }, class: "btn btn-info menu-sp-btn"
        %li
          = link_to "コミュニティ一覧", public_communities_path, data: { 'turbolinks': false }, class: "btn btn-info menu-sp-btn"
        %li
          - if current_customer.present?
            = link_to "マイページ", public_customer_path(current_customer), data: { 'turbolinks': false }, class: "btn btn-info menu-sp-btn"
        %li
          = link_to public_matchings_path, data: { 'turbolinks': false }, class: "btn btn-info menu-sp-btn #{'menu-sp-btn-locked' unless feature_available?(:music_direct_chat)}" do
            個別チャット
            - unless feature_available?(:music_direct_chat)
              %span.menu-lock-note= feature_locked_badge(:music_direct_chat)
        %li
          = link_to "みんなの活動報告", public_activities_path, data: { 'turbolinks': false }, class: "btn btn-info menu-sp-btn"
        %li
          = link_to "イベント参加", public_events_path, data: { 'turbolinks': false }, class: "btn btn-info menu-sp-btn"
        %li.menu-upgrade-item
          = link_to public_lp_path(anchor: "lp-section"), data: { 'turbolinks': false }, class: "menu-upgrade-cta" do
            %span.menu-upgrade-cta__spark ✦
            %span.menu-upgrade-cta__label プランUPGRADE
            %span.menu-upgrade-cta__spark ✦
        %li
          %i.fa-solid.fa-right-from-bracket
          = button_to "ログアウト",
            destroy_customer_session_path,
            method: :delete,
            form_class: "d-inline",
            class: "btn btn-secondary menu-sp-btn"
      - else
        %li
          %i.fa-solid.fa-user-plus
          = link_to "新規登録", new_customer_registration_path, data: { 'turbolinks': false }, class: "btn btn-success menu-sp-btn"
        %li
          %i.fa-solid.fa-right-to-bracket
          = link_to "ログイン", new_customer_session_path, data: { 'turbolinks': false }, class: "btn btn-primary menu-sp-btn"
        %li
          = link_to "Topページ", public_homes_top_path, data: { 'turbolinks': false }, class: "btn btn-info menu-sp-btn"
        %li
          = link_to "BeMyStyleとは？", public_homes_about_path, data: { 'turbolinks': false }, class: "btn btn-info menu-sp-btn"

  .customer-menu-pc
    %ul.list-style-none.list
      - if customer_signed_in?
        %li
          = link_to "Topページ", public_homes_top_path, data: { 'turbolinks': false }, class: "btn btn-info menu-sp-btn"
        %li
          = link_to "BeMyStyleとは？", public_homes_about_path, data: { 'turbolinks': false }, class: "btn btn-info menu-sp-btn"
        %li
          = link_to "コミュニティ一覧", public_communities_path, data: { 'turbolinks': false }, class: "btn btn-info menu-sp-btn"
        %li
          - if current_customer.present?
            = link_to "マイページ", public_customer_path(current_customer), data: { 'turbolinks': false }, class: "btn btn-info menu-sp-btn"
        %li
          = link_to public_matchings_path, data: { 'turbolinks': false }, class: "btn btn-info menu-sp-btn #{'menu-sp-btn-locked' unless feature_available?(:music_direct_chat)}" do
            個別チャット
            - unless feature_available?(:music_direct_chat)
              %span.menu-lock-note= feature_locked_badge(:music_direct_chat)
        %li
          = link_to "みんなの活動報告", public_activities_path, data: { 'turbolinks': false }, class: "btn btn-info menu-sp-btn"
        %li
          = link_to "イベント参加", public_events_path, data: { 'turbolinks': false }, class: "btn btn-info menu-sp-btn"
        %li.menu-upgrade-item
          = link_to public_lp_path(anchor: "lp-section"), data: { 'turbolinks': false }, class: "menu-upgrade-cta menu-upgrade-cta--compact" do
            %span.menu-upgrade-cta__spark ✦
            %span.menu-upgrade-cta__label プランUPGRADE
            %span.menu-upgrade-cta__spark ✦
      - else
        %li
          = link_to "Topページ", public_homes_top_path, data: { 'turbolinks': false }, class: "btn btn-info menu-sp-btn"
        %li
          = link_to "BeMyStyleとは？", public_homes_about_path, data: { 'turbolinks': false }, class: "btn btn-info menu-sp-btn"
        %li.menu-upgrade-item
          = link_to public_lp_path(anchor: "lp-section"), data: { 'turbolinks': false }, class: "menu-upgrade-cta menu-upgrade-cta--compact" do
            %span.menu-upgrade-cta__spark ✦
            %span.menu-upgrade-cta__label 料金を見る
            %span.menu-upgrade-cta__spark ✦
