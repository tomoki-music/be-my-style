= render 'layouts/header_menu_nakama'

.container.profile-container

  .profile-wrapper

    / =========================
    / ヘッダー（強化）
    / =========================
    .profile-hero

      .profile-avatar
        = customer_avatar_tag(@customer, class_name: "profile-icon")

      .profile-main

        %h2.profile-name= @customer.name

        - if @customer.job.present?
          %p.profile-job= @customer.job

        .profile-stats
          .stat
            %span.number= @customer.followings.count
            %span.label フォロー
          .stat
            %span.number= @customer.followers.count
            %span.label フォロワー

      .profile-action
        - if current_customer == @customer
          = link_to "編集", edit_business_customer_path(@customer), class:"btn btn-primary"
        - else
          %div{id: "follow_button_#{@customer.id}"}
            = render "business/relationships/follow_button", customer: @customer

    / =========================
    / メインコンテンツ（2カラム）
    / =========================
    .profile-body

      .profile-left

        .card
          %h3 自己紹介
          - if @customer.introduction.present?
            .markdown-body= markdown(@customer.introduction)
          - else
            %p 未設定

        - if @customer.business_user?

          .card
            %h3 スキル
            - if @customer.skills.present?
              .markdown-body= markdown(@customer.skills)
            - else
              %p 未設定

          .card
            %h3 実績
            - if @customer.achievements.present?
              .markdown-body= markdown(@customer.achievements)
            - else
              %p 未設定

          .card
            %h3 リンク
            - if @customer.url.present?
              = link_to @customer.url, @customer.url, target:"_blank"
            - else
              %p 未設定

      .profile-right

        .card
          %h3 契約プラン
          %p
            %span.plan-badge-inline= customer_plan_label(@customer)
            %span.ml-2
              = @customer.subscribed? ? "有効" : "無料プラン"
          - if current_customer == @customer
            = render "shared/subscription_manager", customer: @customer

        .card
          %h3 投稿

          - @customer.posts.order(created_at: :desc).limit(5).each do |post|
            .post-item
              %p= truncate(post.body, length: 80)
              %small= l(post.created_at, format: :short)

          = link_to "もっと見る", business_posts_path(user_id: @customer.id), class:"link-more"

        .card
          %h3 参加コミュニティ

          .community-list
            - @customer.communities.each do |community|
              = link_to business_community_path(community) do
                .community-chip= community.name
