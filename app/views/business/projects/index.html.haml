= render "layouts/header_menu_nakama"

.container.project-container

  .page-header
    %h2 プロジェクト一覧
    - if @community.present? && current_customer.can_create_project_for?(@community)
      = link_to "＋ 作成", new_business_project_path(community_id: @community.id), class:"btn btn-primary new-btn"
    - elsif @community.present? && @community.customers.include?(current_customer)
      = render "shared/feature_gate",
        feature_key: :business_project_create,
        title: "このコミュニティでプロジェクトを始める",
        class_name: "feature-gate--inline"

  .project-grid

    - @projects.each do |project|

      - if @community.present?
        - path = business_community_project_path(@community, project)
      - else
        - path = business_project_path(project)

      = link_to path, class:"project-link" do

        .project-card

          / =========================
          / 画像（←ここが主役）
          / =========================
          .card-image
            - if project.project_image.attached?
              = image_tag project.project_image, class:"project-img"
            - else
              .no-image
                %span No Image

          / =========================
          / 本文
          / =========================
          .card-body

            .project-header
              %h3.project-title= project.title

              .project-meta
                %span.community= project.community.name

            .project-body
              %p= truncate(project.description, length: 70)

            / =========================
            / フッター
            / =========================
            .project-footer

              .owner
                = customer_avatar_tag(project.customer, class_name: "mini-icon")

                %span= project.customer&.name || "不明"

              .project-stats
                %span 👥 #{project.project_members.count rescue 0}
                %span 🗓 #{l(project.created_at, format: :short)}
