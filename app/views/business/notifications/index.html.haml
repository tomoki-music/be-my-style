= render 'layouts/header_menu_nakama'

.container

  %h2 通知

  - @notifications.each do |notification|

    .notification-card

      - case notification.action

      - when "like"

        %p
          = notification.visitor.name
          があなたの投稿にいいねしました

      - when "message"

        %p
          = notification.visitor.name
          がコメントしました

      - when "follow"

        %p
          = notification.visitor.name
          がフォローしました

      - when "request"

        %p
          = notification.visitor.name
          があなたのコミュニティへ参加申請しました

      - when "accept"

        %p
          = notification.visitor.name
          があなたのコミュニティ参加申請を受理しました