= render "layouts/header_menu_nakama"

.container.community-container

  / =========================
  / ヘッダー
  / =========================
  .page-header

    %h2.page-title コミュニティ一覧

    = link_to "＋ 新規作成",
      new_business_community_path,
      class:"btn btn-primary new-btn"

  / =========================
  / グリッド
  / =========================
  .community-grid

    - @communities.each do |community|

      = link_to business_community_path(community), class:"community-link" do

        .community-card

          / --- 画像 ---
          .card-image
            - if community.community_image.attached?
              = image_tag community.community_image, class:"community-img"
            - else
              = image_tag "no_image", class:"community-img"

          / --- 本文 ---
          .card-body

            %h3.community-name
              = community.name

            .community-meta
              %span.member-count
                👥
                = community.customers.count
                人

            %p.community-desc
              = truncate(community.introduction, length:70)