= render 'layouts/admin_header_menu'

.container.py-4
  .d-flex.justify-content-between.align-items-center.mb-3
    %h2.mb-0 イベントコメント一覧
    = link_to "新規登録", new_admin_event_comment_path, class: "btn btn-primary"

  .table-responsive
    %table.table.table-striped.table-bordered
      %thead
        %tr
          %th ID
          %th イベント
          %th 投稿者
          %th 内容
          %th 投稿日
          %th
      %tbody
        - @requests.each do |request|
          %tr
            %td= request.id
            %td= request.event&.event_name
            %td= request.customer&.name
            %td= request.stamped? ? request.stamp_label : truncate(request.request, length: 40)
            %td= l request.created_at, format: :short
            %td.text-nowrap
              = link_to "詳細", admin_event_comment_path(request), class: "btn btn-sm btn-outline-primary"
              = link_to "編集", edit_admin_event_comment_path(request), class: "btn btn-sm btn-outline-success"
              = link_to "削除", admin_event_comment_path(request), method: :delete, data: { confirm: "このイベントコメントを削除しますか？" }, class: "btn btn-sm btn-outline-danger"
