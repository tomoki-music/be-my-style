= render 'layouts/admin_header_menu'

.container.py-4
  .d-flex.justify-content-between.align-items-center.mb-3
    %h2.mb-0 Community一覧
    = link_to "新規登録", new_admin_community_path, class: "btn btn-primary"

  .table-responsive
    %table.table.table-striped.table-bordered
      %thead
        %tr
          %th ID
          %th 名前
          %th ドメイン
          %th オーナー
          %th 参加人数
          %th 活動場所
          %th 登録日
          %th
      %tbody
        - @communities.each do |community|
          %tr
            %td= community.id
            %td= community.name
            %td= community.domain&.name
            %td= community.owner&.name || "未設定"
            %td= community.customers.count
            %td= community.prefecture&.name
            %td= l community.created_at, format: :short
            %td.text-nowrap
              = link_to "詳細", admin_community_path(community), class: "btn btn-sm btn-outline-primary"
              = link_to "編集", edit_admin_community_path(community), class: "btn btn-sm btn-outline-success"
              = link_to "削除", admin_community_path(community), method: :delete, data: { confirm: "このコミュニティを削除しますか？" }, class: "btn btn-sm btn-outline-danger"
