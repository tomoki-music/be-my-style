= render 'layouts/admin_header_menu'

.container.py-4
  .d-flex.justify-content-between.align-items-center.mb-4
    %h2.mb-0 Recap Movie 管理ダッシュボード

  .row.mb-4
    .col-md-3.col-6.mb-3
      .card.text-center.shadow-sm
        .card-body
          %h4.card-title.mb-1= @stats[:total]
          %p.card-text.text-muted.mb-0 総数
    .col-md-3.col-6.mb-3
      .card.text-center.shadow-sm.border-success
        .card-body
          %h4.card-title.mb-1.text-success= @stats[:completed]
          %p.card-text.text-muted.mb-0 completed
    .col-md-3.col-6.mb-3
      .card.text-center.shadow-sm.border-danger
        .card-body
          %h4.card-title.mb-1.text-danger= @stats[:failed]
          %p.card-text.text-muted.mb-0 failed
    .col-md-3.col-6.mb-3
      .card.text-center.shadow-sm
        .card-body
          %h4.card-title.mb-1= @stats[:processing]
          %p.card-text.text-muted.mb-0 processing

  .row.mb-4
    .col-md-3.col-6.mb-3
      .card.text-center.shadow-sm
        .card-body
          %h4.card-title.mb-1= @stats[:pending]
          %p.card-text.text-muted.mb-0 pending
    .col-md-3.col-6.mb-3
      .card.text-center.shadow-sm
        .card-body
          %h4.card-title.mb-1= @stats[:expired]
          %p.card-text.text-muted.mb-0 expired
    .col-md-3.col-6.mb-3
      .card.text-center.shadow-sm.border-primary
        .card-body
          %h4.card-title.mb-1.text-primary= @stats[:total_shares]
          %p.card-text.text-muted.mb-0 総シェア数
    .col-md-3.col-6.mb-3
      .card.text-center.shadow-sm.border-info
        .card-body
          %h4.card-title.mb-1.text-info= @stats[:total_downloads]
          %p.card-text.text-muted.mb-0 総DL数

  .row.mb-4
    .col-md-3.col-6.mb-3
      .card.text-center.shadow-sm
        .card-body
          %h4.card-title.mb-1= @stats[:total_instagram_clicks]
          %p.card-text.text-muted.mb-0 Instagram導線クリック数

  .row.mb-4
    .col-md-6.mb-3
      .card.shadow-sm.h-100
        .card-header
          %strong Status Distribution
        .card-body
          - max_status = [@status_counts.values.max.to_i, 1].max
          - @status_counts.each do |status, count|
            .mb-2
              .d-flex.justify-content-between.mb-1
                %span.small.font-weight-bold= status
                %span.badge.badge-secondary= count
              .admin-recap-bar__track
                .admin-recap-bar__fill{ class: "admin-recap-bar__fill--#{status}",
                                        style: "width: #{(count.to_f / max_status * 100).round(1)}%" }
    .col-md-6.mb-3
      .card.shadow-sm.h-100
        .card-header
          %strong Yearly Generation
        .card-body
          - if @year_counts.blank?
            %p.text-muted.mb-0 データなし
          - else
            - max_year = [@year_counts.values.max.to_i, 1].max
            - @year_counts.each do |year, count|
              .mb-2
                .d-flex.justify-content-between.mb-1
                  %span.small.font-weight-bold= year
                  %span.badge.badge-secondary= count
                .admin-recap-bar__track
                  .admin-recap-bar__fill.admin-recap-bar__fill--year{ style: "width: #{(count.to_f / max_year * 100).round(1)}%" }

  .card.shadow-sm.mb-4
    .card-header
      %strong Share Engagement
    .card-body
      .row.text-center
        .col-4
          %p.h4.mb-1.text-primary= @stats[:total_shares]
          %p.text-muted.small.mb-0 X シェア
        .col-4
          %p.h4.mb-1.text-info= @stats[:total_downloads]
          %p.text-muted.small.mb-0 ダウンロード
        .col-4
          %p.h4.mb-1= @stats[:total_instagram_clicks]
          %p.text-muted.small.mb-0 Instagram Hint

  - if @failed_movies.present?
    .card.shadow-sm.border-danger.mb-4
      .card-header.bg-danger.text-white
        %strong Failed 一覧（直近 #{@failed_movies.count} 件）
      .card-body.p-0
        .table-responsive
          %table.table.table-sm.table-striped.mb-0
            %thead.thead-light
              %tr
                %th ID
                %th ユーザー
                %th 年
                %th エラー
                %th 更新日時
            %tbody
              - @failed_movies.each do |movie|
                %tr
                  %td= link_to movie.id, admin_singing_recap_movie_path(movie)
                  %td= movie.customer.name
                  %td= movie.year
                  %td.text-danger
                    %small= movie.error_message.to_s.truncate(60)
                  %td.text-nowrap= l(movie.updated_at, format: :short)

  .card.shadow-sm.border-info.mb-4
    .card-header.bg-info.text-white
      %strong 年間Recap Movie一括生成 — 対象件数プレビュー
    .card-body
      %p.mb-2 一括生成を実行する前に対象件数を確認できます。
      = form_with url: preview_yearly_batch_admin_singing_recap_movies_path, method: :get, local: true do |f|
        .form-row.align-items-end
          .col-auto
            = f.label :year, "対象年", class: "mb-1 font-weight-bold"
            = f.number_field :year, value: params[:year].presence || Time.zone.today.year, min: 2020, max: Time.zone.today.year + 1, class: "form-control form-control-sm", style: "width: 100px"
          .col-auto.align-self-end
            = f.submit "対象件数を確認", class: "btn btn-info btn-sm"
      - if @batch_preview
        %hr
        %h6.font-weight-bold.mt-3 プレビュー結果（#{@preview_year}年）
        %ul.list-unstyled.mb-2
          %li
            %span.badge.badge-secondary.mr-1 対象ユーザー
            = @batch_preview[:target_customers_count]
            人
          %li
            %span.badge.badge-primary.mr-1 新規生成
            = @batch_preview[:new_movies_count]
            件
          %li
            %span.badge.badge-warning.mr-1 再生成
            = @batch_preview[:regenerate_movies_count]
            件
          %li
            %span.badge.badge-secondary.mr-1 スキップ
            = @batch_preview[:skipped_movies_count]
            件
            - breakdown = @batch_preview[:skipped_breakdown]
            - if breakdown.values.any?(&:positive?)
              %small.text-muted
                （pending: #{breakdown[:pending]}, processing: #{breakdown[:processing]}, completed: #{breakdown[:completed]}）
        = form_with url: generate_yearly_batch_admin_singing_recap_movies_path, method: :post, local: true do |f|
          = f.hidden_field :year, value: @preview_year
          = f.submit "この内容で#{@preview_year}年の一括生成を開始",
              class: "btn btn-warning btn-sm",
              data: { confirm: "#{@preview_year}年のRecap Movie一括生成を開始します。よろしいですか？" }

  .card.shadow-sm.border-warning.mb-4
    .card-header.bg-warning
      %strong 年間Recap Movie一括生成
    .card-body
      %p.mb-2 指定した年に診断実績のあるSingingユーザー向けにRecap Movie生成Jobを投入します。
      = form_with url: generate_yearly_batch_admin_singing_recap_movies_path, method: :post, local: true do |f|
        .form-row.align-items-end
          .col-auto
            = f.label :year, "対象年", class: "mb-1 font-weight-bold"
            = f.number_field :year, value: Time.zone.today.year, min: 2020, max: Time.zone.today.year + 1, class: "form-control form-control-sm", style: "width: 100px"
          .col-auto.align-self-end
            = f.submit "一括生成を開始",
                class: "btn btn-warning btn-sm",
                data: { confirm: "指定年のRecap Movie一括生成を開始します。よろしいですか？" }
      %p.text-muted.small.mt-2.mb-0
        ※ Job 投入のみ行います。生成完了まで数分〜数十分かかる場合があります。

  .card.shadow-sm.mb-3
    .card-header
      %strong 絞り込み
    .card-body
      = form_with url: admin_singing_recap_movies_path, method: :get, local: true do |f|
        .form-row.align-items-end
          .col-auto
            = f.label :status, "ステータス", class: "sr-only"
            = f.select :status,
                [["すべて", ""]] + [["pending", "pending"], ["processing", "processing"], ["completed", "completed"], ["failed", "failed"], ["expired", "expired"]],
                { selected: @filter_status.to_s },
                { class: "form-control form-control-sm" }
          .col-auto
            = f.label :year, "年", class: "sr-only"
            = f.text_field :year, value: @filter_year, placeholder: "年（例: 2025）", class: "form-control form-control-sm", style: "width: 120px"
          .col-auto
            = f.label :per_page, "表示件数", class: "sr-only"
            = f.select :per_page,
                [["30件", 30], ["50件", 50], ["100件", 100]],
                { selected: @per_page },
                { class: "form-control form-control-sm" }
          .col-auto
            = f.submit "絞り込む", class: "btn btn-sm btn-primary"
          .col-auto
            = link_to "リセット", admin_singing_recap_movies_path, class: "btn btn-sm btn-outline-secondary"
      - if @filter_status.present? || @filter_year.present?
        %small.text-muted.mt-2.d-block
          現在の絞り込み:
          - if @filter_status.present?
            %span.badge.badge-secondary= @filter_status
          - if @filter_year.present?
            %span.badge.badge-secondary= @filter_year

  .d-flex.justify-content-end.mb-2
    = link_to "CSV出力",
        admin_singing_recap_movies_path(request.query_parameters.except("page", "per_page").merge(format: :csv)),
        class: "btn btn-outline-secondary btn-sm"

  .card.shadow-sm
    .card-header
      %strong
        一覧（#{@total_count} 件中 #{@movies.count} 件表示 / ページ #{@page}/#{[@total_pages, 1].max}）
    .card-body.p-0
      - if @movies.empty?
        .p-3.text-muted 該当する Recap Movie はありません。
      - else
        .table-responsive
          %table.table.table-sm.table-striped.mb-0
            %thead.thead-dark
              %tr
                %th ID
                %th ユーザー
                %th 年
                %th ステータス
                %th シェア
                %th DL
                %th IG
                %th 生成日時
                %th
            %tbody
              - @movies.each do |movie|
                %tr
                  %td= movie.id
                  %td= movie.customer.name
                  %td= movie.year
                  %td
                    - case movie.status
                    - when "completed"
                      %span.badge.badge-success completed
                    - when "failed"
                      %span.badge.badge-danger failed
                    - when "processing"
                      %span.badge.badge-warning processing
                    - when "pending"
                      %span.badge.badge-secondary pending
                    - when "expired"
                      %span.badge.badge-dark expired
                  %td.text-center= movie.share_count
                  %td.text-center= movie.download_count
                  %td.text-center= movie.instagram_hint_click_count
                  %td.text-nowrap= movie.generated_at ? l(movie.generated_at, format: :short) : "-"
                  %td= link_to "詳細", admin_singing_recap_movie_path(movie), class: "btn btn-sm btn-outline-secondary"

    - if @total_pages > 1
      .card-footer
        .d-flex.align-items-center.justify-content-between
          .text-muted.small #{@page} / #{@total_pages} ページ
          .btn-group
            - if @page > 1
              = link_to "前へ",
                  admin_singing_recap_movies_path(status: @filter_status, year: @filter_year, per_page: @per_page, page: @page - 1),
                  class: "btn btn-sm btn-outline-secondary"
            - if @page < @total_pages
              = link_to "次へ",
                  admin_singing_recap_movies_path(status: @filter_status, year: @filter_year, per_page: @per_page, page: @page + 1),
                  class: "btn btn-sm btn-outline-secondary"
