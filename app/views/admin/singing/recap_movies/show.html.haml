= render 'layouts/admin_header_menu'

- if Rails.env.production? || Rails.application.config.active_job.queue_adapter.to_s.include?("async")
  .alert.alert-warning.mb-0{ role: "alert" }
    %strong 本番環境では動画生成は専用 runner で順次処理されます。
    「pending に戻す」ボタンを押しても即時生成は行われません。
    %code bin/run_pending_recap_movie_generation
    を実行してください。

.card.border-info.mb-4
  .card-header.bg-info.text-white
    %strong 本番での安全な手動実行手順
  .card-body
    %p.mb-2
      %strong 動画生成は Puma 外プロセスで以下の順序で実施してください。
    %ol.mb-3
      %li
        %strong Step 1 — dry-run で pending を確認
        %pre.bg-light.p-2.rounded.mb-1
          DRY_RUN=1 bin/run_pending_recap_movie_generation
        %small.text-muted movie_id が表示され、生成は行われません。問題なければ Step 2 へ。
      %li
        %strong Step 2 — 1件だけ実際に生成
        %pre.bg-light.p-2.rounded.mb-1
          bin/run_pending_recap_movie_generation
        %small.text-muted 1件のみ処理します。完了後にこの画面でステータスを確認してください。
      %li
        %strong Step 3 — ログ確認
        %pre.bg-light.p-2.rounded.mb-1
          sudo journalctl -u puma -n 50 --no-pager | grep -i "GenerateRecapMovie"
    .alert.alert-danger.mb-0{ role: "alert" }
      %strong 注意：
      cron 登録・自動実行・大量生成・Web リクエストからの生成は次フェーズまで行わないこと。

.container.py-4
  .d-flex.justify-content-between.align-items-center.mb-4
    %h2.mb-0 Recap Movie ##{@movie.id}
    .d-flex.gap-2
      - if @movie.failed? || @movie.expired?
        = button_to "pending に戻す（runner で生成）",
          regenerate_admin_singing_recap_movie_path(@movie),
          method: :post,
          data: { confirm: "pending にリセットします。生成は専用 runner で順次実行されます。よろしいですか？" },
          class: "btn btn-warning"
      = link_to "一覧へ", admin_singing_recap_movies_path, class: "btn btn-outline-dark"

  .row
    .col-md-6.mb-4
      .card.shadow-sm
        .card-header
          %strong 基本情報
        .card-body
          %table.table.table-sm.mb-0
            %tbody
              %tr
                %th.text-nowrap ID
                %td= @movie.id
              %tr
                %th.text-nowrap ステータス
                %td
                  - case @movie.status
                  - when "completed"
                    %span.badge.badge-success completed
                  - when "failed"
                    %span.badge.badge-danger failed
                  - when "processing"
                    %span.badge.badge-warning processing
                  - when "pending"
                    %span.badge.badge-secondary pending
                  - when "expired"
                    %span.badge.badge-dark expired
              %tr
                %th.text-nowrap 年
                %td= @movie.year
              %tr
                %th.text-nowrap エラーメッセージ
                %td.text-danger= @movie.error_message.presence || "-"
              %tr
                %th.text-nowrap 生成日時
                %td= @movie.generated_at ? l(@movie.generated_at, format: :short) : "-"
              %tr
                %th.text-nowrap 有効期限
                %td= @movie.expires_at ? l(@movie.expires_at, format: :short) : "-"
              %tr
                %th.text-nowrap 作成日時
                %td= l(@movie.created_at, format: :short)
              %tr
                %th.text-nowrap 更新日時
                %td= l(@movie.updated_at, format: :short)

    .col-md-6.mb-4
      .card.shadow-sm
        .card-header
          %strong ユーザー情報
        .card-body
          %table.table.table-sm.mb-0
            %tbody
              %tr
                %th.text-nowrap Customer ID
                %td= @movie.customer.id
              %tr
                %th.text-nowrap 名前
                %td= @movie.customer.name
              %tr
                %th.text-nowrap メール
                %td= @movie.customer.email

  .row
    .col-md-6.mb-4
      .card.shadow-sm
        .card-header
          %strong トラッキング数値
        .card-body
          %table.table.table-sm.mb-0
            %tbody
              %tr
                %th.text-nowrap シェア数
                %td= @movie.share_count
              %tr
                %th.text-nowrap 初回シェア日時
                %td= @movie.first_shared_at ? l(@movie.first_shared_at, format: :short) : "-"
              %tr
                %th.text-nowrap 最終シェア日時
                %td= @movie.last_shared_at ? l(@movie.last_shared_at, format: :short) : "-"
              %tr
                %th.text-nowrap ダウンロード数
                %td= @movie.download_count
              %tr
                %th.text-nowrap 最終DL日時
                %td= @movie.last_downloaded_at ? l(@movie.last_downloaded_at, format: :short) : "-"
              %tr
                %th.text-nowrap Instagram導線クリック数
                %td= @movie.instagram_hint_click_count
              %tr
                %th.text-nowrap 最終IGクリック日時
                %td= @movie.last_instagram_hint_clicked_at ? l(@movie.last_instagram_hint_clicked_at, format: :short) : "-"

    .col-md-6.mb-4
      .card.shadow-sm
        .card-header
          %strong 動画ファイル
        .card-body
          - if @movie.video_file.attached?
            %p.text-success
              %strong 添付あり
            %table.table.table-sm.mb-0
              %tbody
                %tr
                  %th.text-nowrap ファイル名
                  %td= @movie.video_file.blob.filename
                %tr
                  %th.text-nowrap Content-Type
                  %td= @movie.video_file.blob.content_type
                %tr
                  %th.text-nowrap サイズ
                  %td= number_to_human_size(@movie.video_file.blob.byte_size)
                %tr
                  %th.text-nowrap Blob Key
                  %td
                    %code= @movie.video_file.blob.key
          - else
            %p.text-muted 動画ファイルは添付されていません。

  .row
    .col-12.mb-4
      .card.shadow-sm
        .card-header
          %strong Generated Props
        .card-body
          - if @movie.generated_props.present?
            %pre.mb-0{ style: "max-height: 400px; overflow-y: auto;" }= JSON.pretty_generate(@movie.generated_props)
          - else
            %p.text-muted.mb-0 まだ生成propsは保存されていません。
