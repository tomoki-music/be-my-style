= render 'layouts/admin_header_menu'

- summary              = @dashboard[:summary]
- trends               = @dashboard[:trends]
- error_analysis       = @dashboard[:error_analysis]
- open_failures        = @dashboard[:open_failures]
- slow_batches         = @dashboard[:slow_batches]
- auto_retry_summary   = @dashboard[:auto_retry_summary]
- auto_retry_failures  = @dashboard[:auto_retry_failures]
- storage_expiry       = @dashboard[:storage_expiry]
- storage_audit        = @dashboard[:storage_audit]
- storage_metrics      = @dashboard[:storage_metrics]
- storage_trends_7d    = @dashboard[:storage_trends_7d]
- storage_trends_30d   = @dashboard[:storage_trends_30d]

.container-fluid.py-4.bhdash

  .d-flex.justify-content-between.align-items-center.mb-4
    %h2.mb-0
      Recap Movie — Batch Health Dashboard
    = link_to "← 管理ダッシュボード", admin_singing_recap_movies_path, class: "btn btn-sm btn-outline-secondary"

  %p.text-muted.mb-4
    Recap Movie システム全体の健康状態を横断的に監視します。

  -# ── Summary Cards ──────────────────────────────────────────────
  .row.mb-4
    .col-md-4.col-6.mb-3
      .card.text-center.shadow-sm.bhdash__card
        .card-body
          %p.bhdash__card-label Total Batches
          %h3.bhdash__card-value= summary[:total_batches]
          %p.bhdash__card-sub 全バッチ実行数

    .col-md-4.col-6.mb-3
      - rate = summary[:batch_success_rate]
      - color_cls = rate >= 80 ? "text-success" : rate >= 50 ? "text-warning" : "text-danger"
      .card.text-center.shadow-sm.bhdash__card
        .card-body
          %p.bhdash__card-label Batch Success Rate
          %h3.bhdash__card-value{ class: color_cls }= "#{rate}%"
          %p.bhdash__card-sub completed / total

    .col-md-4.col-6.mb-3
      - rr = summary[:retry_recovery_rate]
      - rr_cls = rr >= 70 ? "text-success" : rr >= 40 ? "text-warning" : "text-danger"
      .card.text-center.shadow-sm.bhdash__card
        .card-body
          %p.bhdash__card-label Retry Recovery Rate
          %h3.bhdash__card-value{ class: rr_cls }= "#{rr}%"
          %p.bhdash__card-sub resolved / retry_attempted

    .col-md-4.col-6.mb-3
      - of = summary[:open_failures]
      - of_cls = of.zero? ? "text-success" : of < 10 ? "text-warning" : "text-danger"
      .card.text-center.shadow-sm.bhdash__card
        .card-body
          %p.bhdash__card-label Open Failures
          %h3.bhdash__card-value{ class: of_cls }= of
          %p.bhdash__card-sub pending + retry_failed

    .col-md-4.col-6.mb-3
      .card.text-center.shadow-sm.bhdash__card
        .card-body
          %p.bhdash__card-label Avg Render Duration
          %h3.bhdash__card-value
            - if summary[:avg_render_duration]
              - d = summary[:avg_render_duration]
              - if d < 60
                = "#{d}s"
              - else
                = "#{d / 60}m #{d % 60}s"
            - else
              %span.text-muted —
          %p.bhdash__card-sub 平均バッチ実行時間

  -# ── Trend Graph (直近30日) ──────────────────────────────────────
  .card.shadow-sm.mb-4
    .card-header
      %strong 直近30日 Failure Trend
    .card-body
      - max_failures = trends.map { |t| t[:failure_count] }.max.to_i
      - max_failures = 1 if max_failures.zero?
      - chart_h = 80
      .bhdash__chart-wrap
        %svg.bhdash__chart{ viewBox: "0 0 #{trends.size * 12} #{chart_h + 20}", preserveAspectRatio: "none" }
          - trends.each_with_index do |t, i|
            - bar_h  = (t[:failure_count].to_f / max_failures * chart_h).round
            - res_h  = (t[:resolved_count].to_f / max_failures * chart_h).round
            - x      = i * 12
            - bar_y  = chart_h - bar_h
            - res_y  = chart_h - res_h
            - if bar_h > 0
              %rect.bhdash__chart-bar--failure{ x: x, y: bar_y, width: 5, height: bar_h,
                "data-date": t[:date].to_s,
                "data-failures": t[:failure_count],
                "data-resolved": t[:resolved_count] }
            - if res_h > 0
              %rect.bhdash__chart-bar--resolved{ x: x + 6, y: res_y, width: 5, height: res_h }
        .d-flex.mt-1.small.text-muted
          .mr-3
            %span.bhdash__legend-dot.bhdash__legend-dot--failure
            Failures
          .mr-3
            %span.bhdash__legend-dot.bhdash__legend-dot--resolved
            Resolved
      .row.mt-3
        .col-md-4.text-center.small
          %strong.text-danger= trends.sum { |t| t[:failure_count] }
          %div 30日合計 Failures
        .col-md-4.text-center.small
          %strong.text-success= trends.sum { |t| t[:resolved_count] }
          %div 30日合計 Resolved
        .col-md-4.text-center.small
          - total_f = trends.sum { |t| t[:failure_count] }
          - total_r = trends.sum { |t| t[:resolved_count] }
          - trend_rr = total_f > 0 ? (total_r.to_f / total_f * 100).round(1) : 0
          %strong{ class: trend_rr >= 70 ? "text-success" : "text-warning" }= "#{trend_rr}%"
          %div 30日 Recovery Rate

  -# ── Error Analysis ──────────────────────────────────────────────
  .card.shadow-sm.mb-4
    .card-header
      %strong Top Error Classes
    .card-body
      - if error_analysis.empty?
        %p.text-muted.mb-0 障害レコードがありません。
      - else
        - max_count = error_analysis.values.max.to_f
        .table-responsive
          %table.table.table-sm.table-hover.mb-0
            %thead.thead-light
              %tr
                %th Error Class
                %th Count
                %th 割合
            %tbody
              - error_analysis.each do |klass, count|
                %tr
                  %td
                    %code= klass.presence || "(不明)"
                  %td.text-danger.font-weight-bold= count
                  %td{ style: "min-width: 160px;" }
                    .admin-recap-bar__track
                      .admin-recap-bar__fill.admin-recap-bar__fill--failed{ style: "width: #{(count / max_count * 100).round}%" }

  -# ── Open Failures ───────────────────────────────────────────────
  .card.shadow-sm.mb-4
    .card-header.d-flex.justify-content-between.align-items-center
      %strong
        Open Failures
        - if summary[:open_failures] > 0
          %span.badge.badge-danger.ml-1= summary[:open_failures]
    .card-body
      - if open_failures.empty?
        %p.text-success.mb-0
          ✓ 未解決の障害はありません。
      - else
        .table-responsive
          %table.table.table-sm.table-hover.mb-0
            %thead.thead-light
              %tr
                %th Customer
                %th Year
                %th Error Class
                %th Retry Status
                %th Auto Retry
                %th Failed At
                %th Batch
            %tbody
              - open_failures.each do |f|
                %tr
                  %td= f.customer&.name || "(不明)"
                  %td= f.year
                  %td
                    %code= f.error_class.presence || "—"
                  %td
                    %span.badge{ class: f.retry_status_badge_class }= f.retry_status_label
                  %td
                    %span.badge{ class: f.auto_retry_status_badge_class }= f.auto_retry_status_label
                    - if f.auto_retry_scheduled? && f.next_auto_retry_at
                      %br
                      %small.text-muted= l(f.next_auto_retry_at, format: :short)
                  %td.small= f.failed_at ? l(f.failed_at, format: :short) : "—"
                  %td.small
                    - exec = f.singing_recap_movie_batch_execution
                    = link_to "Batch ##{exec.id}", admin_singing_recap_movie_batch_execution_path(exec), class: "badge badge-light"
        - if open_failures.size >= 50
          %p.text-muted.small.mt-2.mb-0 ※ 最大50件を表示しています。

  -# ── Auto Retry Monitoring Dashboard ────────────────────────────
  .card.shadow-sm.mb-4
    .card-header.d-flex.justify-content-between.align-items-center
      %strong
        Auto Retry — Self Healing Monitor
        - if auto_retry_summary[:exhausted] > 0
          %span.badge.badge-danger.ml-1= "#{auto_retry_summary[:exhausted]} exhausted"
        - elsif auto_retry_summary[:due_now] > 0
          %span.badge.badge-warning.ml-1= "#{auto_retry_summary[:due_now]} due"
      = button_to "Auto Retry 対象を実行",
                  run_auto_retries_admin_singing_recap_movies_path,
                  method: :post,
                  class: "btn btn-sm btn-outline-primary",
                  data: { confirm: "Auto Retry 対象を今すぐ実行しますか？" }
    .card-body
      -# Summary cards
      .row.mb-3
        .col-md-2.col-6.mb-2
          - sc = auto_retry_summary[:scheduled]
          = link_to health_admin_singing_recap_movies_path(auto_retry_status: "scheduled"),
                    class: "text-decoration-none" do
            .card.text-center.bhdash__ar-card{ class: @auto_retry_filter == "scheduled" ? "bhdash__ar-card--active border-info" : "border-info" }
              .card-body.py-2
                %p.small.text-muted.mb-1 Scheduled
                %h5.mb-0{ class: sc > 0 ? "text-info" : "text-muted" }= sc
        .col-md-2.col-6.mb-2
          - rn = auto_retry_summary[:running]
          = link_to health_admin_singing_recap_movies_path(auto_retry_status: "running"),
                    class: "text-decoration-none" do
            .card.text-center.bhdash__ar-card{ class: @auto_retry_filter == "running" ? "bhdash__ar-card--active border-warning" : "border-warning" }
              .card-body.py-2
                %p.small.text-muted.mb-1 Running
                %h5.mb-0{ class: rn > 0 ? "text-warning" : "text-muted" }= rn
        .col-md-2.col-6.mb-2
          - ex = auto_retry_summary[:exhausted]
          = link_to health_admin_singing_recap_movies_path(auto_retry_status: "exhausted"),
                    class: "text-decoration-none" do
            .card.text-center.bhdash__ar-card{ class: @auto_retry_filter == "exhausted" ? "bhdash__ar-card--active border-danger" : (ex > 0 ? "bhdash__ar-card--alert border-danger" : "border-danger") }
              .card-body.py-2
                %p.small.text-muted.mb-1
                  Exhausted
                  - if ex > 0
                    %i.fas.fa-exclamation-circle.text-danger
                %h5.mb-0{ class: ex > 0 ? "text-danger font-weight-bold" : "text-muted" }= ex
        .col-md-2.col-6.mb-2
          - dn = auto_retry_summary[:due_now]
          = link_to health_admin_singing_recap_movies_path(auto_retry_status: "due_now"),
                    class: "text-decoration-none" do
            .card.text-center.bhdash__ar-card{ class: @auto_retry_filter == "due_now" ? "bhdash__ar-card--active border-warning" : "border-warning" }
              .card-body.py-2
                %p.small.text-muted.mb-1 Due Now
                %h5.mb-0{ class: dn > 0 ? "text-warning" : "text-muted" }= dn
        .col-md-2.col-6.mb-2
          .card.text-center
            .card-body.py-2
              %p.small.text-muted.mb-1 Next Due At
              - if auto_retry_summary[:next_due_at]
                %small.text-info= l(auto_retry_summary[:next_due_at], format: :short)
              - else
                %small.text-muted —
        .col-md-2.col-6.mb-2
          .card.text-center
            .card-body.py-2
              %p.small.text-muted.mb-1 Avg Attempts
              %h5.mb-0.text-secondary= auto_retry_summary[:avg_attempts] || "—"

      -# Active filter display
      - if @auto_retry_filter
        .d-flex.align-items-center.mb-3
          %span.mr-2.small.text-muted フィルター:
          %span.badge.badge-secondary.mr-2= @auto_retry_filter
          = link_to "× クリア", health_admin_singing_recap_movies_path, class: "btn btn-sm btn-outline-secondary"

      %p.small.text-muted.mb-3
        Auto Retry 対象: timeout / process exit / FFmpeg / Chromium などの一時的エラー（最大#{SingingRecapMovieBatchFailure::AUTO_RETRY_MAX_ATTEMPTS}回）。
        Interval: 1回目 5分後 → 2回目 15分後 → 3回目 30分後。

  -# ── Auto Retry Failure Table ────────────────────────────────────
  .card.shadow-sm.mb-4
    .card-header.d-flex.justify-content-between.align-items-center
      %strong
        Auto Retry — Failure 一覧
        - if @auto_retry_filter
          %span.badge.badge-secondary.ml-1= @auto_retry_filter
        - total_ar = auto_retry_summary[:scheduled] + auto_retry_summary[:running] + auto_retry_summary[:exhausted]
        - if total_ar > 0
          %span.badge.badge-light.ml-1= "計 #{total_ar} 件"
    .card-body
      - if auto_retry_failures.empty?
        %p.text-success.mb-0
          - if @auto_retry_filter
            = "「#{@auto_retry_filter}」に該当する Auto Retry 記録はありません。"
          - else
            ✓ Auto Retry 対象の障害はありません。
      - else
        - if auto_retry_summary[:exhausted] > 0 && (@auto_retry_filter.nil? || @auto_retry_filter == "exhausted")
          .alert.alert-danger.d-flex.align-items-start.mb-3
            .mr-3
              %strong 要手動確認
            %div
              %strong= "#{auto_retry_summary[:exhausted]} 件"
              が Auto Retry 上限 (#{SingingRecapMovieBatchFailure::AUTO_RETRY_MAX_ATTEMPTS}回) に達しました。自動復旧できないため手動対応が必要です。
              = link_to "Exhausted のみ表示 →",
                        health_admin_singing_recap_movies_path(auto_retry_status: "exhausted"),
                        class: "ml-2 btn btn-sm btn-outline-danger"
        .table-responsive
          %table.table.table-sm.table-hover.mb-0
            %thead.thead-light
              %tr
                %th Customer
                %th Year
                %th Batch
                %th Retry Status
                %th Auto Retry
                %th Attempts
                %th Next Retry At
                %th Last Retry At
                %th Error Class
                %th Auto Retry Error
                %th Failed At
            %tbody
              - auto_retry_failures.each do |f|
                - is_exhausted = f.auto_retry_exhausted?
                %tr{ class: is_exhausted ? "table-danger" : nil }
                  %td= f.customer&.name || "(不明)"
                  %td= f.year
                  %td.small
                    - exec = f.singing_recap_movie_batch_execution
                    = link_to "##{exec.id}", admin_singing_recap_movie_batch_execution_path(exec), class: "badge badge-light"
                  %td
                    %span.badge{ class: f.retry_status_badge_class }= f.retry_status_label
                  %td
                    %span.badge{ class: f.auto_retry_status_badge_class }= f.auto_retry_status_label
                    - if is_exhausted
                      %br
                      %small.text-danger.font-weight-bold 要手動確認
                  %td.text-center= f.auto_retry_attempts_count
                  %td.small
                    - if f.next_auto_retry_at && f.auto_retry_scheduled?
                      = l(f.next_auto_retry_at, format: :short)
                    - else
                      %span.text-muted —
                  %td.small
                    - if f.last_auto_retry_at
                      = l(f.last_auto_retry_at, format: :short)
                    - else
                      %span.text-muted —
                  %td
                    %code= f.error_class.presence || "—"
                  %td.small{ style: "max-width: 200px;" }
                    - if f.auto_retry_error_message.present?
                      %span{ title: f.auto_retry_error_message }
                        = truncate(f.auto_retry_error_message, length: 60)
                    - else
                      %span.text-muted —
                  %td.small= f.failed_at ? l(f.failed_at, format: :short) : "—"
        - if auto_retry_failures.size >= Singing::RecapMovieHealthDashboardService::AUTO_RETRY_FAILURES_LIMIT
          %p.text-muted.small.mt-2.mb-0 ※ 最大#{Singing::RecapMovieHealthDashboardService::AUTO_RETRY_FAILURES_LIMIT}件を表示しています。

  -# ── Storage Metrics & Cost Dashboard ───────────────────────────
  - cost   = storage_metrics[:cost_estimation]
  - fmt_bytes = ->(b) do
    - gb = b.to_f / Singing::RecapMovieStorageMetricsService::BYTES_PER_GB
    - if gb >= 1
      - "#{gb.round(2)} GB"
    - elsif b.to_f >= 1_048_576
      - "#{(b.to_f / 1_048_576).round(1)} MB"
    - elsif b.to_f >= 1_024
      - "#{(b.to_f / 1_024).round(1)} KB"
    - else
      - "#{b} B"
  .card.shadow-sm.mb-4
    .card-header
      %strong
        Storage Metrics &amp; Cost Dashboard
      %small.text-muted.ml-2
        = "集計: #{l(storage_metrics[:collected_at], format: :short)}"
    .card-body
      -# ── Summary Cards
      .row.mb-3
        .col-md-3.col-6.mb-3
          .card.text-center.bhdash__card
            .card-body
              %p.bhdash__card-label Attached Movies
              %h3.bhdash__card-value= storage_metrics[:attached_movie_count]
              %p.bhdash__card-sub video_file が存在する件数
        .col-md-3.col-6.mb-3
          .card.text-center.bhdash__card
            .card-body
              %p.bhdash__card-label Total Stored
              %h3.bhdash__card-value= fmt_bytes.call(storage_metrics[:total_bytes])
              %p.bhdash__card-sub ActiveStorage Blob 合計
        .col-md-3.col-6.mb-3
          .card.text-center.bhdash__card
            .card-body
              %p.bhdash__card-label Avg Movie Size
              %h3.bhdash__card-value= fmt_bytes.call(storage_metrics[:avg_bytes])
              %p.bhdash__card-sub 1本あたりの平均サイズ
        .col-md-3.col-6.mb-3
          .card.text-center.bhdash__card
            .card-body
              %p.bhdash__card-label Est. Monthly Cost
              %h3.bhdash__card-value
                = "$#{cost[:monthly_cost_usd]}"
              %p.bhdash__card-sub
                S3 #{cost[:price_per_gb_usd]} USD/GB/月
                %br
                %small.text-muted= cost[:note]

      -# ── Status 別ストレージ
      .row.mb-3
        .col-md-4.col-6.mb-2
          .card.text-center.bhdash__card
            .card-body
              %p.bhdash__card-label Completed
              %h4.bhdash__card-value.text-success= fmt_bytes.call(storage_metrics[:completed_bytes])
              %p.bhdash__card-sub completed 動画の合計
        .col-md-4.col-6.mb-2
          - eb = storage_metrics[:expired_attached_bytes]
          .card.text-center.bhdash__card{ class: eb > 0 ? "border-warning" : "" }
            .card-body
              %p.bhdash__card-label Expired (未削除)
              %h4.bhdash__card-value{ class: eb > 0 ? "text-warning" : "text-muted" }
                = fmt_bytes.call(eb)
              %p.bhdash__card-sub expired だがファイルが残存
        .col-md-4.col-6.mb-2
          .card.text-center.bhdash__card
            .card-body
              %p.bhdash__card-label 直近#{Singing::RecapMovieStorageMetricsService::RECENT_DAYS}日 生成
              %h4.bhdash__card-value.text-info= fmt_bytes.call(storage_metrics[:recent_bytes])
              %p.bhdash__card-sub 直近30日 generated

      -# ── Year Breakdown
      - unless storage_metrics[:year_breakdown].empty?
        %h6.font-weight-bold.mt-2.mb-2 Year Breakdown
        - max_year_bytes = storage_metrics[:year_breakdown].map { |r| r[:bytes] }.max.to_f
        - max_year_bytes = 1.0 if max_year_bytes.zero?
        .table-responsive
          %table.table.table-sm.mb-3
            %thead.thead-light
              %tr
                %th Year
                %th 件数
                %th ストレージ
                %th 割合
            %tbody
              - storage_metrics[:year_breakdown].each do |row|
                %tr
                  %td.font-weight-bold= row[:year]
                  %td= row[:count]
                  %td= fmt_bytes.call(row[:bytes])
                  %td{ style: "min-width: 120px;" }
                    .admin-recap-bar__track
                      .admin-recap-bar__fill{ style: "width: #{(row[:bytes].to_f / max_year_bytes * 100).round}%; background: #2258d8;" }

      -# ── Plan Breakdown
      - unless storage_metrics[:plan_breakdown].empty?
        %h6.font-weight-bold.mt-2.mb-2 Plan Breakdown
        - max_plan_bytes = storage_metrics[:plan_breakdown].map { |r| r[:bytes] }.max.to_f
        - max_plan_bytes = 1.0 if max_plan_bytes.zero?
        - plan_colors = { "premium" => "#ef6c3f", "core" => "#2258d8", "light" => "#6f42c1", "free" => "#6c757d" }
        .table-responsive
          %table.table.table-sm.mb-0
            %thead.thead-light
              %tr
                %th Plan
                %th 件数
                %th ストレージ
                %th 割合
            %tbody
              - storage_metrics[:plan_breakdown].each do |row|
                - bar_color = plan_colors[row[:plan]] || "#adb5bd"
                %tr
                  %td
                    %span.badge.badge-secondary= row[:plan]
                  %td= row[:count]
                  %td= fmt_bytes.call(row[:bytes])
                  %td{ style: "min-width: 120px;" }
                    .admin-recap-bar__track
                      .admin-recap-bar__fill{ style: "width: #{(row[:bytes].to_f / max_plan_bytes * 100).round}%; background: #{bar_color};" }
      - if storage_metrics[:attached_movie_count].zero?
        %p.text-muted.mb-0 まだ動画ファイルが存在しません。

  -# ── Storage Trend Analytics ─────────────────────────────────────
  - trend30 = storage_trends_30d
  - trend7  = storage_trends_7d
  - fmt_bytes_trend = ->(b) do
    - gb = b.to_f / Singing::RecapMovieStorageMetricsService::BYTES_PER_GB
    - if gb >= 1
      - "#{gb.round(2)} GB"
    - elsif b.to_f >= 1_048_576
      - "#{(b.to_f / 1_048_576).round(1)} MB"
    - else
      - "#{b} B"
  .card.shadow-sm.mb-4
    .card-header.d-flex.justify-content-between.align-items-center
      %strong
        Storage Trend Analytics
        - if trend30[:has_data]
          %span.badge.badge-info.ml-2= "#{trend30[:snapshot_count]} snapshots"
        - else
          %span.badge.badge-secondary.ml-2 データ蓄積中
      %small.text-muted
        日次スナップショットによる推移可視化
    .card-body
      - unless trend30[:has_data]
        .alert.alert-info.mb-0
          %strong データがまだ不足しています
          %br
          %small
            Storage Snapshot を最低2日分蓄積すると推移グラフが表示されます。
            %br
            cron または
            %code bin/capture_recap_movie_storage_snapshot
            を実行してください。

      - if trend30[:has_data]
        -# ── 期間サマリーカード (30日)
        .row.mb-4
          .col-md-3.col-6.mb-3
            - g30 = trend30[:storage_growth]
            - delta_cls = g30[:delta_bytes] >= 0 ? "text-warning" : "text-success"
            .card.text-center.bhdash__card
              .card-body
                %p.bhdash__card-label 30日 Storage 増減
                %h4.bhdash__card-value{ class: delta_cls }
                  = g30[:delta_bytes] >= 0 ? "+" : ""
                  = fmt_bytes_trend.call(g30[:delta_bytes].abs)
                %p.bhdash__card-sub
                  = "#{g30[:first_total_bytes] == 0 ? "—" : "#{g30[:growth_pct]}%"} 増減"
          .col-md-3.col-6.mb-3
            - g30 = trend30[:storage_growth]
            .card.text-center.bhdash__card
              .card-body
                %p.bhdash__card-label 日平均増加量
                %h4.bhdash__card-value.text-info= fmt_bytes_trend.call(g30[:daily_avg_bytes].abs)
                %p.bhdash__card-sub 30日平均
          .col-md-3.col-6.mb-3
            - c30 = trend30[:cost_trend]
            - delta_cost = c30[:delta_usd].to_f
            - dcls = delta_cost >= 0 ? "text-warning" : "text-success"
            .card.text-center.bhdash__card
              .card-body
                %p.bhdash__card-label 30日 コスト増減
                %h4.bhdash__card-value{ class: dcls }
                  - if c30[:delta_usd]
                    = delta_cost >= 0 ? "+" : ""
                    = "$#{c30[:delta_usd].abs}"
                  - else
                    %span.text-muted —
                %p.bhdash__card-sub
                  = c30[:first_usd] ? "$#{c30[:first_usd]} → $#{c30[:last_usd]}" : "—"
          .col-md-3.col-6.mb-3
            - cl30 = trend30[:cleanup_effect]
            .card.text-center.bhdash__card{ class: cl30[:reduced_bytes] > 0 ? "border-success" : "" }
              .card-body
                %p.bhdash__card-label Cleanup削減効果
                %h4.bhdash__card-value{ class: cl30[:reduced_bytes] > 0 ? "text-success" : "text-muted" }
                  = fmt_bytes_trend.call(cl30[:reduced_bytes])
                %p.bhdash__card-sub expired bytes 最大→最小

        -# ── SVG グラフ (30日 total_bytes 推移)
        - series30 = trend30[:snapshots]
        - if series30.size >= 2
          %h6.font-weight-bold.mb-2 30日 Total Storage 推移
          - max_bytes30 = series30.map { |s| s[:total_bytes] }.max.to_f
          - max_bytes30 = 1.0 if max_bytes30.zero?
          - chart_h30  = 80
          - chart_w30  = series30.size * 14
          .bhdash__chart-wrap.mb-3
            %svg.bhdash__chart{ viewBox: "0 0 #{chart_w30} #{chart_h30 + 20}", preserveAspectRatio: "none", style: "width: 100%; height: 110px;" }
              -# completed_bytes 塗り (青)
              - series30.each_with_index do |s, i|
                - bar_h  = (s[:completed_bytes].to_f / max_bytes30 * chart_h30).round
                - x      = i * 14
                - bar_y  = chart_h30 - bar_h
                - if bar_h > 0
                  %rect{ x: x, y: bar_y, width: 10, height: bar_h, fill: "#2258d8", opacity: "0.7",
                    "data-date": s[:date].to_s,
                    "data-total": s[:total_bytes],
                    "data-completed": s[:completed_bytes] }
              -# expired_attached_bytes (オレンジ)
              - series30.each_with_index do |s, i|
                - exp_h = (s[:expired_attached_bytes].to_f / max_bytes30 * chart_h30).round
                - x     = i * 14
                - exp_y = chart_h30 - exp_h
                - if exp_h > 0
                  %rect{ x: x, y: exp_y, width: 10, height: exp_h, fill: "#ef6c3f", opacity: "0.6" }
            .d-flex.mt-1.small.text-muted
              .mr-3
                %span{ style: "display:inline-block;width:10px;height:10px;background:#2258d8;border-radius:2px;margin-right:4px;" }
                Completed
              .mr-3
                %span{ style: "display:inline-block;width:10px;height:10px;background:#ef6c3f;border-radius:2px;margin-right:4px;" }
                Expired (未削除)

        -# ── 7日推移テーブル
        - series7 = trend7[:snapshots]
        - if series7.present?
          %h6.font-weight-bold.mb-2.mt-4 直近7日 スナップショット詳細
          .table-responsive
            %table.table.table-sm.table-hover.mb-0
              %thead.thead-light
                %tr
                  %th Date
                  %th Movies
                  %th Total Stored
                  %th Completed
                  %th Expired (残存)
                  %th Est. Cost/月
              %tbody
                - series7.reverse.each do |s|
                  %tr
                    %td.font-weight-bold= s[:date]
                    %td= s[:attached_movie_count]
                    %td= fmt_bytes_trend.call(s[:total_bytes])
                    %td.text-success= fmt_bytes_trend.call(s[:completed_bytes])
                    %td{ class: s[:expired_attached_bytes] > 0 ? "text-warning" : "text-muted" }
                      = fmt_bytes_trend.call(s[:expired_attached_bytes])
                    %td= "$#{s[:estimated_monthly_cost_usd].round(4)}"
          - if trend7[:oldest_snapshot_at]
            %p.small.text-muted.mt-2.mb-0
              = "集計期間: #{trend7[:oldest_snapshot_at]} 〜 #{trend7[:latest_snapshot_at]}"

  -# ── Storage & Expiry ────────────────────────────────────────────
  .card.shadow-sm.mb-4
    .card-header.d-flex.justify-content-between.align-items-center
      %strong
        Storage & Expiry — Cleanup Monitor
        - if storage_expiry[:cleanup_pending] > 0
          %span.badge.badge-warning.ml-1= "#{storage_expiry[:cleanup_pending]} pending"
      = button_to "Cleanup Job を実行",
                  run_cleanup_admin_singing_recap_movies_path,
                  method: :post,
                  class: "btn btn-sm btn-outline-warning",
                  data: { confirm: "期限切れ Movie #{storage_expiry[:cleanup_pending]}件を今すぐCleanupしますか？" }
    .card-body
      .row.mb-2
        .col-md-3.col-6.mb-3
          - cp = storage_expiry[:cleanup_pending]
          - cp_cls = cp.zero? ? "text-success" : cp < 50 ? "text-warning" : "text-danger"
          .card.text-center.bhdash__card
            .card-body
              %p.bhdash__card-label Cleanup Pending
              %h3.bhdash__card-value{ class: cp_cls }= cp
              %p.bhdash__card-sub expires_at 超過・未処理
        .col-md-3.col-6.mb-3
          .card.text-center.bhdash__card
            .card-body
              %p.bhdash__card-label Expired (処理済)
              %h3.bhdash__card-value.text-secondary= storage_expiry[:expired_total]
              %p.bhdash__card-sub status = expired
        .col-md-3.col-6.mb-3
          .card.text-center.bhdash__card
            .card-body
              %p.bhdash__card-label Recently Cleaned
              %h3.bhdash__card-value.text-info= storage_expiry[:recently_cleaned]
              %p.bhdash__card-sub 直近7日で cleanup 済み
        .col-md-3.col-6.mb-3
          - es = storage_expiry[:expiring_soon]
          - es_cls = es.zero? ? "text-muted" : es < 20 ? "text-warning" : "text-danger"
          .card.text-center.bhdash__card
            .card-body
              %p.bhdash__card-label Expiring Soon
              %h3.bhdash__card-value{ class: es_cls }= es
              %p.bhdash__card-sub 7日以内に期限切れ予定
      %p.small.text-muted.mb-0
        Cleanup Job:
        %code Singing::CleanupGeneratedRecapMoviesJob
        (バッチ上限 #{Singing::CleanupGeneratedRecapMoviesJob::BATCH_LIMIT}件/回)。
        期限切れ Movie の S3 ファイルを
        %code purge_later
        し、
        %code cleaned_up_at
        を記録します。

  -# ── Storage Auto Repair ────────────────────────────────────────
  .card.shadow-sm.mb-4{ class: storage_audit[:has_anomalies] ? "border-warning" : "" }
    .card-header.d-flex.justify-content-between.align-items-center
      %strong
        Storage Auto Repair
        - if storage_audit[:has_anomalies]
          - total_repairable = storage_audit[:completed_without_file_count] + storage_audit[:cleaned_but_attached_count]
          %span.badge.badge-warning.ml-1= "#{total_repairable} 件修復可能"
        - else
          %span.badge.badge-success.ml-1 修復対象なし
      .d-flex.gap-2
        = button_to "Dry Run で確認",
                    run_storage_repair_admin_singing_recap_movies_path(dry_run: "true"),
                    method: :post,
                    class: "btn btn-sm btn-outline-secondary mr-2",
                    data: { confirm: "Dry Run モードで修復対象を確認しますか？（実際の変更は行いません）" }
        - if storage_audit[:has_anomalies]
          = button_to "修復を実行",
                      run_storage_repair_admin_singing_recap_movies_path(dry_run: "false"),
                      method: :post,
                      class: "btn btn-sm btn-outline-danger",
                      data: { confirm: "Storage 修復を実行しますか？\n\n【cleaned_but_attached】purge_later を再実行します。\n【completed_without_file】status を failed に変更します。\n\n実行前に Dry Run での確認を推奨します。" }
    .card-body
      .alert.alert-warning.d-flex.align-items-start.mb-3
        .mr-3
          %i.fas.fa-tools
        %div
          %strong Storage 整合性の自動修復
          %br
          %small
            【cleaned_but_attached】purge_later を再実行してファイルを削除します（S3 直接操作は行いません）。
            %br
            【completed_without_file】status を failed に変更します（自動再生成・ファイル削除は行いません）。
            %br
            必ず Dry Run で確認してから実行してください。

      .row.mb-2
        .col-md-6.mb-3
          - cwf = storage_audit[:completed_without_file_count]
          .card.text-center.bhdash__card{ class: cwf > 0 ? "border-danger" : "" }
            .card-body
              %p.bhdash__card-label Completed without File
              %h3.bhdash__card-value{ class: cwf > 0 ? "text-danger" : "text-success" }= cwf
              %p.bhdash__card-sub
                修復: status → failed
                %br
                %small.text-muted 自動再生成・削除はしない
        .col-md-6.mb-3
          - cba = storage_audit[:cleaned_but_attached_count]
          .card.text-center.bhdash__card{ class: cba > 0 ? "border-warning" : "" }
            .card-body
              %p.bhdash__card-label Cleaned but Attached
              %h3.bhdash__card-value{ class: cba > 0 ? "text-warning" : "text-success" }= cba
              %p.bhdash__card-sub
                修復: purge_later 再実行
                %br
                %small.text-muted S3 直接削除は行わない

      - unless storage_audit[:has_anomalies]
        %p.text-success.mb-0
          ✓ 修復対象の Storage 異常は検知されていません。

  -# ── Storage Audit (検知のみ・削除なし) ──────────────────────────
  .card.shadow-sm.mb-4{ class: storage_audit[:has_anomalies] ? "border-danger" : "" }
    .card-header.d-flex.justify-content-between.align-items-center
      %strong
        Storage Audit — 孤立 / 不整合 検知
        - if storage_audit[:has_anomalies]
          %span.badge.badge-danger.ml-1 異常あり
        - else
          %span.badge.badge-success.ml-1 異常なし
      %small.text-muted
        検知のみ（削除は行いません）
        = "／ 最終確認: #{l(storage_audit[:audited_at], format: :short)}"
    .card-body
      .alert.alert-info.d-flex.align-items-start.mb-3
        .mr-3
          %i.fas.fa-info-circle
        %div
          このセクションは Storage の整合性チェック結果を表示します。
          %strong 削除・更新は行いません。
          異常が検知された場合は Storage Auto Repair セクションから修復できます。

      .row.mb-3
        .col-md-6.mb-3
          - cwf_count = storage_audit[:completed_without_file_count]
          - cwf_cls   = cwf_count.zero? ? "text-success" : "text-danger"
          .card.text-center.bhdash__card{ class: cwf_count > 0 ? "border-danger" : "" }
            .card-body
              %p.bhdash__card-label Completed without File
              %h3.bhdash__card-value{ class: cwf_cls }= cwf_count
              %p.bhdash__card-sub
                status=completed だが video_file が存在しない
                %br
                %small.text-muted (S3 消失 / purge 競合の可能性)
        .col-md-6.mb-3
          - cba_count = storage_audit[:cleaned_but_attached_count]
          - cba_cls   = cba_count.zero? ? "text-success" : "text-warning"
          .card.text-center.bhdash__card{ class: cba_count > 0 ? "border-warning" : "" }
            .card-body
              %p.bhdash__card-label Cleaned but Attached
              %h3.bhdash__card-value{ class: cba_cls }= cba_count
              %p.bhdash__card-sub
                cleaned_up_at 記録済みだが video_file がまだ存在する
                %br
                %small.text-muted (purge_later 遅延 / 失敗の可能性)

      -# Completed without File 詳細テーブル
      - unless storage_audit[:completed_without_file].empty?
        %h6.font-weight-bold.text-danger.mt-3.mb-2
          Completed without File — 詳細
          %span.badge.badge-danger.ml-1= storage_audit[:completed_without_file_count]
        .table-responsive
          %table.table.table-sm.table-hover.mb-3
            %thead.thead-light
              %tr
                %th ID
                %th Customer
                %th Year
                %th expires_at
                %th generated_at
                %th updated_at
            %tbody
              - storage_audit[:completed_without_file].each do |m|
                %tr.table-danger
                  %td= m.id
                  %td= m.customer&.name || "(不明)"
                  %td= m.year
                  %td.small= m.expires_at ? l(m.expires_at, format: :short) : "—"
                  %td.small= m.generated_at ? l(m.generated_at, format: :short) : "—"
                  %td.small= l(m.updated_at, format: :short)
        - if storage_audit[:completed_without_file_count] > Singing::RecapMovieStorageAuditService::AUDIT_RECORD_LIMIT
          %p.text-muted.small.mb-0
            = "※ 最大#{Singing::RecapMovieStorageAuditService::AUDIT_RECORD_LIMIT}件を表示しています。"

      -# Cleaned but Attached 詳細テーブル
      - unless storage_audit[:cleaned_but_attached].empty?
        %h6.font-weight-bold.text-warning.mt-3.mb-2
          Cleaned but Attached — 詳細
          %span.badge.badge-warning.ml-1= storage_audit[:cleaned_but_attached_count]
        .table-responsive
          %table.table.table-sm.table-hover.mb-3
            %thead.thead-light
              %tr
                %th ID
                %th Customer
                %th Year
                %th cleaned_up_at
                %th expires_at
                %th updated_at
            %tbody
              - storage_audit[:cleaned_but_attached].each do |m|
                %tr.table-warning
                  %td= m.id
                  %td= m.customer&.name || "(不明)"
                  %td= m.year
                  %td.small= m.cleaned_up_at ? l(m.cleaned_up_at, format: :short) : "—"
                  %td.small= m.expires_at ? l(m.expires_at, format: :short) : "—"
                  %td.small= l(m.updated_at, format: :short)
        - if storage_audit[:cleaned_but_attached_count] > Singing::RecapMovieStorageAuditService::AUDIT_RECORD_LIMIT
          %p.text-muted.small.mb-0
            = "※ 最大#{Singing::RecapMovieStorageAuditService::AUDIT_RECORD_LIMIT}件を表示しています。"

      - if !storage_audit[:has_anomalies]
        %p.text-success.mb-0
          ✓ Storage の整合性に問題は検知されませんでした。

  -# ── Slow Batch Analysis ─────────────────────────────────────────
  .card.shadow-sm.mb-4
    .card-header
      %strong Slow Batch Analysis (Top 10)
    .card-body
      - if slow_batches.empty?
        %p.text-muted.mb-0 バッチ実行履歴がありません。
      - else
        .table-responsive
          %table.table.table-sm.table-hover.mb-0
            %thead.thead-light
              %tr
                %th Batch
                %th Year
                %th Status
                %th Duration
                %th Total Movies
                %th Failures
                %th Started At
            %tbody
              - max_dur = slow_batches.map { |b| (b.finished_at - b.started_at).to_i }.max.to_f
              - slow_batches.each do |b|
                - dur = (b.finished_at - b.started_at).to_i
                %tr
                  %td= link_to "##{b.id}", admin_singing_recap_movie_batch_execution_path(b)
                  %td= b.year
                  %td
                    - badge_cls = { "completed" => "badge-success", "failed" => "badge-danger",
                                    "running" => "badge-warning", "enqueued" => "badge-secondary",
                                    "cancelled" => "badge-dark" }[b.status] || "badge-light"
                    %span.badge{ class: badge_cls }= b.status
                  %td
                    .d-flex.align-items-center
                      .admin-recap-bar__track.flex-grow-1.mr-2{ style: "max-width: 80px;" }
                        .admin-recap-bar__fill{ style: "width: #{max_dur > 0 ? (dur / max_dur * 100).round : 0}%; background: #6f42c1;" }
                      %span.small
                        - if dur < 60
                          = "#{dur}s"
                        - else
                          = "#{dur / 60}m #{dur % 60}s"
                  %td= b.total_movies_count
                  %td.text-danger= b.failed_movies_count
                  %td.small= b.started_at ? l(b.started_at, format: :short) : "—"
