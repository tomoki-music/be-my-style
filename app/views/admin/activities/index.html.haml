= render 'layouts/admin_header_menu'

.container.py-4
  .d-flex.justify-content-between.align-items-center.mb-3
    %h2.mb-0 Activity一覧
    = link_to "新規登録", new_admin_activity_path, class: "btn btn-primary"

  .table-responsive
    %table.table.table-striped.table-bordered
      %thead
        %tr
          %th ID
          %th タイトル
          %th 投稿者
          %th いいね数
          %th コメント数
          %th 投稿日
          %th
      %tbody
        - @activities.each do |activity|
          %tr
            %td= activity.id
            %td= activity.title
            %td= activity.customer&.name
            %td= activity.favorites.count
            %td= activity.comments.count
            %td= l activity.created_at, format: :short
            %td.text-nowrap
              = link_to "詳細", admin_activity_path(activity), class: "btn btn-sm btn-outline-primary"
              = link_to "編集", edit_admin_activity_path(activity), class: "btn btn-sm btn-outline-success"
              = link_to "削除", admin_activity_path(activity), method: :delete, data: { confirm: "この活動報告を削除しますか？" }, class: "btn btn-sm btn-outline-danger"
