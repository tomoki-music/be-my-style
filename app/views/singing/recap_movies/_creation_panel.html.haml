- e = eligibility

.srm-creation-panel
  .srm-creation-panel__about
    .srm-creation-panel__about-icon 🎬
    .srm-creation-panel__about-body
      %p.srm-creation-panel__about-title Recap Movie とは？
      %p.srm-creation-panel__about-desc
        対象年の完了済み歌声診断をもとに、1年間の成長を短い動画にまとめる機能です。
        対象年内に完了済み診断が#{e.required_diagnoses_count}件以上あると作成できます。

  .srm-creation-panel__requirement
    %p.srm-creation-panel__requirement-title Recap Movie 作成条件
    .srm-creation-panel__requirement-grid
      .srm-creation-panel__requirement-row
        %span.srm-creation-panel__requirement-label 対象期間
        %span.srm-creation-panel__requirement-value= e.period_label
      .srm-creation-panel__requirement-row
        %span.srm-creation-panel__requirement-label 必要な完了済み診断
        %span.srm-creation-panel__requirement-value= "#{e.required_diagnoses_count}件"
      .srm-creation-panel__requirement-row
        %span.srm-creation-panel__requirement-label 現在の完了済み診断
        %span.srm-creation-panel__requirement-value= "#{e.completed_diagnoses_count}件"
      - if e.remaining_diagnoses_count > 0
        .srm-creation-panel__requirement-row.srm-creation-panel__requirement-row--progress
          %span.srm-creation-panel__requirement-label あと
          %span.srm-creation-panel__requirement-value= "#{e.remaining_diagnoses_count}件で作成できます"

  .srm-creation-panel__status
    - case e.reason
    - when :no_diagnosis
      .srm-creation-status.srm-creation-status--neutral
        .srm-creation-status__icon 🎤
        .srm-creation-status__body
          %p.srm-creation-status__label 診断がまだありません
          %p.srm-creation-status__desc 歌声診断を完了すると、Recap Movieを作成できるようになります。
        .srm-creation-status__action
          = link_to "歌声診断を始める", new_singing_diagnosis_path, class: "srm-btn srm-btn--primary srm-btn--sm"

    - when :not_enough_diagnoses
      .srm-creation-status.srm-creation-status--neutral
        .srm-creation-status__icon ⬆
        .srm-creation-status__body
          %p.srm-creation-status__label= "あと#{e.remaining_diagnoses_count}件で作成できます"
          %p.srm-creation-status__desc= "現在#{e.completed_diagnoses_count}件 / 必要#{e.required_diagnoses_count}件。診断を続けて条件を満たしましょう。"
        .srm-creation-status__action
          = link_to "歌声診断を始める", new_singing_diagnosis_path, class: "srm-btn srm-btn--primary srm-btn--sm"

    - when :eligible
      .srm-creation-status.srm-creation-status--eligible
        .srm-creation-status__icon ✦
        .srm-creation-status__body
          %p.srm-creation-status__label= "条件を満たしています。#{e.year}年のRecap Movieを作成できます。"
          %p.srm-creation-status__desc= "完了済み診断 #{e.completed_diagnoses_count} 件が対象です。"
        .srm-creation-status__action
          = button_to "Recap Movieの作成を予約する", request_generation_singing_recap_movies_path,
              method: :post, class: "srm-btn srm-btn--coral srm-btn--sm"

    - when :retry_failed
      .srm-creation-status.srm-creation-status--warning
        .srm-creation-status__icon ✕
        .srm-creation-status__body
          %p.srm-creation-status__label= "#{e.year}年の生成に失敗しました"
          %p.srm-creation-status__desc 再生成をリクエストできます。
        .srm-creation-status__action
          = button_to "再生成をリクエスト", request_generation_singing_recap_movies_path,
              method: :post, class: "srm-btn srm-btn--coral srm-btn--sm"

    - when :retry_expired
      .srm-creation-status.srm-creation-status--neutral
        .srm-creation-status__icon ⊘
        .srm-creation-status__body
          %p.srm-creation-status__label= "#{e.year}年のRecap Movieの期限が切れています"
          %p.srm-creation-status__desc 再生成できます。
        .srm-creation-status__action
          = button_to "もう一度作成する", request_generation_singing_recap_movies_path,
              method: :post, class: "srm-btn srm-btn--coral srm-btn--sm"

    - when :already_pending
      .srm-creation-status.srm-creation-status--progress
        .srm-creation-status__icon
          %span.srm-spinner-sm
        .srm-creation-status__body
          %p.srm-creation-status__label= "#{e.year}年のRecap Movie：作成予約済みです"
          %p.srm-creation-status__desc
            作成予約済みです。動画生成はサーバー負荷を避けるため、順番に作成されます。
            %br
            完成後、このページに表示されます。
        .srm-creation-status__action
          - if e.existing_movie
            = link_to "状況を確認する", singing_recap_movie_path(e.existing_movie), class: "srm-btn srm-btn--secondary srm-btn--sm"

    - when :already_processing
      .srm-creation-status.srm-creation-status--progress
        .srm-creation-status__icon
          %span.srm-spinner-sm
        .srm-creation-status__body
          %p.srm-creation-status__label= "#{e.year}年のRecap Movie：作成中です"
          %p.srm-creation-status__desc 作成中です。しばらくしてからページを更新してください。
        .srm-creation-status__action
          - if e.existing_movie
            = link_to "状況を確認する", singing_recap_movie_path(e.existing_movie), class: "srm-btn srm-btn--secondary srm-btn--sm"

    - when :already_completed
      .srm-creation-status.srm-creation-status--done
        .srm-creation-status__icon ✦
        .srm-creation-status__body
          %p.srm-creation-status__label= "#{e.year}年のRecap Movieは作成済みです"
          %p.srm-creation-status__desc 下の一覧から動画を確認・シェアできます。
        .srm-creation-status__action
          - if e.existing_movie
            = link_to "Recapを見る", singing_recap_movie_path(e.existing_movie), class: "srm-btn srm-btn--primary srm-btn--sm"
