.srm-show
  .srm-inner
    .srm-nav
      = link_to singing_recap_movies_path, class: "srm-back-link" do
        &larr; Recap Movie 一覧へ

    .srm-hero
      .srm-hero__eyebrow
        %span.srm-hero__icon 🎬
        %span.srm-hero__label Your Singing Recap
      %h1.srm-hero__title= "#{@recap_movie.year} Recap Movie"
      .srm-hero__meta
        %span.srm-badge{ class: "srm-badge--#{@recap_movie.status}" }
          - case @recap_movie.status
          - when "completed"
            ✦ Completed
          - when "processing"
            ◌ Generating...
          - when "pending"
            ◌ Queued
          - when "failed"
            ✕ Failed
          - when "expired"
            ⊘ Expired
        - if @recap_movie.generated_at.present?
          %span.srm-hero__date
            Generated on
            = @recap_movie.generated_at.strftime("%-m月%-d日, %Y")

    - props = @movie_props || {}
    - has_stats = props[:diagnosis_count].to_i > 0
    - if has_stats
      .srm-meta-grid
        .srm-meta-item
          .srm-meta-item__icon 🎤
          .srm-meta-item__value= "#{props[:diagnosis_count]}回"
          .srm-meta-item__label 診断回数
        - if props[:best_score].present?
          .srm-meta-item
            .srm-meta-item__icon 🏆
            .srm-meta-item__value= props[:best_score]
            .srm-meta-item__label ベストスコア
        - if props[:average_score].present?
          .srm-meta-item
            .srm-meta-item__icon 📊
            .srm-meta-item__value= props[:average_score]
            .srm-meta-item__label 平均スコア
        - if props[:top_growth_metric].present?
          .srm-meta-item
            .srm-meta-item__icon 📈
            .srm-meta-item__value= props[:top_growth_metric]
            .srm-meta-item__label 最も成長
        - if props[:voice_type].present?
          .srm-meta-item.srm-meta-item--wide
            .srm-meta-item__icon 🔥
            .srm-meta-item__value= props[:voice_type]
            .srm-meta-item__label ボイスタイプ

    .srm-show-body
      - if @recap_movie.completed? && @recap_movie.video_file.attached?
        .srm-video-wrap
          = video_tag url_for(@recap_movie.video_file),
            controls: true,
            playsinline: true,
            class: "srm-video"

        .srm-video-note
          %p スマホを縦向きにすると見やすくなります。

      - elsif @recap_movie.processing? || @recap_movie.pending?
        .srm-status-panel.srm-status-panel--processing
          .srm-status-panel__icon
            .srm-spinner
          %p.srm-status-panel__title あなた専用のRecap Movieを生成しています
          %p.srm-status-panel__desc 数分かかる場合があります。ページを再読み込みすると最新状態を確認できます。

      - elsif @recap_movie.failed?
        .srm-status-panel.srm-status-panel--failed
          .srm-status-panel__icon 😔
          %p.srm-status-panel__title 動画の生成に失敗しました
          %p.srm-status-panel__desc 時間をおいて再試行するか、サポートまでお問い合わせください。
          - if Rails.env.development? && @recap_movie.error_message.present?
            %details.srm-error-detail
              %summary エラー詳細（開発環境のみ）
              %pre.srm-error-pre= @recap_movie.error_message

      - elsif @recap_movie.expired?
        .srm-status-panel.srm-status-panel--expired
          .srm-status-panel__icon ⏰
          %p.srm-status-panel__title 動画の保存期限が切れました
          %p.srm-status-panel__desc Recap Movie の保存期限が過ぎました。再生成はバッジページからリクエストできます。
          = link_to "バッジページへ", singing_badges_path, class: "srm-btn srm-btn--secondary"

    .srm-show-footer
      = link_to "一覧へ戻る", singing_recap_movies_path, class: "srm-btn srm-btn--ghost"
