.srm-index
  .srm-inner
    .srm-nav
      = link_to singing_root_path, class: "srm-back-link" do
        &larr; トップへ戻る

    .srm-header
      %p.srm-header__eyebrow Singing / Recap Movie
      %h1.srm-header__title Recap Movie
      %p.srm-header__subtitle
        歌声診断の記録から自動生成される、あなたの1年間の成長ムービーです。
        SNSでシェアして、続けてきた自分を振り返りましょう。

    = render "singing/recap_movies/creation_panel", eligibility: @eligibility

    - if @recap_movies.empty?
      .srm-empty
        .srm-empty__icon 🎬
        %p.srm-empty__title まだ Recap Movie はありません
        %p.srm-empty__desc
          Recap Movie は、あなたの歌声診断の記録をもとに、
          %br
          1年間の成長を短い動画にまとめる機能です。
        .srm-empty__actions
          - if @eligibility.eligible?
            = button_to "Recap Movieを作成する", request_generation_singing_recap_movies_path,
                method: :post, class: "srm-btn srm-btn--primary"
          - else
            = link_to "歌声診断を始める", new_singing_diagnosis_path, class: "srm-btn srm-btn--primary"
          = link_to "バッジ・リワード", singing_badges_path, class: "srm-btn srm-btn--secondary"
    - else
      .srm-list
        - @recap_movies.each do |movie|
          = link_to singing_recap_movie_path(movie), class: "srm-card srm-card--#{movie.status}" do
            .srm-card__year
              %span.srm-card__year-num= movie.year
              %span.srm-card__year-label 年

            .srm-card__body
              - case movie.status
              - when "completed"
                %span.srm-badge.srm-badge--completed ✦ Completed
                %p.srm-card__desc 動画を再生できます。
              - when "processing"
                %span.srm-badge.srm-badge--processing ◌ Generating...
                %p.srm-card__desc あなた専用のRecap Movieを生成しています。数分かかる場合があります。
              - when "pending"
                %span.srm-badge.srm-badge--pending ◌ Queued
                %p.srm-card__desc 生成キューに入っています。
              - when "failed"
                %span.srm-badge.srm-badge--failed ✕ Failed
                %p.srm-card__desc 生成に失敗しました。
              - when "expired"
                %span.srm-badge.srm-badge--expired ⊘ Expired
                %p.srm-card__desc 動画の保存期限が切れました。

            .srm-card__arrow
              - if movie.completed? && movie.video_file.attached?
                %span.srm-card__cta 動画を見る &rarr;
              - else
                %span.srm-card__cta 詳細を見る &rarr;
