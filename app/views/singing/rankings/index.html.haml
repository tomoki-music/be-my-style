.singing-ranking
  .singing-ranking__hero
    .singing-ranking__hero-inner
      %p.singing-ranking__eyebrow RANKING
      %h1.singing-ranking__hero-title
        みんなの演奏力
        %br
        ランキング
      - case @ranking_type
      - when "growth"
        %p.singing-ranking__hero-subtitle
          前回の診断からスコアが伸びたユーザーを称えるランキングです。
          %br
          挑戦し続ける全ての方を応援しています。
      - when "season"
        %p.singing-ranking__hero-subtitle
          - if @current_season
            = @current_season.name
            &mdash;
          = @season_range.begin.strftime("%Y年%-m月")
          のランキングです。
          %br
          毎月リセットされるので、何度でも挑戦できます。
      - else
        %p.singing-ranking__hero-subtitle
          歌唱・演奏診断を受けたユーザーの中から、
          %br
          ランキング参加者のベストスコアを公開しています。

  .singing-ranking__inner
    - case @ranking_type
    - when "growth"
      = render "singing/rankings/my_growth_position",
               my_growth_entry: @my_growth_entry,
               my_completed_count: @my_completed_count.to_i,
               my_badges: @my_badges,
               ranking_plan_context: @ranking_plan_context
    - when "season"
      = render "singing/rankings/my_season_position",
               my_season_diagnosis: @my_season_diagnosis,
               my_season_position: @my_season_position,
               my_season_has_diagnosis_this_month: @my_season_has_diagnosis_this_month,
               my_badges: @my_badges,
               season_range: @season_range,
               ranking_plan_context: @ranking_plan_context
    - else
      = render "singing/rankings/my_position",
               my_position: @my_position,
               my_best_diagnosis: @my_best_diagnosis,
               my_badges: @my_badges

    = render "singing/rankings/tabs", ranking_type: @ranking_type

    - case @ranking_type
    - when "growth"
      = render "singing/rankings/growth",
               growth_rankings: @growth_rankings,
               badges_map: @badges_map,
               ranking_plan_context: @ranking_plan_context
    - when "season"
      = render "singing/rankings/season",
               season_rankings: @season_rankings,
               season_range: @season_range,
               current_season: @current_season,
               season_entries_by_diagnosis: @season_entries_by_diagnosis,
               badges_map: @badges_map,
               ranking_plan_context: @ranking_plan_context
    - else
      = render "singing/rankings/overall", rankings: @rankings, badges_map: @badges_map

    .singing-ranking__privacy-notice
      .singing-ranking__privacy-icon
        %span i
      .singing-ranking__privacy-text
        %strong ランキング参加は任意です。
        診断時に「ランキングに参加する」を選択したユーザーのみ表示されます。
        参加の有無が診断内容や結果に影響することはありません。

    - unless @ranking_type == "season"
      = render "singing/rankings/season_banner"

    .singing-ranking__cta
      %p.singing-ranking__cta-eyebrow NEXT STAGE
      %h2.singing-ranking__cta-title 次はあなたの番です
      %p.singing-ranking__cta-message
        歌唱・演奏診断を受けて、あなたのスコアをランキングに刻みましょう。
        %br
        成長の記録が、あなただけの物語になります。
      = link_to "歌唱・演奏診断を始める", new_singing_diagnosis_path, class: "btn btn-primary singing-ranking__cta-btn"
