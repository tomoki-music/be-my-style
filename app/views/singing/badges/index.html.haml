- content_for :title, "バッジ一覧 | BeMyStyle"

.singing-badges
  .singing-badges__inner
    .singing-badges__header
      %p.singing-badges__eyebrow Badges
      %h1 あなたのバッジ
      %p.singing-badges__lead 診断への取り組みで獲得した称号と、シーズンの実績バッジを確認できます。

    -# ── NextBadgeHint バナー ──────────────────────────────────────
    - if @next_badge_hint
      = render "singing/badges/next_badge_hint_banner", next_badge_hint: @next_badge_hint

    -# ── Near Completion セクション ──────────────────────────
    - if @near_completion_hints.any?
      = render "singing/badges/near_completion_section",
               near_completion_hints:      @near_completion_hints,
               near_completion_more_count: @near_completion_more_count

    -# ── Achievement Badge ギャラリー ────────────────────────────
    %section.singing-badges__section{ class: "achievement-gallery #{achievement_seasonal_class}" }
      = render "singing/badges/achievement_collection_header",
               earned_count:            @achievement_earned_count,
               total_count:             @achievement_total_count,
               completion_rate:         @achievement_completion_rate,
               rarity_counts:           @achievement_rarity_counts,
               recent_earned:           @recent_earned_badges,
               earned_achievement_keys: @earned_achievement_keys

      = render "singing/badges/achievement_category_filter",
               available_categories: @available_categories,
               active_category: @active_category,
               active_rarity: @active_rarity

      - if @grouped_achievement_badges.empty?
        .achievement-gallery__empty
          %p フィルター条件に該当するバッジがありません。
          = link_to "すべて表示", singing_badges_path, class: "achievement-gallery__empty-link"
      - else
        - @grouped_achievement_badges.each do |rarity, entries|
          .achievement-gallery__rarity-section
            .achievement-gallery__rarity-header
              %span.achievement-gallery__rarity-label{ class: "achievement-gallery__rarity-label--#{rarity}" }= rarity.to_s.upcase
              - earned_in_group = entries.count { |e| e[:earned].present? }
              %span.achievement-gallery__rarity-count= "#{earned_in_group} / #{entries.size}"
            .achievement-badge-grid
              - entries.each do |entry|
                = render "singing/badges/achievement_badge_card",
                         key:           entry[:key],
                         definition:    entry[:definition],
                         earned:        entry[:earned],
                         can_share:     @can_share_achievement,
                         progress_hint: entry[:progress_hint],
                         show_pin:      true

      -# Free / Light 向け課金導線（獲得済みバッジがある場合のみ）
      - unless @can_share_achievement
        - if @achievement_earned_count > 0
          .achievement-gallery__upgrade-cta
            .achievement-gallery__upgrade-cta-icon 🏅
            .achievement-gallery__upgrade-cta-text
              %p.achievement-gallery__upgrade-cta-title= "#{@achievement_earned_count}個の達成を、記録に残せます"
              %p.achievement-gallery__upgrade-cta-desc これまで獲得したバッジを、SNS用のシェアカードとして残せます。せっかく積み重ねた努力だから、きれいな1枚にしてみませんか？
            = link_to public_singing_lp_path(anchor: "lp-section"),
                      class: "achievement-gallery__upgrade-cta-btn" do
              シェアカードを作る

    - if @next_badges.present?
      .singing-badges__section.singing-badges__section--next-target
        .singing-badges__section-head
          %p.singing-badges__section-kicker Next Target
          %h2 次に狙えるバッジ
          %p.singing-badges__section-desc あと少しで手が届くバッジです。目標にして、もう一度診断に挑戦してみましょう。
        .singing-badges__next-list
          - @next_badges.each do |hint|
            - emoji = hint.respond_to?(:icon) && hint.icon.present? ? hint.icon : (Singing::NextBadgeService::BADGE_EMOJI[hint.key] || "🎯")
            .singing-badges__next-item
              %span.singing-badges__next-item-emoji= emoji
              .singing-badges__next-item-body
                %strong.singing-badges__next-item-label= hint.label
                %p.singing-badges__next-item-description= hint.description
                - if hint.respond_to?(:progress_label) && hint.progress_label.present?
                  .singing-badges__next-item-progress
                    .singing-badges__next-item-progress-track
                      .singing-badges__next-item-progress-fill{ style: "width: #{hint.progress_percent.to_i.clamp(0, 100)}%" }
                    %span.singing-badges__next-item-progress-label= hint.progress_label
        .singing-badges__next-actions
          = link_to new_singing_diagnosis_path, class: "btn btn-primary singing-badges__next-cta" do
            もう一度診断する →
          = link_to singing_rankings_path, class: "singing-badges__next-ranking-link" do
            ランキングを見る →

    %section.singing-badges__section
      .singing-badges__section-head
        %p.singing-badges__section-kicker Achievement
        %h2 実績バッジ
        %p.singing-badges__section-desc 診断回数やランキング成績で獲得できるバッジです。未獲得のバッジを目標にしてみましょう。
      .singing-badges__ranking-grid
        - @all_ranking_definitions.each do |definition|
          - earned = @earned_badge_keys.include?(definition[:key])
          - rarity = definition[:rarity].to_s
          .singing-badges__ranking-badge{ class: [
              "singing-badges__ranking-badge--#{rarity}",
              ("singing-badges__ranking-badge--unearned" unless earned)
            ].compact.join(" ") }
            .singing-badges__ranking-badge-icon= definition[:icon]
            .singing-badges__ranking-badge-label= definition[:label]
            - unless earned
              %span.singing-badges__ranking-badge-lock 未獲得

    %section.singing-badges__section
      .singing-badges__section-head
        %p.singing-badges__section-kicker Season
        %h2 シーズンバッジ
        %p.singing-badges__section-desc シーズン終了時の実績に応じて付与されるバッジです。
      - if @season_badges.any?
        .singing-badges__season-list
          - @season_badges.each do |badge|
            .singing-badges__season-badge{ class: (singing_badge_new?(badge) ? "singing-badges__season-badge--new" : "") }
              %span.singing-badges__season-badge-emoji= singing_badge_emoji(badge)
              .singing-badges__season-badge-body
                %strong.singing-badges__season-badge-label= singing_badge_label(badge)
                %small.singing-badges__season-badge-season= singing_badge_season_name(badge)
                %small.singing-badges__season-badge-date= badge.awarded_at.strftime("%-m月%-d日 獲得")
              - if singing_badge_new?(badge)
                %span.singing-badges__season-badge-new NEW
      - else
        .singing-badges__empty
          %p シーズンバッジはまだありません。
          %p.singing-badges__empty-note シーズンが終了すると、ランキング上位者や継続参加者にバッジが付与されます。
          = link_to "ランキングに参加する", singing_rankings_path, class: "btn btn-primary singing-badges__cta"

    .singing-badges__cta-section
      %p.singing-badges__cta-message 診断を重ねて、実績とコレクションを育てましょう。
      .singing-badges__cta-buttons
        = link_to "診断に挑戦する", new_singing_diagnosis_path, class: "btn btn-primary"
        = link_to "ランキングに参加する", singing_rankings_path, class: "btn btn-secondary"

    .singing-badges__nav
      = link_to singing_season_histories_path, class: "singing-badges__nav-link" do
        過去のシーズン成績を見る →

:javascript
  (function() {
    var csrfToken = document.querySelector('meta[name="csrf-token"]')
                    && document.querySelector('meta[name="csrf-token"]').getAttribute('content');

    function showToast(message, isError) {
      var existing = document.querySelector('.achievement-pin-toast');
      if (existing) existing.remove();

      var toast = document.createElement('div');
      toast.className = 'achievement-pin-toast' + (isError ? ' achievement-pin-toast--error' : '');
      toast.textContent = message;
      document.body.appendChild(toast);

      requestAnimationFrame(function() {
        toast.classList.add('achievement-pin-toast--visible');
      });

      setTimeout(function() {
        toast.remove();
      }, 2800);
    }

    document.addEventListener('click', function(e) {
      var btn = e.target.closest('.achievement-badge-card__pin-btn');
      if (!btn) return;

      var isPinned = btn.dataset.pinned === 'true';
      var url = isPinned ? btn.dataset.unpinUrl : btn.dataset.pinUrl;

      btn.disabled = true;

      fetch(url, {
        method: 'PATCH',
        headers: {
          'X-CSRF-Token': csrfToken,
          'Accept': 'application/json'
        }
      })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        if (data.ok) {
          var nowPinned = data.pinned;
          btn.dataset.pinned = nowPinned ? 'true' : 'false';
          btn.textContent = nowPinned ? '★' : '☆';
          btn.title = nowPinned ? '固定を解除する' : 'プロフィールに固定する';
          btn.setAttribute('aria-label', btn.title);
          btn.classList.toggle('achievement-badge-card__pin-btn--active', nowPinned);
          showToast(data.message, false);
        } else {
          showToast(data.message, true);
        }
      })
      .catch(function() {
        showToast('通信エラーが発生しました', true);
      })
      .finally(function() {
        btn.disabled = false;
      });
    });
  })();
