-# locals: key (String), definition (Hash), earned (SingingAchievementBadge | nil),
-#          can_share (Boolean), progress_hint (ProgressHintBuilder::ProgressHint | nil),
-#          show_pin (Boolean) — true のとき pin ボタンを表示（自分のギャラリーのみ）
- rarity      = definition[:rarity]
- is_earned   = earned.present?
- card_classes = ["achievement-badge-card", "achievement-badge-card--#{rarity}", ("achievement-badge-card--locked" unless is_earned)].compact.join(" ")
- rarity_label_text = { common: "NORMAL", rare: "RARE", epic: "EPIC", legendary: "LEGENDARY" }[rarity] || rarity.to_s.upcase
- show_progress = !is_earned && progress_hint && progress_hint.progress_ratio >= 0.5
- show_pin      = local_assigns.fetch(:show_pin, false)
- is_pinned     = is_earned && earned.pinned?

-# ── Badge Detail Modal 用データ ─────────────────────────────────────────────
- modal_data = achievement_badge_modal_data(key: key, definition: definition, earned: earned, progress_hint: progress_hint, can_share: can_share, show_pin: show_pin, earned_achievement_keys: @earned_achievement_keys)

%div{ class: card_classes,
      tabindex: "0",
      data: { badge_key: key, badge_modal: modal_data.to_json } }
  .achievement-badge-card__rarity-bar
  - if show_pin && is_earned
    %button.achievement-badge-card__pin-btn{ type: "button",
                                             class: ("achievement-badge-card__pin-btn--active" if is_pinned),
                                             title: (is_pinned ? "固定を解除する" : "プロフィールに固定する"),
                                             "aria-label": (is_pinned ? "固定を解除する" : "プロフィールに固定する"),
                                             "data-badge-id": earned.id,
                                             "data-pin-url": pin_singing_badge_path(earned),
                                             "data-unpin-url": unpin_singing_badge_path(earned),
                                             "data-pinned": is_pinned.to_s }
      = is_pinned ? "★" : "☆"

  %div{ class: "achievement-badge-card__emoji#{is_earned ? '' : ' achievement-badge-card__emoji--locked'}" }
    = definition[:emoji]

  .achievement-badge-card__body
    %p.achievement-badge-card__label= definition[:label]

    - if is_earned
      .achievement-badge-card__earned-info
        %span.achievement-badge-card__earned-check ✅
        %span.achievement-badge-card__earned-label 獲得済み
        %span.achievement-badge-card__earned-date= earned.earned_at.strftime("%-m月%-d日 達成")
      %p.achievement-badge-card__description= definition[:description]

      -# ShareImage 導線
      - if can_share
        = link_to singing_share_image_path(target: "achievement-badge"),
                  class: "achievement-badge-card__share-btn",
                  title: "シェアカードを作成" do
          シェアする
      - else
        .achievement-badge-card__share-preview-wrap
          -# Share Image 風ミニカード（blur で "本物っぽさ" を演出。Selenium 不使用）
          .achievement-badge-card__share-preview{ class: "achievement-badge-card__share-preview--#{rarity}" }
            .achievement-badge-card__share-mini-brand
              BeMyStyle Singing
              %small 🎤
            .achievement-badge-card__share-mini-body
              .achievement-badge-card__share-mini-emoji= definition[:emoji]
              %p.achievement-badge-card__share-mini-rarity{ class: "achievement-badge-card__share-mini-rarity--#{rarity}" }= rarity_label_text
              %p.achievement-badge-card__share-mini-label= definition[:label]
            .achievement-badge-card__share-mini-footer
              %span= earned.earned_at.strftime("%-m月%-d日 達成")
              %span #BeMyStyle
          .achievement-badge-card__share-lock-overlay
            %p.achievement-badge-card__share-lock-main この努力を1枚に残す
            = link_to "Coreプランでシェア", public_singing_lp_path(anchor: "lp-section"),
                      class: "achievement-badge-card__share-lock-link"

    - else
      .achievement-badge-card__locked-info
        %span.achievement-badge-card__lock-icon 🔒
        %span.achievement-badge-card__lock-label 未獲得

      - if show_progress
        -# Phase 2-B: ProgressHint 表示（達成率 50% 以上）
        - percent = (progress_hint.progress_ratio * 100).to_i
        .achievement-badge-card__progress-hint
          %p.achievement-badge-card__hint-text= progress_hint.hint_text
          .achievement-badge-card__progress-bar-wrap
            .achievement-badge-card__progress-bar-track
              %div{ class: "achievement-badge-card__progress-bar-fill achievement-badge-card__progress-bar-fill--#{rarity}", style: "width: #{percent}%" }
            %span.achievement-badge-card__progress-rate= "#{percent}%"
          %p.achievement-badge-card__detail-text= progress_hint.detail_text
      - else
        %p.achievement-badge-card__locked-description= definition[:locked_description]
