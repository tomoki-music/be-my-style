-# locals: key (String), definition (Hash), earned (SingingAchievementBadge | nil),
-#          can_share (Boolean), progress_hint (ProgressHintBuilder::ProgressHint | nil)
- rarity      = definition[:rarity]
- is_earned   = earned.present?
- card_classes = ["achievement-badge-card", "achievement-badge-card--#{rarity}", ("achievement-badge-card--locked" unless is_earned)].compact.join(" ")
- show_progress = !is_earned && progress_hint && progress_hint.progress_ratio >= 0.5

%div{ class: card_classes, data: { badge_key: key } }
  .achievement-badge-card__rarity-bar

  %div{ class: "achievement-badge-card__emoji#{is_earned ? '' : ' achievement-badge-card__emoji--locked'}" }
    = definition[:emoji]

  .achievement-badge-card__body
    %p.achievement-badge-card__label= definition[:label]

    - if is_earned
      .achievement-badge-card__earned-info
        %span.achievement-badge-card__earned-check ✅
        %span.achievement-badge-card__earned-label 獲得済み
        %span.achievement-badge-card__earned-date= earned.earned_at.strftime("%-m月%-d日 達成")
      %p.achievement-badge-card__description= definition[:description]

      -# ShareImage 導線
      - if can_share
        = link_to singing_share_image_path(target: "achievement-badge"),
                  class: "achievement-badge-card__share-btn",
                  title: "シェアカードを作成" do
          シェアする
      - else
        .achievement-badge-card__share-locked{ title: "Coreプランでシェア機能を解放" }
          🔒
          %span Coreプランでシェア

    - else
      .achievement-badge-card__locked-info
        %span.achievement-badge-card__lock-icon 🔒
        %span.achievement-badge-card__lock-label 未獲得

      - if show_progress
        -# Phase 2-B: ProgressHint 表示（達成率 50% 以上）
        - percent = (progress_hint.progress_ratio * 100).to_i
        .achievement-badge-card__progress-hint
          %p.achievement-badge-card__hint-text= progress_hint.hint_text
          .achievement-badge-card__progress-bar-wrap
            .achievement-badge-card__progress-bar-track
              %div{ class: "achievement-badge-card__progress-bar-fill achievement-badge-card__progress-bar-fill--#{rarity}", style: "width: #{percent}%" }
            %span.achievement-badge-card__progress-rate= "#{percent}%"
          %p.achievement-badge-card__detail-text= progress_hint.detail_text
      - else
        %p.achievement-badge-card__locked-description= definition[:locked_description]
