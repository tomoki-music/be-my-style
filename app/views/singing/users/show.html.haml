.singing-profile
  .singing-profile__hero
    .singing-profile__cover
    .singing-profile__hero-inner
      .singing-profile__avatar-wrap
        = customer_avatar_tag(@user, class_name: "singing-profile__avatar", fallback: "no_image")
      .singing-profile__identity
        .singing-profile__eyebrow Music Growth Profile
        %h1.singing-profile__name= @user.name
        - if @growth_type.present?
          .growth-type-badge
            %span.growth-type-badge__icon= @growth_type.icon
            %span.growth-type-badge__label= @growth_type.label
        - if @growth_circle_primary.present?
          .growth-circle-mini-badge{ style: "border-color: #{@growth_circle_primary.color}; color: #{@growth_circle_primary.color};" }
            %span.growth-circle-mini-badge__icon= @growth_circle_primary.icon
            %span.growth-circle-mini-badge__title= @growth_circle_primary.title
        .singing-profile__title-card
          %span.singing-profile__title-icon= @profile_title.icon
          .singing-profile__title-body
            %strong.singing-profile__title-label= @profile_title.label
            %span.singing-profile__title-desc= @profile_title.description
          = link_to "バッジ一覧 →", singing_badges_path, class: "singing-profile__title-link"

        - progress = @singer_rank_progress
        .singer-rank{ class: @singer_rank.color_class }
          .singer-rank__header
            %span.singer-rank__icon= @singer_rank.icon
            .singer-rank__info
              %strong.singer-rank__label= @singer_rank.label
              %span.singer-rank__level= "Lv.#{@singer_rank.level}"
            %span.singer-rank__xp= "#{@user.singing_xp} XP"
          - if @singer_next_rank
            .singer-rank__progress
              .singer-rank__progress-bar
                .singer-rank__progress-fill{ style: "width: #{progress[:percent]}%" }
              %span.singer-rank__progress-label= "次のランクまで #{progress[:xp_to_next]} XP"
          - else
            .singer-rank__max
              %span MAX RANK 達成！

        - if @user.singing_profile_comment.present?
          %p.singing-profile__comment= @user.singing_profile_comment
        - else
          %p.singing-profile__comment 音楽の成長を記録しています。
        .singing-profile__badges
          %span{ class: customer_plan_badge_class(@user) }= customer_plan_label(@user)
          - if @activity_count >= 10
            %span.singing-profile__badge.singing-profile__badge--hot= "🔥 #{@activity_count}投稿"
          - elsif @activity_count >= 3
            %span.singing-profile__badge= "✨ 活動中"
          - if @best_diagnosis.present?
            %span.singing-profile__badge.singing-profile__badge--rank= "Best #{@best_diagnosis.overall_score}点"
        .singing-profile__meta
          %span= @user.parts.any? ? @user.parts.map(&:name).join(" / ") : "担当パート未設定"
          %span= @user.genres.any? ? @user.genres.map(&:name).join(" / ") : "好きなジャンル未設定"
        .singing-profile__reactions
          %span.singing-profile__reactions-label 応援リアクション
          .singing-profile__reaction-buttons
            - SingingProfileReaction::REACTION_TYPES.each do |type|
              - label = SingingProfileReaction.label_for(type)
              - emoji = SingingProfileReaction.emoji_for(type)
              - reaction_count = @profile_reaction_counts[type].to_i
              - already_reacted = @current_customer_profile_reactions.include?(type)
              - reaction_url = singing_user_profile_reaction_path(@user, reaction_type: type)
              %button.activity-reaction-btn.singing-profile__reaction-btn{ type: "button", title: label, "aria-label": label, "data-reaction-url": reaction_url, disabled: (current_customer.blank? || current_customer == @user), class: (already_reacted ? "activity-reaction-btn--active" : "") }
                %span.singing-profile__reaction-emoji= emoji
                %span.singing-profile__reaction-text= label
                - if reaction_count > 0
                  %span.reaction-count= reaction_count
      .singing-profile__actions
        - if current_customer == @user
          = link_to "プロフィールを編集", edit_singing_user_path(current_customer), class: "singing-profile__edit-link"
        = link_to "ランキングへ", singing_rankings_path, class: "singing-profile__sub-link"

  .singing-profile__inner
    .singing-profile__main
      %section.singing-profile__section
        .singing-profile__section-head
          %p.singing-profile__section-kicker Story
          %h2 この人の音楽ストーリー
        - if @user.introduction.present?
          .singing-profile__story.singing-profile__markdown
            = singing_markdown(@user.introduction)
        - else
          .singing-profile__empty
            %p まだ自己紹介はありません。
            - if current_customer == @user
              = link_to "自己紹介を書く", edit_singing_user_path(@user)

      - if @pinned_achievement_badges.any?
        %section.singing-profile__section.singing-profile__section--pinned-achievements
          .singing-profile__section-head
            %p.singing-profile__section-kicker Pinned
            %h2 ピン止めバッジ
          .singing-profile__pinned-badges
            - @pinned_achievement_badges.each do |badge|
              - defn = badge.definition
              - rarity = badge.rarity
              .singing-profile__pinned-badge{ class: "singing-profile__pinned-badge--#{rarity}" }
                .singing-profile__pinned-badge-glow
                %span.singing-profile__pinned-badge-emoji= defn[:emoji]
                .singing-profile__pinned-badge-body
                  %p.singing-profile__pinned-badge-rarity= rarity.to_s.upcase
                  %strong.singing-profile__pinned-badge-label= defn[:label]
                  %p.singing-profile__pinned-badge-date= badge.earned_at.strftime("%-m月%-d日 達成")
          - if current_customer == @user
            = link_to "バッジを管理する →", singing_badges_path, class: "singing-profile__pinned-manage-link"

      - if @growth_circle_primary.present?
        %section.singing-profile__section.singing-profile__section--growth-circle
          .singing-profile__section-head
            %p.singing-profile__section-kicker Growth Circle
            %h2 あなたの称号
          .growth-circle-profile-badge{ style: "border-color: #{@growth_circle_primary.color}; box-shadow: 0 0 20px #{@growth_circle_primary.color}33;" }
            %span.growth-circle-profile-badge__icon{ style: "color: #{@growth_circle_primary.color};" }= @growth_circle_primary.icon
            .growth-circle-profile-badge__body
              %strong.growth-circle-profile-badge__title{ style: "color: #{@growth_circle_primary.color};" }= @growth_circle_primary.title
              %p.growth-circle-profile-badge__desc= @growth_circle_primary.description
          = link_to growth_circle_singing_badges_path, class: "singing-profile__sub-link" do
            すべての称号を見る →

      - if @community_identity.present?
        %section.singing-profile__section.singing-profile__section--community-identity
          .singing-profile__section-head
            %p.singing-profile__section-kicker Community
            %h2 🎵 Community Identity
          .profile-community-identity
            .profile-community-identity__reputation
              %strong.profile-community-identity__reputation-title= @community_identity.reputation_title
              %span.profile-community-identity__reputation-points= "#{@community_identity.reputation_points} pt"
            - if @community_identity.growth_circle_name.present?
              %p.profile-community-identity__circle-name= @community_identity.growth_circle_name
            - if @community_identity.mission_label.present?
              .profile-community-identity__mission
                %span.profile-community-identity__mission-label 最近のテーマ
                %span.profile-community-identity__mission-value= @community_identity.mission_label
            - if @community_identity.activity_summary.present?
              %p.profile-community-identity__summary= @community_identity.activity_summary
            %p.profile-community-identity__message= @community_identity.identity_message
            - if @profile_connection.present?
              .profile-connection-cta
                - if @profile_connection.connection_count > 0
                  .profile-connection-cta__graph
                    %span.profile-connection-cta__graph-label 音楽のつながり
                    %strong.profile-connection-cta__graph-count= "#{@profile_connection.connection_count}人"
                %p.profile-connection-cta__message= @profile_connection.cta_message
                .profile-connection-cta__buttons
                  - if @profile_connection.show_circle_cta
                    = link_to singing_users_path(circle: @profile_connection.circle_slug), class: "profile-connection-cta__btn profile-connection-cta__btn--circle" do
                      同じCircleを見る
                  - if @profile_connection.show_follow_cta && current_customer.present? && current_customer != @user
                    = link_to singing_user_profile_reaction_path(@user, reaction_type: "cheer"), method: :post, class: "profile-connection-cta__btn profile-connection-cta__btn--follow", data: { reaction_url: singing_user_profile_reaction_path(@user, reaction_type: "cheer"), turbolinks: false } do
                      🌱 一緒に成長する

      %section.singing-profile__section
        .singing-profile__section-head
          %p.singing-profile__section-kicker Achievements
          %h2 獲得した称号
        - if @ranking_badges.present?
          .singing-profile__achievement-panel
            = render "singing/rankings/badges", badges: @ranking_badges, limit: 12, class_name: "singing-profile__achievement-badges"
          %p.singing-profile__achievement-note 診断回数、成長幅、ランキング実績に応じて称号が増えていきます。
        - else
          .singing-profile__empty
            %p 最初の診断が完了すると、ここに称号が表示されます。
            - if current_customer == @user
              = link_to "診断に挑戦する", new_singing_diagnosis_path
        - if @next_badges.present? && current_customer == @user
          .singing-profile__next-badges
            %h3 次に狙える称号
            .singing-profile__next-badge-list
              - @next_badges.each do |hint|
                - emoji = hint.respond_to?(:icon) && hint.icon.present? ? hint.icon : (Singing::NextBadgeService::BADGE_EMOJI[hint.key] || "🎯")
                .singing-profile__next-badge-item
                  %span.singing-profile__next-badge-emoji= emoji
                  .singing-profile__next-badge-body
                    %strong.singing-profile__next-badge-label= hint.label
                    %p.singing-profile__next-badge-description= hint.description
                    - if hint.respond_to?(:progress_label) && hint.progress_label.present?
                      .singing-profile__next-badge-progress
                        .singing-profile__next-badge-progress-track
                          .singing-profile__next-badge-progress-fill{ style: "width: #{hint.progress_percent.to_i.clamp(0, 100)}%" }
                        %span.singing-profile__next-badge-progress-label= hint.progress_label
            .singing-profile__next-badge-cta
              %p.singing-profile__next-badge-cta-message 診断を重ねて、次の称号に近づきましょう。
              .singing-profile__next-badge-cta-buttons
                = link_to "診断に挑戦する", new_singing_diagnosis_path, class: "btn btn-primary"
                = link_to "ランキングを見る", singing_rankings_path, class: "btn btn-secondary"
                = link_to "バッジ一覧を見る", singing_badges_path, class: "btn btn-secondary"

      %section.singing-profile__section
        .singing-profile__section-head
          %p.singing-profile__section-kicker Season
          %h2 シーズン実績
        %p.singing-profile__season-lead
          今月の挑戦が、あなたの成長の証として残ります。
          %br
          順位だけではなく、挑戦したこと自体が立派な記録です。
        - if @season_achievement_entries.present?
          .singing-profile__season-achievements
            - @season_achievement_entries.each do |entry|
              .singing-profile__season-achievement
                .singing-profile__season-achievement-meta
                  %span= entry.singing_ranking_season.name
                  %strong= season_category_label(entry.category)
                  %small= "#{entry.rank}位 / #{entry.score}点"
                = render "singing/shared/season_badge", entry: entry
        - else
          .singing-profile__empty
            %p まだシーズン実績はありません。
        - unless @user.plan == "premium"
          %p.singing-profile__season-premium-note
            Premiumでは、TOMOKIコメント付きのシーズン振り返りや限定称号にも対応予定です。

      %section.singing-profile__section
        .singing-profile__section-head
          %p.singing-profile__section-kicker Badges
          %h2 シーズンバッジ
        - if @season_badges.any?
          .singing-profile__season-badge-list
            - @season_badges.first(6).each do |badge|
              .singing-profile__season-badge-item{ class: (singing_badge_new?(badge) ? "singing-profile__season-badge-item--new" : "") }
                %span.singing-profile__season-badge-emoji= singing_badge_emoji(badge)
                .singing-profile__season-badge-body
                  %strong.singing-profile__season-badge-label= singing_badge_label(badge)
                  %small.singing-profile__season-badge-season= singing_badge_season_name(badge)
                - if singing_badge_new?(badge)
                  %span.singing-profile__season-badge-new NEW
          - if @season_badges.count > 6
            %p.singing-profile__season-badge-more= "他 #{@season_badges.count - 6} 件のバッジを獲得しています。"
          - if @user == current_customer
            = link_to "バッジ一覧を見る →", singing_badges_path, class: "singing-profile__season-badge-link"
        - else
          .singing-profile__empty
            %p バッジはまだありません。シーズンが終了すると、実績に応じてバッジが付与されます。
          - if @user == current_customer
            = link_to "バッジ・実績を確認する →", singing_badges_path, class: "singing-profile__season-badge-link"

      %section.singing-profile__section
        .singing-profile__section-head
          %p.singing-profile__section-kicker Growth
          %h2 成長の記録
        - if @growth_diagnoses.present?
          - if @growth_entry.present?
            .singing-profile__growth-story
              %span.singing-profile__growth-story-label= "成長ランキング #{@growth_position}位"
              %strong= "+#{@growth_entry.growth_score}点"
              %small= "#{@growth_entry.previous_diagnosis.overall_score}点から#{@growth_entry.latest_diagnosis.overall_score}点へ更新"
          .singing-profile__growth
            - @growth_diagnoses.each do |diagnosis|
              - score_width = [[diagnosis.overall_score.to_i, 0].max, 100].min
              .singing-profile__growth-item
                .singing-profile__growth-meta
                  %span= diagnosis.diagnosed_at&.strftime("%m/%d") || diagnosis.created_at.strftime("%m/%d")
                  %strong= "#{diagnosis.overall_score}点"
                .singing-profile__growth-bar
                  .singing-profile__growth-fill{ style: "width: #{score_width}%" }
                %small= diagnosis.performance_type_label
        - else
          .singing-profile__empty
            %p 完了した診断が増えると、成長の軌跡がここに表示されます。

      %section.singing-profile__section
        - summary_title = (current_customer == @user) ? "あなたの成長記録" : "#{@user.name}さんの成長記録"
        = render "singing/shared/journey_summary_card",
                 summary: @journey_summary,
                 viewer_is_owner: (current_customer == @user),
                 title: summary_title

      %section.singing-profile__section
        .singing-profile__section-head
          %p.singing-profile__section-kicker Activity
          %h2 最近の活動報告
        - if @recent_activities.present?
          .singing-profile__activity-list
            - @recent_activities.each do |activity|
              = link_to public_activity_path(activity), class: "singing-profile__activity-card", data: { turbolinks: false } do
                .singing-profile__activity-thumb
                  - if activity.activity_image.attached?
                    = image_tag activity.activity_image
                  - else
                    %span ♪
                .singing-profile__activity-body
                  %strong= truncate(activity.title, length: 34)
                  %p= truncate(activity.introduction.presence || activity.keep, length: 70)
                  %small= "#{time_ago_in_words(activity.created_at)}前"
        - else
          .singing-profile__empty
            %p 活動報告が投稿されると、練習や挑戦の記録がここに並びます。

    .singing-profile__side
      %section.singing-profile__side-card
        %h2 プロフィール
        %dl.singing-profile__definition
          %dt 担当
          %dd= @user.parts.any? ? @user.parts.map(&:name).join(" / ") : "未設定"
          %dt 好きなジャンル
          %dd= @user.genres.any? ? @user.genres.map(&:name).join(" / ") : "未設定"
          %dt SNS / リンク
          %dd
            - if @safe_profile_url.present?
              = link_to @safe_profile_url, @safe_profile_url, target: "_blank", rel: "noopener noreferrer"
            - else
              未設定

      %section.singing-profile__side-card
        %h2 最近の診断
        - if @recent_diagnoses.present?
          .singing-profile__diagnosis-list
            - @recent_diagnoses.each do |diagnosis|
              .singing-profile__diagnosis-item
                %span= diagnosis.performance_type_label
                %strong= diagnosis.overall_score.present? ? "#{diagnosis.overall_score}点" : "-"
                %small= diagnosis.diagnosed_at&.strftime("%Y/%m/%d") || diagnosis.created_at.strftime("%Y/%m/%d")
        - else
          %p.singing-profile__side-empty まだ診断結果はありません。

      %section.singing-profile__side-card.singing-profile__side-card--rank
        %h2 ランキング実績
        .singing-profile__achievement-stats
          .singing-profile__achievement-stat
            %span 最高スコア
            %strong= @best_diagnosis.present? ? "#{@best_diagnosis.overall_score}点" : "-"
          .singing-profile__achievement-stat
            %span 診断回数
            %strong= "#{@diagnosis_count}回"
          .singing-profile__achievement-stat
            %span 総合ランキング
            %strong= @ranking_position.present? ? "#{@ranking_position}位" : "-"
          .singing-profile__achievement-stat
            %span 今月のシーズン
            %strong= @season_position.present? ? "#{@season_position}位" : "-"
          .singing-profile__achievement-stat
            %span 成長ランキング
            %strong= @growth_entry.present? ? "#{@growth_position}位 / +#{@growth_entry.growth_score}点" : "-"
        - if @best_diagnosis.present?
          %p.singing-profile__rank-title= "#{@best_diagnosis.performance_type_label} / #{singing_ranking_title(@best_diagnosis.overall_score)}"
        - else
          %p.singing-profile__side-empty ランキング参加中の診断はまだありません。
