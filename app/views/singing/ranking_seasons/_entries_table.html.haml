-# entries: Array<SingingSeasonRankingEntry>
- if entries.empty?
  %p.singing-season__no-entries エントリーなし

- else
  - top3 = entries.first(3)
  - rest  = entries.drop(3)

  - if top3.present?
    .singing-season__podium
      - [[top3[1], 2], [top3[0], 1], [top3[2], 3]].each do |entry, rank|
        - next unless entry
        - rank_label = { 1 => "1st", 2 => "2nd", 3 => "3rd" }[rank]
        .singing-season__podium-card{ class: "singing-season__podium-card--rank-#{rank}" }
          .singing-season__podium-rank-badge= rank_label
          .singing-season__podium-score
            %span.singing-season__podium-score-num= entry.score
            %span.singing-season__podium-score-unit 点
          = link_to singing_user_path(entry.customer), class: "singing-season__podium-user" do
            = customer_avatar_tag(entry.customer, class_name: "singing-season__podium-avatar", fallback: "no_image")
            %span.singing-season__podium-name= entry.customer.name
          - if entry.title.present?
            %span.singing-season__podium-title-badge= entry.title
          - if entry.badge_key.present?
            %span.singing-season__podium-badge-key{ data: { badge: entry.badge_key } }
          .singing-season__podium-step{ class: "singing-season__podium-step--rank-#{rank}" }
            = rank_label

  - if rest.present?
    .singing-season__list
      %table.singing-season__table
        %thead
          %tr
            %th.singing-season__th 順位
            %th.singing-season__th ユーザー
            %th.singing-season__th スコア
            %th.singing-season__th 称号
        %tbody
          - rest.each do |entry|
            %tr.singing-season__tr
              %td.singing-season__td.singing-season__td--rank #{entry.rank}位
              %td.singing-season__td
                = link_to singing_user_path(entry.customer), class: "singing-season__user-link" do
                  = customer_avatar_tag(entry.customer, class_name: "singing-season__user-avatar", fallback: "no_image")
                  %span.singing-season__user-name= entry.customer.name
              %td.singing-season__td.singing-season__td--score= "#{entry.score}点"
              %td.singing-season__td= entry.title
