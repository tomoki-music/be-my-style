.singing-share-image__card{ role: "img", "aria-label": "#{share_image.report.year}年の歌声成長レポート", data: { share_capture_target: "yearly-growth" } }
  .singing-share-image__topline
    %span= "#{share_image.report.year} YEAR IN VOICE"
    %strong BeMyStyle Singing

  .singing-share-image__hero
    %p.singing-share-image__kicker ANNUAL GROWTH REPORT
    %h1= share_image.headline
    %p= share_image.annual_copy

  .singing-share-image__metric.singing-share-image__metric--primary
    %span 今年の診断回数
    %strong= share_image.report.diagnosis_count
    %small times

  .singing-share-image__metric-grid
    .singing-share-image__metric
      %span 最大成長した能力
      %strong= share_image.report.top_growth&.label || "これから"
      %small growth area
    .singing-share-image__metric
      %span 最大成長量
      %strong= share_image.growth_delta_label
      %small= share_image.growth_range_label
    .singing-share-image__metric
      %span 自己ベスト更新
      %strong= share_image.best_updates_label
      %small personal best
    .singing-share-image__metric
      %span 最も挑戦したAIチャレンジ
      %strong= share_image.challenge_label
      %small challenge
    .singing-share-image__metric
      %span 最も歌った曲
      %strong= share_image.song_label
      %small most sung

  .singing-share-image__singer-rank
    %span.singing-share-image__singer-rank-icon= singer_rank.icon
    %span.singing-share-image__singer-rank-label= singer_rank.label
    %span.singing-share-image__singer-rank-level= "Lv.#{singer_rank.level}"

  .singing-share-image__footer
    %span= share_image.hashtag
    %small Screenshot ready
