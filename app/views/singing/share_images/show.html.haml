- content_for :title, "#{@share_image.report.year}年 歌声成長シェアカード | BeMyStyle"
- content_for :og_title, "#{@share_image.report.year}年 歌声成長レポート | BeMyStyle Singing"
- content_for :og_description, @share_text
- content_for :twitter_card, "summary_large_image"

.singing-share-image
  .singing-share-image__inner
    = render "share_actions", variant: :toolbar, share_text: @share_text, share_url: request.original_url

    .singing-share-image__capture-guide
      %span Screenshot guide
      %strong カード全体が入るようにスクショして、Instagramの投稿やストーリーズへ。

    .singing-share-image__stage
      = render "share_card", share_image: @share_image, singer_rank: @singer_rank

    .singing-share-image__invite-cta
      %strong あなたは何タイプ？
      %p 歌声・演奏診断で、あなたの声の個性を無料で確認してみよう。
      = link_to "無料で診断してみる →", new_singing_diagnosis_path, class: "singing-share-image__invite-cta-btn"

    .singing-share-image__share-note
      %h2 SNSで共有
      %p Xはボタンから投稿できます。Instagramでは上のカードだけが入るようにスクショして、投稿やストーリーズでシェアしてください。

    = render "share_actions", variant: :footer, share_text: @share_text, share_url: request.original_url
