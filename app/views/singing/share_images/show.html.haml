- if @capture_target == "yearly-growth"
  - page_title = "#{@share_image.report.year}年 歌声成長シェアカード"
  - og_title = "#{@share_image.report.year}年 歌声成長レポート"
- elsif @capture_target == "daily-challenge"
  - page_title = "Daily Challenge シェアカード"
  - og_title = "Daily Challenge を完了しました"
- elsif @capture_target == "monthly-wrapped"
  - page_title = "#{@share_image.month_label} Monthly Wrapped"
  - og_title = "#{@share_image.month_label} Singing Wrapped"
- else
  - page_title = "Singing Ranking シェアカード"
  - og_title = "Singing Rankingに挑戦しました"
- content_for :title, "#{page_title} | BeMyStyle"
- content_for :og_title, "#{og_title} | BeMyStyle Singing"
- content_for :og_description, @share_text
- content_for :twitter_card, "summary_large_image"
- content_for :og_image, @generated_image_url if @generated_image_url.present?

.singing-share-image
  .singing-share-image__inner
    .singing-share-image__hub
      %span.singing-share-image__hub-label ShareImage Hub
      %h1 成果共有ハブ
      %p 年間の成長も、今日の一歩も、SNSで共有しやすい画像にできます。

    - yearly_active   = @capture_target == "yearly-growth"
    - daily_active    = @capture_target == "daily-challenge"
    - ranking_active  = @capture_target == "ranking"
    - wrapped_active  = @capture_target == "monthly-wrapped"
    .singing-share-image__tabs{ role: "tablist", "aria-label": "シェア画像の種類" }
      = link_to singing_share_image_path, class: "singing-share-image__tab #{'singing-share-image__tab--active' if yearly_active}", role: "tab", "aria-selected": yearly_active do
        %span 年間レポート
        %small 今年の成長を1枚に
      = link_to singing_share_image_path(target: "daily-challenge"), class: "singing-share-image__tab #{'singing-share-image__tab--active' if daily_active}", role: "tab", "aria-selected": daily_active do
        %span Daily Challenge
        %small 今日の頑張りを1枚に
      = link_to singing_share_image_path(target: "ranking"), class: "singing-share-image__tab #{'singing-share-image__tab--active' if ranking_active}", role: "tab", "aria-selected": ranking_active do
        %span ランキング
        %small 挑戦の記録を1枚に
      = link_to singing_share_image_path(target: "monthly-wrapped"), class: "singing-share-image__tab #{'singing-share-image__tab--active' if wrapped_active}", role: "tab", "aria-selected": wrapped_active do
        %span Monthly Wrapped
        %small 今月の成果を1枚に

    = render "share_actions", variant: :toolbar, share_text: @share_text, share_url: request.original_url

    .singing-share-image__capture-guide
      %span Screenshot guide
      %strong カード全体が入るようにスクショして、Instagramの投稿やストーリーズへ。

    .singing-share-image__stage
      - if @capture_target == "daily-challenge"
        = render "daily_challenge_card", share_image: @share_image
      - elsif @capture_target == "ranking"
        = render "ranking_card", share_image: @share_image
      - elsif @capture_target == "monthly-wrapped"
        = render "monthly_wrapped_card", share_image: @share_image
      - else
        = render "share_card", share_image: @share_image, singer_rank: @singer_rank

    .singing-share-image__invite-cta
      %strong あなたは何タイプ？
      %p 歌声・演奏診断で、あなたの声の個性を無料で確認してみよう。
      = link_to "無料で診断してみる →", new_singing_diagnosis_path, class: "singing-share-image__invite-cta-btn"

    .singing-share-image__share-note
      %h2 SNSで共有
      %p Xはボタンから投稿できます。Instagramでは上のカードだけが入るようにスクショして、投稿やストーリーズでシェアしてください。

    .singing-share-image__instagram-guide
      %span 📱
      .singing-share-image__instagram-guide-body
        %strong Instagramで共有する場合
        %p スマホでは画像を長押し保存、またはスクリーンショット保存して、ストーリーズや投稿に貼り付けてください。

    = render "share_actions", variant: :footer, share_text: @share_text, share_url: request.original_url
