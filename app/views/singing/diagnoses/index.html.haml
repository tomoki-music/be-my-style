.singing-diagnosis{ data: (@polling_required ? { singing_diagnosis_polling: true, singing_diagnosis_polling_interval: 5000 } : {}) }
  .singing-diagnosis__inner
    %p.singing-diagnosis__eyebrow Singing / Performance Diagnosis
    %h1 成長記録
    %p.singing-diagnosis__lead 診断を重ねるほど、あなたの歌声の変化と成長が見えてきます。

    - completed_count = @diagnoses.select(&:completed?).count
    - if completed_count > 0
      .singing-diagnosis__growth-dashboard
        .singing-diagnosis__growth-stat
          %span.singing-diagnosis__growth-stat-number= completed_count
          %span.singing-diagnosis__growth-stat-label 回の診断完了
        .singing-diagnosis__growth-stat
          - best_score = @diagnoses.select(&:completed?).filter_map(&:overall_score).max
          %span.singing-diagnosis__growth-stat-number= best_score || "-"
          %span.singing-diagnosis__growth-stat-label 最高スコア
        .singing-diagnosis__growth-stat
          - activity_level = case completed_count
            - when 1..2 then { label: "Lv.1", name: "スタート", icon: "🌱" }
            - when 3..5 then { label: "Lv.2", name: "継続中", icon: "🌿" }
            - when 6..9 then { label: "Lv.3", name: "成長中", icon: "🌳" }
            - when 10..19 then { label: "Lv.4", name: "熟練", icon: "⭐" }
            - else { label: "Lv.5", name: "エキスパート", icon: "🌟" }
          %span.singing-diagnosis__growth-stat-icon= activity_level[:icon]
          %span.singing-diagnosis__growth-stat-number= activity_level[:label]
          %span.singing-diagnosis__growth-stat-label= activity_level[:name]
        - if completed_count >= 3
          .singing-diagnosis__growth-badge
            🏆 継続バッジ獲得中
      - latest_completed = @diagnoses.select(&:completed?).first
      - if latest_completed&.overall_score
        .singing-diagnosis__motivation-banner
          %p.singing-diagnosis__motivation-text
            - score = latest_completed.overall_score
            - if score >= 80
              直近スコア #{score}点。高水準を維持できています。この調子で続けましょう！
            - elsif score >= 60
              直近スコア #{score}点。着実に伸びています。次回も続けると変化が見えてきます。
            - else
              直近スコア #{score}点。スコアは伸びしろ。振り返りを続けることが上達への近道です。

    .singing-diagnosis__actions
      = link_to "新しい診断を作成", new_singing_diagnosis_path, class: "btn btn-primary"
      = link_to "歌唱・演奏診断トップへ", singing_root_path, class: "btn btn-secondary"
      - if current_customer.has_feature?(:singing_yearly_growth_report)
        = link_to "年間成長シェアカードを見る", singing_share_image_path, class: "btn btn-secondary"

    - weekly_theme = singing_weekly_challenge_theme
    - weekly_done = singing_weekly_diagnosed?(@diagnoses)
    .singing-diagnosis__weekly-challenge{ class: (weekly_done ? "singing-diagnosis__weekly-challenge--done" : "") }
      .singing-diagnosis__weekly-challenge-header
        %span.singing-diagnosis__weekly-challenge-week= "Week #{Date.today.cweek} チャレンジ"
        - if weekly_done
          %span.singing-diagnosis__weekly-challenge-status 今週診断済み ✓
        - else
          %span.singing-diagnosis__weekly-challenge-status--pending 今週未診断
      .singing-diagnosis__weekly-challenge-body
        %span.singing-diagnosis__weekly-challenge-icon= weekly_theme[:icon]
        .singing-diagnosis__weekly-challenge-content
          %strong.singing-diagnosis__weekly-challenge-title= weekly_theme[:title]
          %p.singing-diagnosis__weekly-challenge-desc= weekly_theme[:body]
      .singing-diagnosis__weekly-challenge-footer
        - if weekly_done
          %p.singing-diagnosis__weekly-challenge-done-msg 今週のチャレンジに取り組みました！次の診断で変化を確認しよう。
          = link_to "新しい診断を作成", new_singing_diagnosis_path, class: "singing-diagnosis__weekly-challenge-btn"
        - else
          = link_to "今週診断してみる", new_singing_diagnosis_path, class: "singing-diagnosis__weekly-challenge-btn singing-diagnosis__weekly-challenge-btn--cta"

    = link_to singing_rankings_path, class: "singing-diagnosis__ranking-banner" do
      .singing-diagnosis__ranking-banner-left
        %span.singing-diagnosis__ranking-banner-badge RANKING
        %strong.singing-diagnosis__ranking-banner-title ランキングに参加して成長を楽しもう
        %span.singing-diagnosis__ranking-banner-sub 診断時に参加を選ぶと、スコアがランキングに掲載されます
      .singing-diagnosis__ranking-banner-right
        %span ランキングを見る &rarr;

    - if @polling_required
      %p.singing-diagnosis__polling-note 解析中の診断があるため、自動更新しています。すべて完了または失敗になると更新は止まります。

    - if current_customer.has_feature?(:singing_yearly_growth_report)
      = render "yearly_growth_report", report: @yearly_growth_report

    = render "growth_timeline", events: @growth_timeline_events, customer: current_customer

    - if @diagnoses.any?
      .singing-diagnosis__history
        .singing-diagnosis__history-row.singing-diagnosis__history-row--head
          %div 状態
          %div 診断対象
          %div 曲名
          %div 作成日時
          %div 総合スコア
          %div 詳細

        - @diagnoses.each_with_index do |diagnosis, idx|
          .singing-diagnosis__history-row
            .singing-diagnosis__history-status
              %span.singing-diagnosis__history-badge{ class: "singing-diagnosis__history-badge--#{diagnosis.status}" }
                = diagnosis.respond_to?(:status_i18n) ? diagnosis.status_i18n : diagnosis.status

            .singing-diagnosis__history-type
              %span.singing-diagnosis__type-badge= diagnosis.performance_type_label

            .singing-diagnosis__history-title
              = diagnosis.song_title.presence || "未入力"
              - if diagnosis.completed? && idx == 0
                %span.singing-diagnosis__latest-badge 最新
              - if diagnosis.completed?
                %p.singing-diagnosis__history-growth
                  %span.singing-diagnosis__history-growth-label= singing_history_growth_label(diagnosis)
                  %span.singing-diagnosis__history-growth-text= singing_history_growth_hint(diagnosis, current_customer)

            .singing-diagnosis__history-date
              = diagnosis.created_at.strftime("%Y/%m/%d %H:%M")

            .singing-diagnosis__history-score
              - if diagnosis.completed?
                %strong= diagnosis.overall_score || "-"
                %span / 100
              - elsif diagnosis.processing?
                %span 解析中
              - elsif diagnosis.failed?
                %span 失敗
              - else
                %span 解析待ち

            .singing-diagnosis__history-link
              = link_to "詳細", singing_diagnosis_path(diagnosis), class: "btn btn-sm btn-outline-primary"
    - else
      .singing-diagnosis__empty
        %h2 まだ診断履歴はありません
        %p 音声ファイルを添付して、最初の歌唱・演奏診断を依頼できます。
        %p.singing-diagnosis__empty-note 診断を重ねると、スコア推移・成長グラフ・称号が見えてきます。
        = link_to "診断を始める", new_singing_diagnosis_path, class: "btn btn-primary"
