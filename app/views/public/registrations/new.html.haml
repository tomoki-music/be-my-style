.devise-container
  .signup-card

    %h2.signup-title 新規登録

    = form_with model: resource, url: customer_registration_path, local: true do |f|

      .domain-cards
        - ["music","business"].each do |type|
          - label = type == "music" ? "音楽" : "ビジネス"
          - desc  = type == "music" ? "仲間とセッション" : "スキルで繋がる"
          - icon  = type == "music" ? "🎸" : "💼"

          %label.domain-card{ class: type }
            = f.radio_button :domain_name, type,
              class:"domain-radio",
              checked: (f.object.domain_name.presence || "music") == type

            .card-inner
              .icon= icon
              .text
                %h4= label
                %p= desc

      .form-group
        %label メールアドレス
        = f.email_field :email, class:"form-control"

      .form-group
        %label パスワード
        = f.password_field :password, class:"form-control"

      .form-group
        %label ニックネーム
        = f.text_field :name, class:"form-control"

      / =========================
      / プロフィール画像
      / =========================
      .form-group

        %label プロフィール画像

        .image-upload-area

          .image-preview
            %img#preview-image{ src: asset_path("no_image"), class: "preview-avatar" }
            %span.camera-icon 📷

          = f.file_field :profile_image,
            accept: "image/*",
            class: "image-input",
            id: "image-input"

        %small.text-muted アイコンを設定すると見つけてもらいやすくなります

        

      / =========================
      / 🎸 MUSIC専用
      / =========================
      .music-fields

        .form-card
          %h4 🎸 パート

          .checkbox-grid
            = f.collection_check_boxes(:part_ids, Part.all, :id, :name) do |tag|
              = tag.label(class:"check-item") do
                = tag.check_box
                %span= tag.text

        .form-card
          %h4 🎵 ジャンル

          .checkbox-grid
            = f.collection_check_boxes(:genre_ids, Genre.all, :id, :name) do |genre|
              = genre.label(class:"check-item") do
                = genre.check_box
                %span= genre.text

        .form-card
          %h4 🎤 好きなアーティスト

          .artist-inputs
            = f.text_field :favorite_artist1, placeholder:"例：ONE OK ROCK", class:"form-control"
            = f.text_field :favorite_artist2, class:"form-control"
            = f.text_field :favorite_artist3, class:"form-control"
            = f.text_field :favorite_artist4, class:"form-control"
            = f.text_field :favorite_artist5, class:"form-control"

      / =========================
      / 💼 BUSINESS専用
      / =========================
      .business-fields
        %h4.section-title 💼 ビジネスプロフィール

        .form-group
          %label 職種
          = f.text_field :job, class:"form-control", placeholder:"例：エンジニア / マーケター"

        .form-group
          %label スキル
          = f.text_area :skills, class:"form-control", placeholder:"Ruby / AWS / 営業 など"

        .form-group
          %label 実績・サービス
          = f.text_area :achievements, class:"form-control"

        .form-group
          %label HP / SNS
          = f.text_field :url, class:"form-control"

      .form-group
        %label 自己紹介
        = f.text_area :introduction, class:"form-control"

      = f.submit "登録する", class:"btn btn-primary signup-btn"