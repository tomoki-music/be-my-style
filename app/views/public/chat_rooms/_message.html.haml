- display_context = local_assigns[:display_context] || :normal
- in_thread = display_context == :thread
- community = local_assigns[:community]
- if chat_message.customer.id != current_customer.id
  .partner-message{ id: "chat-message-#{chat_message.id}", data: { "chat-message-id" => chat_message.id } }
    %ul
      %li
      = link_to public_customer_path(chat_message.customer), class: "chat-room-customer-link" do
        .img-element
          = customer_avatar_tag(chat_message.customer)
        .name-element
          = chat_message.customer.name + 'さんのメッセージ'
      %li
      - unless in_thread
        = render "public/chat_rooms/reply_source_card", chat_message: chat_message
      = render "public/chat_rooms/quote_card", chat_message: chat_message
      .partner-content
        - if chat_message.stamped?
          %span.stamp-badge= chat_message.stamp_label
        - elsif chat_message.content.present?
          - if chat_message.markdown?
            - markdown_class = in_thread ? 'markdown-body markdown-body--thread' : 'markdown-body'
            %div{ class: markdown_class }= chat_markdown(chat_message)
          - else
            = simple_format(chat_message.content)
        = render "public/chat_rooms/link_preview_cards", chat_message: chat_message
      - if chat_message.attachments.attached?
        - attachments_class = in_thread ? 'message-attachments message-attachments--thread' : 'message-attachments'
        %li
          %div{ class: attachments_class }
            - chat_message.attachments.each do |file|
              .partner-chat-image
                - if file.image?
                  - image_class = in_thread ? 'message-image message-image--thread' : 'message-image'
                  - link_class = in_thread ? 'chat-image-link chat-image-link--thread' : 'chat-image-link'
                  = link_to url_for(file), target: '_blank', rel: 'noopener', aria: { label: '画像を拡大表示' }, class: link_class do
                    = image_tag file.variant(resize: '300x300'), class: image_class
                - elsif file.content_type == "application/pdf"
                  %div.pdf-preview
                    %p PDFファイル:
                    = link_to "🧾 PDFを見る", url_for(file), target: "_blank", rel: "noopener", class: "btn-view"
                    = link_to "⬇️ ダウンロード", url_for(file), download: file.filename.to_s, class: "btn-download"
                    %iframe{ src: url_for(file), width: "100%", height: "400px", class: "pdf-frame" }
                - elsif file.content_type.start_with?("audio/")
                  %p 音声ファイル:
                  %audio{ controls: true }
                    %source{ src: url_for(file), type: file.content_type }
                - elsif file.content_type.start_with?("video/")
                  %p 動画ファイル:
                  %video{ controls: true, width: "100%", height: "auto", style: "max-width: 500px;" }
                    %source{ src: url_for(file), type: file.content_type }
      %li
      .message-meta
        %span.message-timestamp
          = l chat_message.created_at, format: :short
          に送信済み
        - if chat_message.edited_at.present?
          %span.edited-label 編集済み
        - if chat_message.pinned?
          %span.pinned-label 📌 ピン留め済み
          - if can_unpin_chat_message?(chat_message.chat_message_pin, community)
            %button.pin-button.pin-button--unpin{ type: "button",
                "aria-label" => "ピン留めを解除",
                data: { "pin-message-id" => chat_message.id, "pin-action" => "unpin" } }
              %span.pin-button-icon 📌
              %span.pin-button-label ピン留めを解除
        - else
          %button.pin-button.pin-button--pin{ type: "button",
              "aria-label" => "ピン留めする",
              data: { "pin-message-id" => chat_message.id, "pin-action" => "pin" } }
            %span.pin-button-icon 📌
            %span.pin-button-label ピン留めする
        - unless in_thread
          %button.reply-button{ type: "button",
              "aria-label" => "このメッセージに返信",
              data: { "reply-message-id" => chat_message.id,
                      "reply-author" => chat_message.customer.name,
                      "reply-preview" => chat_reply_excerpt(chat_message) } }
            %span.reply-button-icon ↩
            %span.reply-button-label 返信
        %button.quote-button{ type: "button",
            "aria-label" => "このメッセージを引用返信",
            data: { "quote-message-id" => chat_message.id,
                    "quote-author" => chat_message.customer.name,
                    "quote-label" => chat_quote_label(chat_message),
                    "quote-excerpt" => chat_reply_excerpt(chat_message),
                    "quote-has-image" => chat_quote_has_image?(chat_message) } }
          %span.quote-button-icon "
          %span.quote-button-label 引用返信
      - if !in_thread && chat_message.replies_count > 0
        %button.thread-replies-button{ type: "button",
            "aria-label" => "#{chat_message.replies_count}件の返信を表示",
            data: { "thread-message-id" => chat_message.id } }
          %span.thread-replies-button-icon ↩
          = "#{chat_message.replies_count}件の返信"
    %hr
- else
  .self-message{ id: "chat-message-#{chat_message.id}", data: { "chat-message-id" => chat_message.id } }
    %ul
      %li
      = link_to public_customer_path(chat_message.customer), class: "chat-room-customer-link" do
        .img-element
          = customer_avatar_tag(chat_message.customer)
        .name-element
          = chat_message.customer.name + 'さんのメッセージ'
      %li
      - unless in_thread
        = render "public/chat_rooms/reply_source_card", chat_message: chat_message
      = render "public/chat_rooms/quote_card", chat_message: chat_message
      .self-content
        - if chat_message.stamped?
          %span.stamp-badge= chat_message.stamp_label
        - elsif chat_message.content.present?
          - if chat_message.markdown?
            - markdown_class = in_thread ? 'markdown-body markdown-body--thread' : 'markdown-body'
            %div{ class: markdown_class }= chat_markdown(chat_message)
          - else
            = simple_format(chat_message.content)
        = render "public/chat_rooms/link_preview_cards", chat_message: chat_message
      - if chat_message.content_editable?
        - hydrated_edit_content = Chat::MentionHydrator.call(chat_message.content)
        .message-edit-form{ hidden: true }
          %form{ action: public_chat_message_path(chat_message), method: "post" }
            %input{ type: "hidden", name: "_method", value: "patch" }
            .edit-errors{ hidden: true }
            .markdown-composer{ data: { "preview-url" => preview_public_chat_messages_path } }
              .markdown-toolbar
                %button.md-btn{ type: "button", data: { md: "bold" }, title: "太字" }
                  %strong B
                %button.md-btn{ type: "button", data: { md: "italic" }, title: "斜体" }
                  %em I
                %button.md-btn{ type: "button", data: { md: "heading" }, title: "見出し" } H
                %button.md-btn{ type: "button", data: { md: "strikethrough" }, title: "取り消し線" }
                  %s S
                %button.md-btn{ type: "button", data: { md: "quote" }, title: "引用" } "
                %button.md-btn{ type: "button", data: { md: "unordered-list" }, title: "箇条書き" } •
                %button.md-btn{ type: "button", data: { md: "ordered-list" }, title: "番号付きリスト" } 1.
                %button.md-btn{ type: "button", data: { md: "checklist" }, title: "チェックリスト" } ☑
                %button.md-btn{ type: "button", data: { md: "code" }, title: "インラインコード" } </>
                %button.md-btn{ type: "button", data: { md: "codeblock" }, title: "コードブロック" } { }
                %button.md-btn{ type: "button", data: { md: "link" }, title: "リンク" } 🔗
                %button.md-btn{ type: "button", data: { md: "image" }, title: "画像" } 🖼
                %button.md-btn{ type: "button", data: { md: "hr" }, title: "区切り線" } ―
                .md-tabs
                  %button.md-tab.is-active{ type: "button", data: { tab: "edit" } } 編集
                  %button.md-tab{ type: "button", data: { tab: "preview" } } プレビュー
              .markdown-panes
                .md-pane.edit-pane.is-active
                  %textarea.chat-form.markdown-textarea{ name: "chat_message[content]", data: { "initial-mentions" => hydrated_edit_content.mentions.to_json } }= hydrated_edit_content.content
                .md-pane.preview-pane
                  .markdown-body.markdown-preview-pane
                    %p.markdown-preview-placeholder 入力するとここにプレビューが表示されます
            .message-edit-actions
              %button.edit-cancel-button{ type: "button" } キャンセル
              %button.edit-save-button{ type: "submit" } 保存
      - if chat_message.attachments.attached?
        - attachments_class = in_thread ? 'message-attachments message-attachments--thread' : 'message-attachments'
        %li
          %div{ class: attachments_class }
            - chat_message.attachments.each do |file|
              .self-chat-image
                - if file.image?
                  - image_class = in_thread ? 'message-image message-image--thread' : 'message-image'
                  - link_class = in_thread ? 'chat-image-link chat-image-link--thread' : 'chat-image-link'
                  = link_to url_for(file), target: '_blank', rel: 'noopener', aria: { label: '画像を拡大表示' }, class: link_class do
                    = image_tag file.variant(resize: '300x300'), class: image_class
                - elsif file.content_type == "application/pdf"
                  %div.pdf-preview
                    %p PDFファイル:
                    = link_to "🧾 PDFを見る", url_for(file), target: "_blank", rel: "noopener", class: "btn-view"
                    = link_to "⬇️ ダウンロード", url_for(file), download: file.filename.to_s, class: "btn-download"
                    %iframe{ src: url_for(file), width: "100%", height: "400px", class: "pdf-frame" }
                - elsif file.content_type.start_with?("audio/")
                  %p 音声ファイル:
                  %audio{ controls: true }
                    %source{ src: url_for(file), type: file.content_type }
                - elsif file.content_type.start_with?("video/")
                  %p 動画ファイル:
                  %video{ controls: true, width: "100%", height: "auto", style: "max-width: 500px;" }
                    %source{ src: url_for(file), type: file.content_type }
      %li
      .message-meta
        %span.message-timestamp
          = l chat_message.created_at, format: :short
          に送信済み
        - if chat_message.edited_at.present?
          %span.edited-label 編集済み
        - if chat_message.pinned?
          %span.pinned-label 📌 ピン留め済み
          - if can_unpin_chat_message?(chat_message.chat_message_pin, community)
            %button.pin-button.pin-button--unpin{ type: "button",
                "aria-label" => "ピン留めを解除",
                data: { "pin-message-id" => chat_message.id, "pin-action" => "unpin" } }
              %span.pin-button-icon 📌
              %span.pin-button-label ピン留めを解除
        - else
          %button.pin-button.pin-button--pin{ type: "button",
              "aria-label" => "ピン留めする",
              data: { "pin-message-id" => chat_message.id, "pin-action" => "pin" } }
            %span.pin-button-icon 📌
            %span.pin-button-label ピン留めする
        - unless in_thread
          %button.reply-button{ type: "button",
              "aria-label" => "このメッセージに返信",
              data: { "reply-message-id" => chat_message.id,
                      "reply-author" => chat_message.customer.name,
                      "reply-preview" => chat_reply_excerpt(chat_message) } }
            %span.reply-button-icon ↩
            %span.reply-button-label 返信
        %button.quote-button{ type: "button",
            "aria-label" => "このメッセージを引用返信",
            data: { "quote-message-id" => chat_message.id,
                    "quote-author" => chat_message.customer.name,
                    "quote-label" => chat_quote_label(chat_message),
                    "quote-excerpt" => chat_reply_excerpt(chat_message),
                    "quote-has-image" => chat_quote_has_image?(chat_message) } }
          %span.quote-button-icon "
          %span.quote-button-label 引用返信
        - if chat_message.content_editable?
          %button.edit-button{ type: "button",
              "aria-label" => "このメッセージを編集",
              data: { "edit-message-id" => chat_message.id } }
            %span.edit-button-icon ✎
            %span.edit-button-label 編集
      - if !in_thread && chat_message.replies_count > 0
        %button.thread-replies-button{ type: "button",
            "aria-label" => "#{chat_message.replies_count}件の返信を表示",
            data: { "thread-message-id" => chat_message.id } }
          %span.thread-replies-button-icon ↩
          = "#{chat_message.replies_count}件の返信"
    %hr
