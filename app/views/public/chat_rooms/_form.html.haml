.form-container
  = form_with model: [:public, chat_message], url: form_url do |f|
    = f.hidden_field :chat_room_id, value: chat_room.id
    - if local_assigns[:customer_id].present?
      = f.hidden_field :customer_id, value: customer_id
    .reply-preview{ hidden: true }
      .reply-preview-body
        .reply-preview-label 返信先:
        %span.reply-preview-author
        .reply-preview-snippet
      %button.reply-preview-cancel{ type: "button", "aria-label" => "返信をキャンセル" } ×
    = f.hidden_field :reply_to_chat_message_id, value: nil, class: "reply-to-hidden-field"
    .markdown-composer{ data: { "preview-url": preview_public_chat_messages_path } }
      .markdown-toolbar
        %button.md-btn{ type: "button", data: { md: "bold" }, title: "太字" }
          %strong B
        %button.md-btn{ type: "button", data: { md: "italic" }, title: "斜体" }
          %em I
        %button.md-btn{ type: "button", data: { md: "heading" }, title: "見出し" } H
        %button.md-btn{ type: "button", data: { md: "strikethrough" }, title: "取り消し線" }
          %s S
        %button.md-btn{ type: "button", data: { md: "quote" }, title: "引用" } "
        %button.md-btn{ type: "button", data: { md: "unordered-list" }, title: "箇条書き" } •
        %button.md-btn{ type: "button", data: { md: "ordered-list" }, title: "番号付きリスト" } 1.
        %button.md-btn{ type: "button", data: { md: "checklist" }, title: "チェックリスト" } ☑
        %button.md-btn{ type: "button", data: { md: "code" }, title: "インラインコード" } </>
        %button.md-btn{ type: "button", data: { md: "codeblock" }, title: "コードブロック" } { }
        %button.md-btn{ type: "button", data: { md: "link" }, title: "リンク" } 🔗
        %button.md-btn{ type: "button", data: { md: "image" }, title: "画像" } 🖼
        %button.md-btn{ type: "button", data: { md: "hr" }, title: "区切り線" } ―
        .md-tabs
          %button.md-tab.is-active{ type: "button", data: { tab: "edit" } } 編集
          %button.md-tab{ type: "button", data: { tab: "preview" } } プレビュー
      .markdown-panes
        .md-pane.edit-pane.is-active
          = f.text_area :content, autofocus: true, class: 'chat-form markdown-textarea', placeholder: "Markdownが使えます 例: **太字** *斜体* `コード` [リンク](URL) :fire:"
        .md-pane.preview-pane
          .markdown-body.markdown-preview-pane
            %p.markdown-preview-placeholder 入力するとここにプレビューが表示されます
    = f.file_field :attachments, multiple: true, accept: 'image/*,application/pdf'
    = f.submit "メッセージを送信", data: { disable_with: '送信中', confirm: "メッセージを送信しますか？"}, class: 'btn btn-info chat-form-btn'
  .stamp-picker
    - stamp_options.each do |stamp_type, label|
      = form_with model: [:public, ChatMessage.new], url: form_url, local: true, html: { class: "stamp-picker-form" } do |f|
        = f.hidden_field :chat_room_id, value: chat_room.id
        = f.hidden_field :stamp_type, value: stamp_type
        = f.submit label, class: "stamp-button"
