= form_with model: [:public, activity], local: true do |f|
  .activity-new-edit-container.px-0.px-sm-0
    %table.table.table-striped.activity-new-edit-table{:width=>"100%",:border=>"1"}
      %colgroup
        %col{width: "10%"}
        %col{width: "70%"}
          %tr
            %th{scope:"row"} 活動報告「画像」
            %td
              = f.file_field :activity_image, accept: 'image/*'
              %span [Point]TOPのイメージ画像になります。
              #new-activity-image
              #edit-activity-image
          %tr
            %th{scope:"row"} 活動報告「Youtube動画」
            %td
              = f.text_field :youtube_url, placeholder: 'youtubeの動画URL（上部アドレスバーのURL）を記載', class: 'form-control'
              %span ※注意※Youtubeショート動画は添付できません。
          %tr
            %th{scope:"row"} 参考URL
            %td
              = f.text_field :url, placeholder: "活動報告に関連するURLを記入します", class: 'form-control'
          %tr
            %th{scope:"row"} URLの説明
            %td
              = f.text_field :url_comment, placeholder: "URLの説明を記入します", class: 'form-control'
          %tr
            %th{scope:"row"}
              活動報告「タイトル」
              %i.text-red
                (必須)
            %td
              = f.text_field :title, class: 'form-control'
          %tr
            %th{scope:"row"}
              やって良かった事
              %i.text-red
                (必須)
            %td
              = f.text_field :keep, class: 'form-control'
          %tr
            %th{scope:"row"}
              失敗した事
              %i.text-red
                (必須)
            %td
              = f.text_field :problem, class: 'form-control'
          %tr
            %th{scope:"row"}
              次回挑戦したい事
              %i.text-red
                (必須)
            %td
              = f.text_field :try, class: 'form-control'
          %tr
            %th{scope:"row"} 活動報告「詳細」
            %td
              = f.text_area :introduction,
                rows: "10",
                style: "width:90%",
                class: "form-control",
                placeholder: "# 🎤 活動報告\n\n## 本日のセッション概要\n本日は〇〇スタジオにてセッション会を開催しました！\n\n参加人数は**15名**で、初参加の方も多くとても盛り上がりました🙌\n\n\n---\n\n## 🎵 セットリスト\n- 曲①（邦楽）\n- 曲②（洋楽）\n- 曲③（アニソン）\n\n\n---\n\n## 🌟 印象的だったポイント\n\n### ▶ 初参加の方が大活躍！\n最初は緊張していた様子でしたが、\n演奏が始まると一気に場に溶け込んでいました👏\n\n\n### ▶ 即興バンドが大成功🔥\nその場で組んだバンドでも、\n驚くほどまとまった演奏に！\n\n\n---\n\n## ❗ やって良かったこと\n- 事前にパート募集を明確にした\n- 初心者にも声かけをした\n\n\n## ⚠️ 反省点\n- 進行が少し押してしまった\n- 機材トラブルが一部あり\n\n\n## 🚀 次回やりたいこと\n- 進行表を事前に共有\n- 機材チェックを強化\n\n\n---\n\n## 💬 参加者の声\n> 「初めてでもすごく楽しめました！」\n\n> 「また絶対参加したいです！」\n\n\n---\n\n## 📸 写真・動画\n[イベントの様子はこちら](https://example.com)\n\n\n---\n\n## 🎯 まとめ\n今回も最高のセッションでした！\n\n音楽を通じて人がつながる瞬間は、やっぱり最高ですね🎶\n\n\n---\n\n※改行を使うと読みやすさがグッと上がります！\n※Markdown記法もぜひ使ってみてください！"
          = f.submit "活動報告を登録", class: "btn btn-info activity-new-edit-btn", data: { confirm: 'こちらの内容で登録します。よろしいですか？' }