= render 'layouts/header_menu'

.activity-index-head-title
  .directory-page-heading
    %p.directory-page-heading__eyebrow Music Activity Log
    %h2 みんなの音楽活動ログ
    %p.directory-page-heading__lead
      練習の気づき・セッションの記録・挑戦の歩みを残し、仲間に見てもらえる場所です。
    .activity-index-value-chips
      %span.activity-value-chip 記録が応援になる
      %span.activity-value-chip 仲間の目に届く
      %span.activity-value-chip 継続が力になる
  .directory-page-action
    = link_to new_public_activity_path, data: { 'turbolinks': false }, class: "btn btn-info activity-index-create-btn" do
      %span.activity-index-create-btn__icon ✏️
      活動ログを投稿する

  - if customer_signed_in? && current_customer.plan == "free"
    = render "shared/plan_upsell_panel",
      badge_label: "✦ LIGHT プラン",
      title: "活動が「見つけてもらえる場」になる",
      lead: "記録するだけでなく、仲間に認識され、応援が自然と集まります。",
      toggle_closed_text: "LIGHTプランのメリットを見る",
      cards: [{ icon: "🏅", name: "活動バッジ表示", note: "投稿数に応じてバッジ獲得。継続が目に見えるかたちになります" }, { icon: "⭐", name: "注目に選ばれやすい", note: "「注目の活動ログ」枠への掲載はLIGHT以上のみ" }, { icon: "🔥", name: "応援リアクションが増える", note: "プラン表示で信頼感が上がり、仲間が反応しやすくなります" }, { icon: "👥", name: "仲間に認識されやすい", note: "コミュニティ内での存在感・声かけが自然と増えます" }, { icon: "🎸", name: "セッションに誘われやすい", note: "活動が見えることで、仲間からの誘いが来やすくなります" }],
      demo: { eyebrow: "👀 LIGHT メンバーはこんな反応を受けています", avatar: "🎸", name: "田中 タクマ", badge_class: "plan-badge-inline plan-badge-inline--light", badge_text: "LIGHT", achievement: "🔥 15投稿", title: "\"先週のスタジオセッションで音程が安定してきた。次はリズムを磨く週にします\"", reactions: [{ icon: "🔥", count: 14, class_name: "activity-light-value__demo-reaction--hot" }, { icon: "👏", count: 9 }, { icon: "🎸", count: 21 }, { icon: "🎤", count: 6 }], comment_avatar: "🎵", comment: "「今度一緒にセッションしませんか？音程意識してるの伝わりました」" },
      cta_text: "LIGHTの詳細を見る →",
      cta_path: public_lp_path(anchor: "lp-section"),
      cta_note: "まずはここから始められます"

  - elsif customer_signed_in? && current_customer.paid_plan?
    .activity-light-active-banner
      %span.activity-light-active-banner__check ✓
      %span.activity-light-active-banner__text 活動ログを投稿するほど、仲間に認識されやすくなります。今日も記録を続けましょう。

.directory-search
  = form_with url: public_activities_path, method: :get, local: true, class: "directory-search__form" do
    = text_field_tag :keyword, params[:keyword], placeholder: "タイトル・KPT・紹介文で検索", class: "directory-search__input"
    = text_field_tag :author, params[:author], placeholder: "投稿者名で検索", class: "directory-search__input"
    = select_tag :sort, options_for_select(activity_sort_options, params[:sort].presence || "newest"), class: "directory-search__select"
    = submit_tag "検索する", class: "btn btn-info directory-search__submit"
    = link_to "リセット", public_activities_path, class: "btn btn-outline-secondary directory-search__reset"
- if @featured_activities.present?
  .activity-featured-section
    .activity-featured-section__header
      %span.activity-featured-section__icon ⭐
      %h3.activity-featured-section__title 注目の活動ログ
      %span.activity-featured-section__label LIGHT以上のメンバーから
    .activity-featured-list
      - @featured_activities.each do |featured|
        = link_to public_activity_path(featured), class: "activity-featured-card", data: { turbolinks: false } do
          .activity-featured-card__thumb
            - if featured.activity_image.present?
              = image_tag featured.activity_image, class: "activity-featured-card__img"
            - else
              .activity-featured-card__no-img 🎵
          .activity-featured-card__body
            %p.activity-featured-card__title= featured.title.truncate(20)
            .activity-featured-card__meta
              %span.activity-featured-card__author= featured.customer.name
              %span{ class: customer_plan_badge_class(featured.customer) }= customer_plan_label(featured.customer)
- else
  .activity-featured-section.activity-featured-section--empty
    .activity-featured-section__header
      %span.activity-featured-section__icon ⭐
      %h3.activity-featured-section__title 注目の活動ログ
      %span.activity-featured-section__label LIGHT以上のメンバーから
    .activity-featured-empty
      %p.activity-featured-empty__title まだ注目できる活動ログはありません。
      %p.activity-featured-empty__text LIGHT以上の活動ログが投稿されると、ここに仲間の挑戦が表示されます。
      - if customer_signed_in? && current_customer.plan == "free"
        = link_to "LIGHTの詳細を見る", public_lp_path(anchor: "lp-section"), class: "activity-featured-empty__link", data: { turbolinks: false }

.activities-kaminari
  = paginate @activities
- if @activities.present?
  %nav.activity-toc.d-sm-none
    %h4.activity-toc-title 📝 目次
    %ul
      - @activities.each_with_index do |activity, index|
        %li
          🎤
          %a{href: "#activity-#{index}"}= truncate(activity.title, length: 20)

.activity-index-container
  - if @activities.present?
    - @activities.each_with_index do |activity, index|
      - activity_id = activity.id
      .activity-log-card.card.mb-5{id: "activity-#{index}"}
        - if time_ago_in_words(activity.created_at) =~ /分|時間/
          .new_activity
            NEW!!
        = link_to public_activity_path(activity), data: { 'turbolinks': false } do
          .img-container
            - if activity.activity_image.present?
              = image_tag activity.activity_image
            - else
              = image_tag 'no_image'
        .card-body.text-container
          .activity-card-author-row
            = link_to singing_user_path(activity.customer), data: { 'turbolinks': false }, class: "activity-card-author-link" do
              = customer_avatar_tag(activity.customer, class_name: "activity-card-avatar")
              %span.activity-card-author-name= activity.customer.name
            - unless activity.customer.plan == "free"
              %span{ class: customer_plan_badge_class(activity.customer) }= customer_plan_label(activity.customer)
            - activity_count = @customer_activity_counts[activity.customer_id].to_i
            - if activity.customer.paid_plan? && activity_count >= 10
              %span.activity-achievement-badge= "🔥 #{activity_count}投稿"
            - elsif activity.customer.paid_plan? && activity_count >= 3
              %span.activity-achievement-badge.activity-achievement-badge--starter= "✨ 活動中"
          %h5.card-title#title-js
            - if activity.title.length > 13
              .title-truncated
                = link_to activity.title.truncate(13), public_activity_path(activity), data: { 'turbolinks': false }
                %p.text-red.title-see-more もっと見る
              .title-untruncated.hide
                = link_to activity.title, public_activity_path(activity), data: { 'turbolinks': false }
            - else
              = link_to activity.title, public_activity_path(activity), data: { 'turbolinks': false }
          %h6.card-subtitle#kpt
            %span.kpt-keep Keep
            - if activity.keep.length > 13
              .keep-truncated
                = activity.keep.truncate(13)
                %p.keep-see-more もっと見る
              .keep-untruncated.hide
                = activity.keep
            - else
              = activity.keep
              %br
              %br
            %span.kpt-problem Problem
            - if activity.problem.length > 13
              .problem-truncated
                = activity.problem.truncate(13)
                %p.problem-see-more もっと見る
              .problem-untruncated.hide
                = activity.problem
            - else
              = activity.problem
              %br
              %br
            %span.kpt-try Try
            - if activity.try.length > 13
              .try-truncated
                = activity.try.truncate(13)
                %p.try-see-more もっと見る
              .try-untruncated.hide
                = activity.try
            - else
              = activity.try
              %br
              %br
          %hr
          .activity-show-link-area
            = link_to "活動ログを見る", public_activity_path(activity), class: "btn-info activity-show-link", data: { 'turbolinks': false }
          %hr
          .activity-card-footer
            .activity-card-meta
              %span.activity-card-date= time_ago_in_words(activity.created_at) + "前"
            .activity-reaction-row
              - [["fire", "🔥", "熱い！"], ["clap", "👏", "いいね！"], ["guitar", "🎸", "ギタリスト！"], ["mic", "🎤", "歌声！"]].each do |type, emoji, label|
                - reaction_count = activity.activity_reactions.count { |r| r.reaction_type == type }
                - already_reacted = customer_signed_in? && activity.activity_reactions.any? { |r| r.reaction_type == type && r.customer_id == current_customer.id }
                - reaction_url = public_activity_reactions_path(activity, reaction_type: type)
                %button.activity-reaction-btn{ title: label, "aria-label": "#{emoji}リアクション", "data-reaction-url": reaction_url, class: (already_reacted ? "activity-reaction-btn--active" : "") }
                  = emoji
                  - if reaction_count > 0
                    %span.reaction-count= reaction_count
          %div{id: "favorite_buttons_#{activity_id}"}
            = render "public/favorites/favorite", activity: activity
  - else
    .activity-empty-state
      %p.activity-empty-state__text まだ活動ログはありません。
      %p.activity-empty-state__sub 最初の活動ログを投稿してみましょう。記録することが、つながりの第一歩です。
