- content_for :title, "BeMyStyle Singing | 音楽コミュニティ"
- content_for :suppress_singing_nav, "1"
- content_for :suppress_layout_notifications, "1"

- lp_cta_label = customer_signed_in? ? "診断してみる" : "無料登録して参加する"
- lp_primary_cta_path = customer_signed_in? ? new_singing_diagnosis_path : new_customer_registration_path
- lp_cta_options = { class: "lp-btn" }
- lp_cta_options[:data] = { turbolinks: false } unless customer_signed_in?
- singing_lp_back_label = @singing_lp_back_label || "Singingホームへ"
- singing_lp_back_path = @singing_lp_back_path || singing_root_path
- singing_lp_hero_back_label = @singing_lp_hero_back_label || "Singingホームへ戻る"
- music_home = @music_community_home

.lp-container.lp-container--singing
  - if notice.present? || alert.present?
    .singing-toast{ class: alert.present? ? "singing-toast--alert" : nil }
      = notice.presence || alert

  .lp-header
    .header-inner
      .lp-logo
        %span.logo-main BeMyStyle
      .lp-singing-nav.lp-singing-nav--desktop
        - if customer_signed_in?
          = link_to "今日の挑戦", singing_challenges_path, class: "lp-singing-nav__link lp-singing-nav__link--primary"
          = link_to "みんなの成長", singing_growth_feed_path, class: "lp-singing-nav__link"
          = link_to "成長記録", singing_diagnoses_path, class: "lp-singing-nav__link"
          = link_to "プランを変更する", "#lp-section", class: "lp-singing-nav__link"
          = button_to "ログアウト",
            destroy_customer_session_path,
            method: :delete,
            form_class: "lp-singing-nav__form",
            class: "lp-singing-nav__link lp-singing-nav__button"
        = link_to "BeMyStyleへ", root_path, class: "lp-singing-nav__link"

      %details.lp-singing-mobile-nav
        %summary.lp-singing-mobile-nav__toggle{ "aria-label": "メニューを開く" }
          %span.lp-singing-mobile-nav__bar
          %span.lp-singing-mobile-nav__bar
          %span.lp-singing-mobile-nav__bar
        .lp-singing-mobile-nav__panel
          .lp-singing-nav.lp-singing-nav--mobile
            - if customer_signed_in?
              = link_to "今日の挑戦", singing_challenges_path, class: "lp-singing-nav__link lp-singing-nav__link--primary"
              = link_to "みんなの成長", singing_growth_feed_path, class: "lp-singing-nav__link"
              = link_to "成長記録", singing_diagnoses_path, class: "lp-singing-nav__link"
              = link_to "プランを変更する", "#lp-section", class: "lp-singing-nav__link"
              = button_to "ログアウト",
                destroy_customer_session_path,
                method: :delete,
                form_class: "lp-singing-nav__form",
                class: "lp-singing-nav__link lp-singing-nav__button"
            = link_to "BeMyStyleへ", root_path, class: "lp-singing-nav__link"

  .lp-hero
    .lp-hero-inner
      %p.lp-eyebrow Singing Music Community
      %h1.lp-hero-title
        - if customer_signed_in?
          %span おかえりなさい。
          %span 今日も音楽を楽しもう。
        - else
          %span 音楽を楽しみながら、
          %span 自分らしく成長しよう。
      %p
        = music_home&.hero_message || "まずは楽しむところから始めよう"
      .lp-hero-points
        %span.lp-chip 今日の挑戦
        %span.lp-chip 仲間とつながる
        %span.lp-chip イベントに出会う
        %span.lp-chip 成長を続ける
      = link_to "今日のホームを見る", "#music-community-home", class: "lp-btn lp-btn--hero-cta"
      .lp-hero-back
        = link_to singing_lp_hero_back_label, singing_lp_back_path

  - if music_home.present?
    .lp-section.singing-community-home#music-community-home
      .singing-community-home__inner
        %p.singing-community-home__eyebrow Music Community Home
        %h2 今日は何をしようかな
        %p.lp-section-lead
          診断だけで終わらず、今日の挑戦、仲間、イベント、成長へ自然につながるホームです。

        - return_motivation = music_home.return_motivation
        - if customer_signed_in? && return_motivation&.visible
          .return-motivation-card
            .return-motivation-card__copy
              %span.return-motivation-card__eyebrow Return Motivation
              %h3.return-motivation-card__title= return_motivation.title
              .return-motivation-card__message= simple_format(return_motivation.message)
            = link_to return_motivation.cta_label, return_motivation.cta_path, class: "return-motivation-card__cta"

        .singing-community-home__mission
          %span.singing-home-section__eyebrow Today's Mission
          %h3.singing-home-section__title= music_home.today_mission&.title || "今日はここだけ歌ってみよう"
          %p.singing-home-section__description= music_home.today_mission&.description || "好きな曲から、歌いたい部分を少しだけ選んで歌ってみよう。"
          - if music_home.today_mission&.coach_message.present?
            %p.singing-community-home__coach-message= music_home.today_mission.coach_message
          .singing-community-home__mission-cta
            = link_to music_home.home_cta.primary_label, music_home.home_cta.primary_path, class: "singing-home-cta__button singing-home-cta__button--primary"

        %p.singing-home-story-copy 今日の一歩が、あなたの音楽の輪を広げます。

        - inbox = @encouragement_inbox
        - if customer_signed_in? && inbox&.items.present?
          .encouragement-inbox#encouragement-inbox
            .encouragement-inbox__header
              %span.encouragement-inbox__eyebrow 💌 仲間からの応援
              %h3.singing-home-section__title 応援が届いています
            .encouragement-inbox__list
              - inbox.items.each do |item|
                - next if item.customer.nil?
                = link_to singing_user_path(item.customer), class: "encouragement-inbox__item" do
                  %span.encouragement-inbox__icon= item.icon
                  .encouragement-inbox__body
                    %span.encouragement-inbox__name= "#{item.customer.name.presence || 'メンバー'}さん"
                    %span.encouragement-inbox__message= item.message
                  %time.encouragement-inbox__time{ datetime: item.occurred_at.iso8601 }= time_ago_in_words(item.occurred_at) + "前"
        - elsif customer_signed_in? && inbox&.items.blank?
          .encouragement-inbox.encouragement-inbox--empty#encouragement-inbox
            %p.encouragement-inbox__empty-icon 💌
            %p.encouragement-inbox__empty-text
              まだ応援は届いていません。
              %br
              まずは診断や挑戦を続けてみましょう。
              %br
              あなたの一歩が、仲間とのつながりになります。
            .encouragement-inbox__empty-actions
              = link_to "今日の診断をする", new_singing_diagnosis_path, class: "encouragement-inbox__empty-button"
              = link_to "Community Feedを見る", "#community-feed", class: "encouragement-inbox__empty-button encouragement-inbox__empty-button--secondary"

        - community_feed = @community_feed
        - if community_feed&.feed_items.present?
          .community-feed#community-feed
            .community-feed__header
              %span.community-feed__eyebrow 🎵 Community Feed
              %h3.singing-home-section__title 仲間の挑戦が流れてくる
              %p.singing-home-section__description 今日も仲間たちが歌い、挑戦し、続けています。
            .community-feed__list
              - community_feed.feed_items.each do |item|
                - next if item.customer.nil?
                .community-feed__item
                  = link_to singing_user_path(item.customer), class: "community-feed__item-main" do
                    %span.community-feed__icon= item.icon
                    .community-feed__body
                      %span.community-feed__name= "#{item.customer.name.presence || 'メンバー'}さん"
                      %span.community-feed__message= item.message
                      %time.community-feed__time{ datetime: item.occurred_at.iso8601 }= time_ago_in_words(item.occurred_at) + "前"
                  - if customer_signed_in? && current_customer != item.customer
                    .community-feed__actions
                      - if item.reacted
                        %span.community-feed__cheered 👏 応援済み
                      - else
                        = button_to "👏 応援する", singing_user_profile_reaction_path(item.customer, reaction_type: "cheer"),
                            method: :post,
                            class: "community-feed__cheer-button",
                            data: { disable_with: "応援中..." }

        - suggested = music_home.suggested_musicians
        - if suggested&.musicians.present?
          .suggested-musicians
            .suggested-musicians__header
              %span.suggested-musicians__eyebrow 🎵 Suggested Musicians
              %h3.singing-home-section__title あなたへのおすすめ
              %p.singing-home-section__description 近い挑戦や音楽のつながりから、まだ知らない仲間に出会えます。
            .suggested-musicians__list
              - suggested.musicians.each do |musician|
                - next if musician.customer.nil?
                .suggested-musician-card
                  = link_to musician.profile_path, class: "suggested-musician-card__main" do
                    .suggested-musician-card__avatar
                      %span= musician.customer.name.to_s.first.presence || "🎤"
                    .suggested-musician-card__body
                      %strong= "#{musician.customer.name.presence || 'メンバー'}さん"
                      %span= musician.reason
                  - if customer_signed_in? && current_customer != musician.customer
                    .suggested-musicians__actions
                      = link_to "プロフィールを見る", musician.profile_path, class: "suggested-musicians__button suggested-musicians__button--profile"
                      - if musician.reacted
                        %span.suggested-musicians__cheered 👏 応援済み
                      - else
                        = button_to "👏 応援する", singing_user_profile_reaction_path(musician.customer, reaction_type: "cheer"),
                            method: :post,
                            form_class: "suggested-musicians__form",
                            class: "suggested-musicians__button suggested-musicians__button--cheer",
                            data: { disable_with: "応援中..." }
            %p.suggested-musicians__footer 新しい仲間との出会いが、次の挑戦を少し軽くしてくれます。

        - if music_home.reputation.present?
          - rep = music_home.reputation
          .community-reputation
            .community-reputation__header
              %span.community-reputation__eyebrow 🌟 Community Reputation
              %h3.singing-home-section__title あなたのコミュニティポイント
              %p.singing-home-section__description 活動と応援を積み重ねることで、コミュニティでの存在感が育っていきます。
            .community-reputation__level
              %span.community-reputation__title= rep.reputation_title
              %span.community-reputation__points= "#{rep.reputation_points} pt"
            .reputation-progress
              .reputation-progress__bar{ style: "width: #{rep.progress_percent}%" }
            - if rep.next_level_points > 0
              %p.community-reputation__next-level
                = "次のレベルまで #{rep.next_level_points}pt"
            .community-reputation__message= rep.reputation_message

        - if music_home.growth_partnerships.present?
          - gp = music_home.growth_partnerships
          .growth-partnerships
            .growth-partnerships__header
              %span.growth-partnerships__eyebrow 🤝 Growth Partners
              %h3.singing-home-section__title 一緒に成長できる仲間
              %p.singing-home-section__description 競争ではなく、近いペースで続けている仲間を見つけましょう。
            - if gp.partners.any?
              .growth-partnerships__list
                - gp.partners.each do |partner|
                  .growth-partnership-card
                    .growth-partnership-card__avatar
                      %span= partner.growth_type&.split(" ")&.first || "🎤"
                    .growth-partnership-card__meta
                      %strong= partner.display_name
                      - if partner.growth_type.present?
                        %em= partner.growth_type
                      - if partner.activity_label.present?
                        %span= partner.activity_label
                    .growth-partnership-card__reason= partner.partnership_reason
              %p.growth-partnerships__footer 競争ではなく、一緒に続ける仲間です。
            - else
              .singing-home-empty-state
                %p.singing-home-empty-state__icon 🤝
                %h4.singing-home-empty-state__title まだ成長パートナーは見つかっていません
                %p.singing-home-empty-state__text
                  でも大丈夫。
                  %br
                  最初の診断や応援が、あなたに近い仲間との出会いにつながります。
                = link_to "診断してみる", new_singing_diagnosis_path, class: "singing-home-empty-state__cta"

        - if music_home.music_social_graph.present?
          - msg = music_home.music_social_graph
          .music-social-graph
            .music-social-graph__header
              %span.music-social-graph__eyebrow 🕸 Music Social Graph
              %h3.singing-home-section__title 音楽でつながる仲間の輪
              %p.singing-home-section__description 応援・成長タイプ・挑戦テーマ・イベントを通じた、あなたの音楽ネットワーク全体像です。
            - if msg.connected_members_count.zero?
              .singing-home-empty-state
                %p.singing-home-empty-state__icon 🕸
                %h4.singing-home-empty-state__title これから音楽でつながりが広がります
                %p.singing-home-empty-state__text
                  応援したり、挑戦を続けることで、
                  %br
                  あなたの音楽の輪が少しずつ育っていきます。
                = link_to "今日のミッションを見る", singing_challenges_path, class: "singing-home-empty-state__cta"
            - else
              .music-social-graph__summary
                あなたは
                %strong.music-social-graph__count= "#{msg.connected_members_count}人"
                の音楽仲間とつながっています
              .music-social-graph__connections
                .music-social-graph__connection
                  %span.music-social-graph__connection-icon 🎵
                  %span.music-social-graph__connection-label 応援
                  %span.music-social-graph__connection-count= "#{msg.cheer_connections_count}人"
                .music-social-graph__connection
                  %span.music-social-graph__connection-icon 🌱
                  %span.music-social-graph__connection-label 成長タイプ
                  %span.music-social-graph__connection-count= "#{msg.growth_type_connections_count}人"
                .music-social-graph__connection
                  %span.music-social-graph__connection-icon 🎯
                  %span.music-social-graph__connection-label 挑戦テーマ
                  %span.music-social-graph__connection-count= "#{msg.mission_connections_count}人"
                .music-social-graph__connection
                  %span.music-social-graph__connection-icon 🎤
                  %span.music-social-graph__connection-label イベント
                  %span.music-social-graph__connection-count= "#{msg.event_connections_count}人"
              %p.music-social-graph__message= msg.graph_message

        %p.singing-home-story-copy 近い仲間とつながりながら、自分のペースで続けましょう。

        .singing-community-home__circles
          .singing-community-home__band-header
            %span.singing-home-section__eyebrow Growth Circles
            %h3.singing-home-section__title 近い仲間たちの小さな輪
            %p.singing-home-section__description 同じ方向を向いて歌っている仲間たちがいます。あなたも、その輪の一員です。
          - if music_home.growth_circles.present?
            .singing-community-home__circles-list
              - music_home.growth_circles.each do |circle|
                .singing-community-home__circle-item
                  %h4.singing-community-home__circle-title= circle.title
                  %p.singing-community-home__circle-count
                    %strong= "#{circle.member_count}人"
                    が参加中
                  %p.singing-community-home__circle-desc= circle.description
          - else
            .singing-home-empty-state
              %p.singing-home-empty-state__icon 🌱
              %h4.singing-home-empty-state__title あなたの輪は、ここから始まります
              %p.singing-home-empty-state__text 診断を続けることで、近い仲間との小さな輪が見えてきます。
              = link_to "診断してみる", new_singing_diagnosis_path, class: "singing-home-empty-state__cta"

        - if music_home.ecosystem.present?
          - eco = music_home.ecosystem
          .music-community-ecosystem
            .music-community-ecosystem__header
              %span.music-community-ecosystem__eyebrow 🎵 Music Community
              %h3.singing-home-section__title コミュニティ全体の動き
              %p.singing-home-section__description あなたが歌うたびに、この輪は少しずつ広がっていきます。
            - if eco.active_members_count.zero? && eco.weekly_cheers_count.zero? && eco.weekly_challenges_count.zero?
              .singing-home-empty-state
                %p.singing-home-empty-state__icon 🎵
                %h4.singing-home-empty-state__title 音楽の輪はこれから育っていきます
                %p.singing-home-empty-state__text あなたが歌い、応援することで、この場所はだんだん活気づいていきます。
                = link_to "コミュニティを見る", "/public/communities/7", class: "singing-home-empty-state__cta"
            - else
              .ecosystem-stats
                .ecosystem-stat
                  %strong= "#{eco.active_members_count}人"
                  %span が今週歌いました
                .ecosystem-stat
                  %strong= "#{eco.weekly_cheers_count}件"
                  %span の応援
                .ecosystem-stat
                  %strong= "#{eco.weekly_challenges_count}件"
                  %span の挑戦達成
                .ecosystem-stat
                  %strong= "#{eco.active_circles_count}つ"
                  %span のCircleが活動中
              .music-community-ecosystem__membership
                あなたもこの輪の一員です
              .music-community-ecosystem__message
                = eco.ecosystem_message

        .singing-community-home__network
          .singing-community-home__band-header
            %span.singing-home-section__eyebrow Community Network
            %h3 あなたと近い仲間
            %p= music_home.community_network&.message || "音楽を楽しむ仲間が増えています。これからつながりが広がっていきます。"
          - if music_home.community_network&.connections.present?
            .singing-community-home__network-list
              - music_home.community_network.connections.each do |connection|
                .singing-community-home__network-item{ class: "singing-community-home__network-item--#{connection.connection_type}" }
                  .singing-community-home__network-avatar
                    %span= connection.growth_type_icon || "🎤"
                  .singing-community-home__network-copy
                    %strong= connection.display_name
                    %span= connection.reason
                    - if connection.growth_type_label.present?
                      %em= connection.growth_type_label
            %p.singing-community-home__network-footer あなたの一歩が、音楽の輪を育てます。
          - else
            .singing-community-home__network-empty
              .singing-home-empty-state
                %p.singing-home-empty-state__icon 🎵
                %h4.singing-home-empty-state__title 音楽でつながる仲間が増えています
                %p.singing-home-empty-state__text 応援や診断を続けることで、あなたの音楽の仲間が少しずつ広がっていきます。
                = link_to "コミュニティを見る", "/public/communities/7", class: "singing-home-empty-state__cta"

        .singing-community-home__band
          .singing-community-home__band-header
            %span.singing-community-home__section-label 仲間
            %h3= music_home.community_summary.title
            %p= music_home.community_summary.message
          .singing-community-home__cards
            - music_home.community_summary.items.each do |item|
              .singing-community-home__card
                %span.singing-community-home__card-label= item.label
                %h4= item.title
                %p= item.message
                - if item.meta.present?
                  %span.singing-community-home__meta= item.meta
          = link_to music_home.community_summary.cta_label, music_home.community_summary.cta_url, class: "singing-community-home__link"

        .singing-community-home__band
          .singing-community-home__band-header
            %span.singing-community-home__section-label イベント
            %h3= music_home.recommended_event.title
            %p= music_home.recommended_event.message
          .singing-community-home__cards.singing-community-home__cards--two
            - music_home.recommended_event.items.each do |item|
              .singing-community-home__card
                %span.singing-community-home__card-label= item.label
                %h4= item.title
                %p= item.message
                - if item.meta.present?
                  %span.singing-community-home__meta= item.meta
          = link_to music_home.recommended_event.cta_label, music_home.recommended_event.cta_url, class: "singing-community-home__link"

        .singing-community-home__band
          .singing-community-home__band-header
            %span.singing-community-home__section-label 成長
            %h3= music_home.growth_summary.title
            %p= music_home.growth_summary.message
          .singing-community-home__cards.singing-community-home__cards--two
            - music_home.growth_summary.items.each do |item|
              .singing-community-home__card
                %span.singing-community-home__card-label= item.label
                %h4= item.title
                %p= item.message
                - if item.meta.present?
                  %span.singing-community-home__meta= item.meta
          = link_to music_home.growth_summary.cta_label, music_home.growth_summary.cta_url, class: "singing-community-home__link"

        .singing-home-cta
          %p.singing-home-cta__message= music_home.home_cta.message
          .singing-home-cta__buttons
            = link_to music_home.home_cta.primary_label, music_home.home_cta.primary_path, class: "singing-home-cta__button singing-home-cta__button--primary"
            = link_to music_home.home_cta.secondary_label, music_home.home_cta.secondary_path, class: "singing-home-cta__button singing-home-cta__button--secondary"

  - if customer_signed_in? && @growth_dashboard
    = render "singing/shared/home_growth_dashboard", dashboard: @growth_dashboard

  - if customer_signed_in?
    .singing-plan-status-card
      .singing-plan-status-card__inner
        .singing-plan-status-card__info
          %p.singing-plan-status-card__label 現在のプラン
          %p.singing-plan-status-card__plan= current_customer.plan.upcase
          - monthly_limit = current_customer.singing_diagnosis_monthly_limit
          - if monthly_limit
            - remaining = current_customer.remaining_singing_diagnosis_quota
            %p.singing-plan-status-card__quota
              今月の残り診断数：
              %strong= "#{remaining} / #{monthly_limit}回"
          - else
            %p.singing-plan-status-card__quota
              %strong 今月の診断：無制限
        .singing-plan-status-card__cta
          = link_to "今すぐ診断する", new_singing_diagnosis_path, class: "btn-singing-diagnose"
          - if current_customer.plan == "free"
            = link_to "LIGHTで5回/月に増やす", "#lp-section", class: "singing-plan-status-card__upgrade-link"
          - elsif current_customer.plan == "light"
            = link_to "COREで20回/月に増やす", "#lp-section", class: "singing-plan-status-card__upgrade-link"

    = render "singing/shared/recap_movie_cta"

  .lp-section
    %h2 なんとなく練習する、から抜け出す
    %ul.lp-list
      %li 音程やリズムの弱点を、自分だけでは判断しにくい
      %li 何を優先して練習すればいいか迷ってしまう
      %li 前より良くなっているのか、感覚だけでは分かりにくい
      %li 本番前や練習後に、今の声の状態を確認したい

  .lp-section.gray
    %h2 診断結果が、次の練習を選びやすくする
    %p.lp-section-lead
      歌唱・演奏診断は、点数で優劣を決めるものではありません。今の状態を知り、次に整えるポイントを見つけるための目印です。
    .lp-grid
      .lp-card
        %strong 音程・リズム・表現を見える化
        %p 感覚だけでは気づきにくい傾向を、スコアとコメントで振り返れます。
      .lp-card
        %strong 前回との差を確認
        %p 継続して録音すると、練習前後や本番前後の変化を見つけやすくなります。
      .lp-card
        %strong 練習メニューにつながる
        %p 診断結果に合わせて、次に試しやすい練習の方向を絞れます。

  .lp-section
    %h2 続けるほど、自分の歌声が見えてくる
    .lp-story
      .lp-story-card.before
        %span.story-label Before
        %strong なんとなく録音して、なんとなく練習する
        %p うまく歌えた日とそうでない日の違いが分かりにくく、練習の優先順位も曖昧になりがち。
      .lp-story-arrow →
      .lp-story-card.after
        %span.story-label After
        %strong 診断結果を見ながら、次の一歩を決める
        %p 音程・リズム・表現の変化を振り返り、自分に合った練習を選びやすくなります。
    .lp-section-cta
      = link_to lp_cta_label, lp_primary_cta_path, lp_cta_options

  .lp-section
    %h2 バンド演奏診断で、まとまりの課題も見つけやすく
    %p.lp-section-lead= singing_band_promo_catch_copy
    .lp-grid
      .lp-card
        %strong 何が分かる？
        %p= singing_band_promo_description
      .lp-card
        %strong こんな人におすすめ
        %ul.lp-list
          - singing_band_promo_recommended_for.first(2).each do |item|
            %li= item
      .lp-card
        %strong 推奨音源
        %p= singing_band_promo_upload_note
    .lp-section-cta
      %p.lp-section-lead= singing_band_premium_promo
      = link_to lp_cta_label, lp_primary_cta_path, lp_cta_options

  .lp-section.gray
    %h2 Coreから声の個性を、Premiumで深い伴走を
    %p.lp-section-lead
      Core以上では6つのボイスタイプ診断で今の声の個性を整理できます。PremiumではTOMOKI本人の視点、限定イベント、AI深掘り成長分析を通じて、さらに深く成長を育てます。
    .lp-grid
      .lp-card
        %strong Core以上：6つのボイスタイプ診断
        %p パワフル・ハイトーン・クリスタルなどの観点で、取り入れると良い声の個性を確認できます。
      .lp-card
        %strong Core以上：詳細診断
        %p 声量、リラックス、発音、ミックスボイスなど、スコアをもう一段細かく読み解きます。
      .lp-card
        %strong Premium：TOMOKIと一緒に伸ばす
        %p 本人診断、月1限定オンラインイベント、AI深掘り成長分析で、次の練習へつながる視点を届けます。

  .lp-section.gray#lp-section
    %h2 歌唱・演奏診断プラン
    %p.lp-section-lead
      回数制限は現行仕様のまま、freeは月1回、Lightは月5回、Coreは月20回、Premiumは無制限で利用できます。
    .lp-plan-reassure
      .lp-plan-reassure__item
        %span.lp-plan-reassure__icon 🔓
        %p いつでも解約可能
      .lp-plan-reassure__item
        %span.lp-plan-reassure__icon 🔄
        %p 必要な時だけプラン変更OK
      .lp-plan-reassure__item
        %span.lp-plan-reassure__icon 🎵
        %p Freeでも診断1回試せる
      .lp-plan-reassure__item
        %span.lp-plan-reassure__icon 🚀
        %p 無料から気軽にスタート
    %p.lp-plan-pressure-free
      成長を続けたくなったらプランアップを。有料プランは、「もっと練習したい」と思った時に深く楽しむための選択肢です。
    .lp-pricing-grid.lp-pricing-grid-conversion#lp-pricing-plans

      .lp-pricing.free
        .plan-head
          %span.plan-badge Starter
          %h3 free
          %p.plan-tag まず試す
        %p.price ¥0
        %p.plan-copy 月1回の基本診断で、今の歌声や演奏の状態を試せます。まずは雰囲気を知りたい人向けです。
        %p.plan-singing-copy 歌唱・演奏診断 1回／月
        %ul
          %li 基本診断で音程・リズム・表現のスコアを確認
          %li ランキング閲覧で参加者の雰囲気を見られる
          %li 一部プロフィールを閲覧できる
          %li おすすめ練習メニューを見られる
        .plan-note 無料で最初の一歩を軽くする

      .lp-pricing.recommend.light-plan
        .plan-ribbon 継続しやすい
        .plan-head
          %span.plan-badge Popular
          %h3 light
          %p.plan-tag 気軽に参加
        %p.price ¥1,500/月
        %p.plan-copy 月5回まで診断でき、活動ログやリアクション体験を通じて、音楽コミュニティに気軽に参加できます。
        %p.plan-singing-copy 歌唱・演奏診断 5回／月
        %ul
          %li 前回比較で変化を確認しやすい
          %li 活動ログで練習の成果を定期的に残せる
          %li 応援リアクションで参加の手触りが生まれる
          %li コミュニティ参加の導線が広がる
        .plan-action
          - if customer_signed_in?
            - if current_customer.plan == "light"
              %span.plan-action__button.plan-action__button--disabled 契約中
            - elsif current_customer.stripe_managed_subscription?
              = link_to "Lightに変更する", public_portal_path, method: :post, class: "plan-action__button"
            - else
              = link_to "Lightを契約する", public_checkout_path("light"), method: :post, class: "plan-action__button"
          - else
            = link_to "無料登録してLightへ", new_customer_registration_path, data: { turbolinks: false }, class: "plan-action__button"
        .plan-note 継続のリズムを作る

      .lp-pricing
        .plan-head
          %span.plan-badge Growth
          %h3 core
          %p.plan-tag 楽しく成長する
        %p.price ¥3,980/月
        %p.plan-copy 月20回まで診断でき、6つのボイスタイプ診断と成長履歴で、自分の声の個性と伸び方を楽しく追えます。
        %p.plan-singing-copy 歌唱・演奏診断 20回／月
        %ul
          %li 6つのボイスタイプ診断で声の個性を確認
          %li 成長履歴と詳細フィードバックで練習の方向を見つける
          %li ランキング参加・シーズンランキング称号・バッジを楽しめる
          %li 応援リアクション通知で継続の手応えが残る
        .plan-action
          - if customer_signed_in?
            - if current_customer.plan == "core"
              %span.plan-action__button.plan-action__button--disabled 契約中
            - elsif current_customer.stripe_managed_subscription?
              = link_to "Coreに変更する", public_portal_path, method: :post, class: "plan-action__button"
            - else
              = link_to "Coreを契約する", public_checkout_path("core"), method: :post, class: "plan-action__button"
          - else
            = link_to "無料登録してCoreへ", new_customer_registration_path, data: { turbolinks: false }, class: "plan-action__button"
        .plan-note 練習の質を高める

      .lp-pricing.premium-plan
        .plan-head
          %span.plan-badge Premium
          %h3 premium
          %p.plan-tag TOMOKIと一緒に伸ばす
        %p.price ¥9,800/月
        %p.plan-copy Premiumは、ただ機能が増えるだけのプランではありません。TOMOKI本人の視点・限定イベント・深い成長分析を通じて、あなたの歌の成長を一緒に育てていくプランです。
        %p.plan-singing-copy 歌唱・演奏診断 無制限
        %ul
          %li TOMOKI本人による歌唱診断
          %li 月1プレミアム限定オンラインイベント
          %li AI深掘り成長分析で次の練習ポイントを整理
          %li Premium限定称号・Premium限定バッジ
          %li 優先的な成長サポートで継続を伴走
        .plan-action
          - if customer_signed_in?
            - if current_customer.plan == "premium"
              %span.plan-action__button.plan-action__button--disabled 契約中
            - elsif current_customer.stripe_managed_subscription?
              = link_to "Premiumに変更する", public_portal_path, method: :post, class: "plan-action__button"
            - else
              = link_to "Premiumを契約する", public_checkout_path("premium"), method: :post, class: "plan-action__button"
          - else
            = link_to "無料登録してPremiumへ", new_customer_registration_path, data: { turbolinks: false }, class: "plan-action__button"
        .plan-note TOMOKIと歌の成長を育てる

