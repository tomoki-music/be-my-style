= render 'layouts/header_menu'

.container.about-page

  / =====================
  / 🎵 HERO
  / =====================
  .about-hero
    .hero-overlay
    .hero-content
      %h1 BeMyStyle
      %p.hero-sub 初めてでも、初心者でも、安心して楽しめる音楽コミュニティ

      .hero-buttons
        = link_to "コミュニティを見る", public_communities_path, class: "btn btn-main"
        = link_to "イベントを見る", public_events_path, class: "btn btn-sub"

  / =====================
  / 🎯 コンセプト
  / =====================
  .about-section
    %h2.section-title 🎵 大切にしていること

    .concept-grid
      .concept-item
        .icon 🎵
        %h4 自分を大切に
        %p やりたい気持ちを優先しよう

      .concept-item
        .icon 🤝
        %h4 相手を尊重
        %p お互いの自由を大切に

      .concept-item
        .icon 🌱
        %h4 挑戦を応援
        %p 成長を楽しめる環境に

  / =====================
  / 💡 ターゲット
  / =====================
  .about-section.alt-bg
    %h2.section-title 📝 こんな方におすすめ

    .card-grid
      .card
        %p 🤝 人との繋がりを広げたい
      .card
        %p 🎸 趣味に打ち込みたい
      .card
        %p 🚀 新しいことに挑戦したい

  / =====================
  / 🚀 ステップ
  / =====================
  .about-section
    %h2.section-title 🚀 はじめ方

    .step-timeline
      .step
        .step-dot
        .step-content
          %h4 コミュニティに参加
          %p 気になる場所に申請しよう

      .step
        .step-dot
        .step-content
          %h4 活動報告を投稿
          %p 成長や日常をシェア

      .step
        .step-dot
        .step-content
          %h4 イベントに参加
          %p 実際に演奏して楽しもう

  / =====================
  / ⚠️ 注意
  / =====================
  .attention-box
    %h4 利用時間
    %p 6:00〜26:00

  / =====================
  / 💬 メッセージ
  / =====================
  .about-message
    %p
      みんなで安心して楽しめる場所を作っていきましょう😊