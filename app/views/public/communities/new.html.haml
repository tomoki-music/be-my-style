= render 'layouts/header_menu'

.community-new-title
  %h2 コミュニティ作成画面
  - if @community.errors.any?
    .alert
      %ul.list-style-none
        - @community.errors.full_messages.each do |message|
          %li
            = message

= form_with model: [:public, @community], local: true, html: { multipart: true } do |f|
  .community-new-container.px-0.px-sm-0
    %table.table.table-striped.community-new-table{:width=>"100%",:border=>"1"}
      %colgroup
        %col{width: "19%"}
        %col{width: "81%"}
          %tr
            %th{scope:"row"} コミュニティ画像
            %td
              = f.file_field :community_image, accept: 'image/*'
              #new-community-image
          %tr
            %th{scope:"row"}
              コミュニティ名前
              %i.text-red
                (必須)
            %td
              = f.text_field :name
              %br
              ※15文字以内で命名お願い致します。
          %tr
            %th{scope:"row"} 活動場所
            %td 
              = f.collection_select :prefecture_id, Prefecture.all, :id, :name
          %tr
            %th{scope:"row"} 活動ペース
            %td
              = f.select :activity_stance, Community.enum_options_for_select(:activity_stance)
          %tr
            %th{scope:"row"} 好きなジャンル
            %td
              = f.collection_check_boxes(:genre_ids, Genre.all, :id, :name) do |genre|
                = genre.label do
                  = genre.check_box
                  = genre.text
          %tr
            %th{:rowspan => 5} PickUpアーティスト
            %td
              = f.text_field :favorite_artist1
          %tr
            %td
              = f.text_field :favorite_artist2
          %tr
            %td
              = f.text_field :favorite_artist3
          %tr
            %td
              = f.text_field :favorite_artist4
          %tr
            %td
              = f.text_field :favorite_artist5
          %tr
            %th{scope:"row"} コミュニティURL
            %td
              = f.text_field :url
          %tr
            %th{scope:"row"}
              コミュニティ紹介文
              %i.text-red
                (必須)
            %td
              = f.text_area :introduction,
                style: "width:90%",
                rows: "10",
                placeholder: "# コミュニティ紹介\n\n## 概要\nこのコミュニティは音楽好きが集まる場所です！\n\n## 活動内容\n- セッション会（月1回）\n- ライブイベント\n- オフ会（BBQ・カラオケなど）\n\n## こんな人におすすめ\n- 音楽仲間が欲しい\n- 初心者だけど参加してみたい\n- バンドを組んでみたい\n\n## 注意事項\n**最低限のマナーを守って楽しみましょう！**\n\n自由に改行して読みやすく書いてね！\n\n---\n\n【Markdown記法の使い方】\n\n# 見出し1\n## 見出し2\n### 見出し3\n\n- リスト\n- リスト\n\n1. 番号リスト\n2. 番号リスト\n\n**太字**\n*斜体*\n\n~~打ち消し~~\n\n[リンク](https://example.com)\n\n> 引用\n\n`コード`\n\n```コードブロック```\n\n---\n\n※改行をうまく使うと、読みやすさがグッと上がります！"
          = f.submit "コミュニティを作成", class: "btn btn-info community-new-btn", data: { confirm: 'こちらの内容で作成します。よろしいですか？' }
