- if @show_tutorial
  #portal-tutorial.portal-tutorial{ data: { complete_url: learning_student_portal_complete_tutorial_path(@student.public_access_token) } }
    .portal-tutorial__backdrop
    .portal-tutorial__card
      .portal-tutorial__step{ data: { step: "1" } }
        %h2.portal-tutorial__title ようこそ！
        %p ここはあなただけの練習ポータルです。
        %p
          課題をこなすたびに
          %strong 努力ポイント
          がもらえます。
        %button.learning-button.portal-tutorial__next{ data: { action: "next" } } 次へ
      .portal-tutorial__step{ data: { step: "2" }, style: "display:none" }
        %h2.portal-tutorial__title ポイントをためよう
        %p
          %strong 練習記録をつけると5PT
        %p
          %strong 課題を達成すると20PT
        %p
          毎週連続でアクセスすると
          %strong ボーナスポイント
          ももらえます！
        %button.learning-button.portal-tutorial__done{ data: { action: "complete" } } はじめる！

.learning-shell.learning-shell--portal
  .learning-main.learning-main--portal
    .learning-topbar
      .learning-topbar__text
        %p.learning-topbar__eyebrow Student Page
        %h1= "#{@student.display_name} さんのトレーニング"
        %p.learning-topbar__subtitle
          = [@student.learning_school_group&.name, @student.grade.presence].compact.join(" / ").presence || "今週の目標と進捗を確認できます。"

    .learning-content
      - if @show_comeback_message
        .learning-comeback
          .learning-comeback__body
            %span.learning-comeback__eyebrow おかえりなさい
            %h2 ここから再スタートできます
            %p= "#{@idle_days}日空いていても大丈夫です。今日やることを1つだけ選べば、また流れに戻れます。"
          - unless @today_task.empty?
            = link_to "今日やることへ", "##{@today_task.cta_anchor}", class: "learning-button"

      .learning-start-guide
        .learning-start-guide__header
          .learning-start-guide__title
            %span.learning-start-guide__eyebrow 7日間スタートガイド
            %h2= @start_guide.completed? ? "1週間達成！" : "あと#{@start_guide.remaining_days}日で達成"
            %p= @start_guide.current_step.body
          .learning-start-guide__meter
            %strong= "#{@start_guide.completed_days} / 7"
            %span 日完了
        .learning-progress.learning-start-guide__progress{ style: learning_progress_style(@student.main_part) }
          .learning-progress__bar{ style: "width: #{learning_progress_bar_width(@start_guide.progress_percent)}%" }
        .learning-start-guide__steps
          - @start_guide.steps.each do |step|
            .learning-start-guide-step{ class: "#{'is-complete' if step.completed} #{'is-current' if step.current}" }
              %span= "Day#{step.day}"
              %strong= step.title

      - if @reminder&.active?
        .learning-student-reminder{ class: "learning-student-reminder--#{@reminder.level}" }
          %strong 最近少し空いています
          %span= @reminder.message

      - unless @line_connected
        .learning-line-nudge
          .learning-line-nudge__body
            %span.learning-line-nudge__eyebrow LINE連携
            %h2 LINE連携すると便利
            %p リマインドが届くので、練習を忘れにくくなります。続けやすい流れをスマホにも作れます。
          %span.learning-line-status 未連携

      - if @today_task.present? && !@today_task.empty?
        .learning-first-action{ style: learning_progress_style(@today_task.training.part) }
          .learning-first-action__body
            %span.learning-first-action__eyebrow 今日やること
            %h2
              = @today_task.title
              %small= "（#{@today_task.duration_label}）"
            .learning-first-action__meta
              %span= "優先度: #{@today_task.priority_label}"
              %span= "連続日数: #{@current_streak}日"
              %span= @yesterday_training_title.present? ? "昨日: #{@yesterday_training_title}" : "昨日: 記録なし"
            %p
              = @today_task.reason
              。まずこの1つをやると、今日の練習が前に進みます。
          = link_to "今すぐやる", "##{@today_task.cta_anchor}", class: "learning-button"
      - else
        .learning-first-action.learning-first-action--empty
          .learning-first-action__body
            %span.learning-first-action__eyebrow 今日やること
            %h2 先生が準備中です
            %p 課題が届いたらここに今日やる練習が表示されます。今は部活で決まっている基礎練習や曲の確認を続けておけば大丈夫です。

      .learning-section
        .learning-section__header
          %h2 今週やること
          - if @weekly_training_assignments.any?
            %span.learning-notification-current= "割り当てトレーニング #{@weekly_training_assignments.size}件"
        .learning-stack
          - if @weekly_training_assignments.any?
            - @weekly_training_assignments.each do |assignment|
              - training = assignment.learning_student_training
              .learning-assignment-card
                .learning-assignment-card__head
                  .learning-assignment-card__title
                    %strong= training&.title || assignment.title
                    - if assignment.due_on
                      %small= "期限：#{assignment.due_on.strftime('%-m/%-d')}"
                  %span.learning-assignment-status{ class: "learning-assignment-status--#{assignment.status}" }= assignment.status_label
                  - if assignment.overdue?
                    %span.learning-assignment-status.learning-assignment-status--overdue 提出期限を過ぎています
                %p= training&.description.presence || assignment.description
                - if training
                  .learning-detail-card
                    - if training.check_method.present?
                      %p
                        %strong 確認方法
                        = training.check_method
                    - if training.achievement_criteria.present?
                      %p
                        %strong 達成の目安
                        = training.achievement_criteria
                    %p
                      %strong 誰に見てもらうか
                      = training.judge_type_label
                .learning-first-action__meta
                  %span= "完了reaction: #{assignment.completed_at.present? ? '受信済み' : '未受信'}"
                  %span= "連続日数: #{@current_streak}日"
                  - if training&.frequency.present?
                    %span= "頻度: #{training.frequency}"
          - elsif @current_assignments.any?
            - @current_assignments.each do |assignment|
              .learning-assignment-card
                .learning-assignment-card__head
                  .learning-assignment-card__title
                    %strong= assignment.title
                    - if assignment.due_on
                      %small= "期限：#{assignment.due_on.strftime('%-m/%-d')}"
                  %span.learning-assignment-status{ class: "learning-assignment-status--#{assignment.status}" }= assignment.status_label
                  - if assignment.overdue?
                    %span.learning-assignment-status.learning-assignment-status--overdue 提出期限を過ぎています
                - if assignment.description.present?
                  = simple_format(assignment.description)
          - else
            .learning-empty
              %strong 今週やることはまだありません
              %p 先生からトレーニングが割り当てられたらここに表示されます。終わったらLINEで「やった！」と返信できます。

      .learning-two-column.learning-two-column--balanced
        .learning-section.learning-student-nudge
          .learning-section__header
            %h2 今のあなたへの一言
          %p.learning-student-nudge__text= @student_feedback.headline
          .learning-feedback-list
            %p
              %strong 前回との変化
              = @student_feedback.change
            %p
              %strong 次にやるべきこと
              = @student_feedback.next_action

        .learning-section.learning-student-nudge
          .learning-section__header
            %h2 あなたにおすすめの練習
          .learning-inline-tags
            - @part_recommendations.each do |recommendation|
              %span.learning-part-tag= recommendation

      .learning-section.learning-badge-panel
        .learning-section__header
          %h2 継続バッジ
        .learning-badge-list
          - @student_badges.each do |badge|
            .learning-retention-badge{ class: ("is-earned" if badge.earned) }
              %span= badge.earned ? "✓" : "○"
              %strong= badge.label

      .learning-community-pulse
        %strong= "今週は#{@weekly_active_student_count}人が練習しています"
        %span ひとりで頑張るより、少し戻りやすい流れを部活全体で作っています。

      .learning-stat-grid
        .learning-stat-card{ style: learning_progress_style(@student.main_part) }
          %span.learning-stat-card__label 進捗率
          %strong.learning-stat-card__value= "#{@summary[:progress_rate]}%"
          .learning-progress{ style: learning_progress_style(@student.main_part) }
            .learning-progress__bar{ style: "width: #{learning_progress_bar_width(@summary[:progress_rate])}%" }
        .learning-stat-card
          %span.learning-stat-card__label 達成数
          %strong.learning-stat-card__value= @summary[:achievement_count]
          %p.learning-stat-card__sub= "全 #{@summary[:total_count]} 件"
        .learning-stat-card
          %span.learning-stat-card__label 努力ポイント
          %strong.learning-stat-card__value= "#{@effort_points}PT"
          - if @ranking
            %p.learning-stat-card__sub= "グループ #{@ranking}位"
        .learning-stat-card
          %span.learning-stat-card__label 連続アクセス
          %strong.learning-stat-card__value= "#{@current_streak}日"
          %p.learning-stat-card__sub= @current_streak >= 7 ? "すごい！続けてます" : "毎日チェックしよう"
        .learning-stat-card
          %span.learning-stat-card__label 今週の目標
          %strong.learning-stat-card__value= @summary[:weekly_goal].presence || "確認しよう"
        .learning-stat-card
          %span.learning-stat-card__label メインパート
          %strong.learning-stat-card__value= learning_part_label(@student.main_part)
          %p.learning-stat-card__sub= @student.displayed_parts.map { |part| learning_part_label(part) }.join(" / ")

      .learning-two-column
        .learning-section
          .learning-section__header
            %h2 今週の目標
          .learning-detail-card
            %p
              %strong 目標
              = @summary[:weekly_goal].presence || "先生と次の目標を相談してみよう。"
            %p
              %strong 先生からのメッセージ
              = @summary[:teacher_comment].presence || "先生からのコメントはまだありません。"

        .learning-section
          .learning-section__header
            %h2 次にやる課題
          .learning-stack
            - upcoming_trainings = @current_trainings.reject { |training| training.status == "achieved" || training.star? }.first(4)
            - if upcoming_trainings.any?
              - upcoming_trainings.each do |training|
                .learning-training-card{ style: learning_progress_style(training.part) }
                  .learning-training-card__header
                    %strong= training.title
                    %span= learning_mark_label(training.achievement_mark)
                  %p= training.description
                  - if training.check_method.present? || training.achievement_criteria.present?
                    - check_items = []
                    - check_items << "確認方法: #{training.check_method}" if training.check_method.present?
                    - check_items << "達成の目安: #{training.achievement_criteria}" if training.achievement_criteria.present?
                    - check_items << "誰に見てもらうか: #{training.judge_type_label}"
                    %small= check_items.join(" / ")
                  %small= "#{training.period} / #{training.level}"
            - else
              .learning-empty
                %strong 今の課題はよく進んでいます
                %p 次の課題が追加されるまで、できた練習を先生に伝えながらこの調子で続けよう。

      .learning-two-column
        .learning-section
          .learning-section__header
            %h2 取り組み中のメニュー
          .learning-stack
            - if @current_trainings.any?
              - @current_trainings.each do |training|
                .learning-training-card{ id: "training-#{training.id}", style: learning_progress_style(training.part) }
                  .learning-training-card__header
                    %strong= training.title
                    %span= learning_mark_label(training.achievement_mark)
                  %p= training.description
                  - if training.check_method.present? || training.achievement_criteria.present?
                    - check_items = []
                    - check_items << "確認方法: #{training.check_method}" if training.check_method.present?
                    - check_items << "達成の目安: #{training.achievement_criteria}" if training.achievement_criteria.present?
                    - check_items << "誰に見てもらうか: #{training.judge_type_label}"
                    %small= check_items.join(" / ")
                  %small= "#{training.period} / #{training.level} / #{training.frequency.presence || '頻度未設定'}"
            - else
              .learning-empty.learning-empty--action
                %strong 課題は先生が準備中です
                %p 最初の課題が届くと、ここに練習内容・目標・先生からのコメントが表示されます。

        .learning-section
          .learning-section__header
            %h2 最近のがんばり記録
          .learning-stack
            - if @recent_logs.any?
              - @recent_logs.each do |log|
                .learning-log-card
                  .learning-log-card__head
                    %strong= l(log.practiced_on)
                    %span= learning_mark_label(log.achievement_mark)
                  %p= "#{learning_part_label(log.part)} / #{log.training_title}"
                  %small= log.comment.presence || "コメントなし"
            - else
              .learning-empty
                %strong 最初の記録を楽しみにしています
                %p 練習記録が増えると、努力ポイントや成長率に少しずつ反映されます。まずは今日のおすすめ練習から始めよう。
