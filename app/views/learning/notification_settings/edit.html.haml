= render "learning/shared/page", title: "通知設定", subtitle: "LINE/メール連携の前に、顧問が通知方針を管理できるようにします。" do
  .learning-section
    .learning-section__header
      %h2 通知方針
      = link_to "通知ログを見る", learning_notifications_path, class: "learning-button learning-button--ghost learning-button--sm"

    = form_with model: @notification_setting, url: learning_notification_settings_path, method: :patch, local: true, class: "learning-form learning-notification-settings-form" do |f|
      .learning-setting-list
        %label.learning-setting-toggle
          .learning-setting-toggle__body
            %strong 生徒リマインド通知
            %span 2日/3日/5日空いた生徒を通知ログに表示します。
          = f.check_box :reminder_enabled

        %label.learning-setting-toggle
          .learning-setting-toggle__body
            %strong 顧問向け週次まとめ
            %span 今後、週次サマリー配信に使う予定の設定です。
          = f.check_box :teacher_summary_enabled

        %label.learning-setting-toggle
          .learning-setting-toggle__body
            %strong 生徒復帰通知
            %span 生徒が戻ってきた時の通知に使う予定の設定です。
          = f.check_box :student_reactivation_enabled

        %label.learning-setting-toggle
          .learning-setting-toggle__body
            %strong 自動リマインド送信
            %span ONにした顧問だけ、LINE連携済み生徒へ自動フォローを送信します。
          = f.check_box :auto_reminder_enabled

      .learning-form-group
        = f.label :auto_reminder_send_hour, "自動送信時間帯"
        = f.number_field :auto_reminder_send_hour, min: 0, max: 23, class: "learning-input", placeholder: "例: 18"
        %p.learning-muted 0〜23で指定します。空欄の場合はrake task実行時刻を制限しません。

      .learning-form-group
        %label 配信方法
        .learning-channel-options
          %label.learning-channel-option.is-active
            = f.radio_button :delivery_channel, "manual"
            .learning-channel-option__body
              %strong 手動コピー
              %span コピーUIから顧問が必要なタイミングで声かけします。
          %label.learning-channel-option.is-disabled
            = f.radio_button :delivery_channel, "email", disabled: true
            .learning-channel-option__body
              %strong メール：準備中
              %span 実配信はまだ行いません。
          %label.learning-channel-option.is-disabled
            = f.radio_button :delivery_channel, "line", disabled: true
            .learning-channel-option__body
              %strong LINE：準備中
              %span LINE連携前の安全な準備段階です。

      .learning-section
        .learning-section__header
          %h2 LINE通知
          = link_to "自動リマインドを確認", learning_auto_reminders_path, class: "learning-button learning-button--ghost learning-button--sm"
        .learning-empty
          %strong LINE通知：自動リマインドは明示ONのみ
          %p 手動LINE送信はこれまで通り利用できます。自動リマインドはプレビュー画面で候補を確認してからONにしてください。

      .learning-inline-actions
        = f.submit "保存する", class: "learning-button"
        = link_to "顧問ダッシュボードへ", learning_teacher_dashboard_path, class: "learning-button learning-button--ghost"
