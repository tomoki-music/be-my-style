= render "learning/shared/page", title: "顧問ダッシュボード", subtitle: "生徒の進捗・努力ポイントを一覧確認できます。" do
  - next_action = @teacher_next_action
  .learning-next-action
    .learning-next-action__body
      %span.learning-next-action__eyebrow 使い方ナビ
      %h2 次にやること
      %strong= next_action.title
      %p= next_action.body
    = link_to next_action.cta_label, next_action.cta_path, class: "learning-button"

  .learning-start-package
    .learning-start-package__intro
      %span.learning-start-package__eyebrow 初回導入パッケージ
      %h2 まずは3ステップで始めましょう
      %ol.learning-start-package__steps
        %li 生徒を登録
        %li LINE連携QRを配布
        %li 課題を1つ出す
      %p 自動リマインドは慣れてきたらONで大丈夫です。まずは生徒登録、LINE連携、最初の課題配布まで進めましょう。
    .learning-start-package__progress
      %strong= "#{@onboarding_checklist.completed_count} / #{@onboarding_checklist.total_count}"
      %span 完了

  .learning-onboarding-checklist
    .learning-onboarding-checklist__header
      %div
        %span.learning-onboarding-checklist__eyebrow 初回設定チェックリスト
        %h2 迷わず始めるための準備
        %p 生徒が迷わず始められて、顧問が送信前に確認できる状態を順番に作ります。
    .learning-onboarding-checklist__items
      - @onboarding_checklist.items.each do |item|
        .learning-onboarding-checklist-item{ class: ("is-complete" if item.completed) }
          .learning-onboarding-checklist-item__marker= item.completed ? "✓" : "未"
          .learning-onboarding-checklist-item__body
            %strong= item.title
            %p= item.description
          = link_to item.cta_label, item.cta_path, class: "learning-button learning-button--ghost learning-button--sm"

  -# 初回オンボーディング
  - if @onboarding_status.completed?
    .learning-ready-banner
      .learning-ready-banner__icon ✓
      .learning-ready-banner__body
        %strong 運用準備完了
        %span 生徒登録・グループ・割当・案内・初回記録まで進んでいます。このまま週1回の確認を続けましょう。
  - else
    .learning-onboarding
      .learning-onboarding__header
        .learning-onboarding__title
          %span.learning-onboarding__eyebrow 初日セットアップ
          %h2 次にやること
          %p まずは1つずつ進めれば、生徒が自分の課題を確認できる状態になります。
        .learning-onboarding__progress
          %strong= "#{@onboarding_status.completed_count} / #{@onboarding_status.total_count}"
          %span 完了
      .learning-onboarding__steps
        - @onboarding_status.steps.each_with_index do |step, index|
          .learning-onboarding-step{ class: ("is-complete" if step.completed) }
            .learning-onboarding-step__marker= step.completed ? "✓" : index + 1
            .learning-onboarding-step__body
              %strong= step.title
              %p= step.body
            - unless step.completed
              = link_to step.cta_label, step.cta_path, class: "learning-button learning-button--sm"

  -# 月次サマリー
  - report = @monthly_report
  .learning-stat-grid
    .learning-stat-card
      %span.learning-stat-card__label 在籍生徒数
      %strong.learning-stat-card__value= @students.count
      %p.learning-stat-card__sub アクティブな生徒
    .learning-stat-card
      %span.learning-stat-card__label 今月の練習記録
      %strong.learning-stat-card__value= report.persisted? ? report.total_progress_logs : "-"
      %p.learning-stat-card__sub= report.persisted? ? report.month_label : "未集計"
    .learning-stat-card
      %span.learning-stat-card__label 平均達成率
      %strong.learning-stat-card__value= report.persisted? ? "#{report.avg_achievement_rate}%" : "-"
      %p.learning-stat-card__sub 今月の全体平均
    .learning-stat-card
      %span.learning-stat-card__label 今月の課題達成
      %strong.learning-stat-card__value= report.persisted? ? report.total_achieved_trainings : "-"
      %p.learning-stat-card__sub ⭐ に更新された件数
    .learning-stat-card
      %span.learning-stat-card__label 今日の自動フォロー候補
      %strong.learning-stat-card__value= "#{@auto_reminder_summary.inactive_count}名"
      %p.learning-stat-card__sub 3日以上未反応
    .learning-stat-card
      %span.learning-stat-card__label 期限前日リマインド
      %strong.learning-stat-card__value= "#{@auto_reminder_summary.due_tomorrow_count}件"
      %p.learning-stat-card__sub 明日が期限の未完了課題
    .learning-stat-card
      %span.learning-stat-card__label 期限超過リマインド
      %strong.learning-stat-card__value= "#{@auto_reminder_summary.overdue_count}件"
      %p.learning-stat-card__sub 今日時点の未完了課題

  - analytics_summary = @analytics_report.summary
  - at_risk_students = @analytics_report.at_risk_students
  - at_risk_connected_count = at_risk_students.count(&:line_connected)
  - at_risk_unconnected_count = at_risk_students.size - at_risk_connected_count
  .learning-section
    .learning-section__header
      %h2= "#{@analytics_report.period_label}のLearningレポート"
      .learning-section__actions
        - Learning::AnalyticsReport::PERIODS.each do |period_key, label|
          = link_to label,
                    learning_teacher_dashboard_path(period: period_key, group_id: params[:group_id]),
                    class: "learning-button learning-button--sm #{'learning-button--ghost' unless @analytics_report.period == period_key}"
    .learning-stat-grid.learning-stat-grid--compact
      .learning-stat-card
        %span.learning-stat-card__label 課題提出率
        %strong.learning-stat-card__value= "#{analytics_summary.assignment_submission_rate}%"
        %p.learning-stat-card__sub= "対象 #{analytics_summary.assignment_count}件"
      .learning-stat-card
        %span.learning-stat-card__label トレーニング消化率
        %strong.learning-stat-card__value= "#{analytics_summary.training_completion_rate}%"
        %p.learning-stat-card__sub 今週の割当トレーニング
      .learning-stat-card
        %span.learning-stat-card__label LINE反応率
        %strong.learning-stat-card__value= "#{analytics_summary.line_reaction_rate}%"
        %p.learning-stat-card__sub= "反応 #{analytics_summary.line_reaction_count} / 送信 #{analytics_summary.line_sent_count}"
      .learning-stat-card
        %span.learning-stat-card__label 練習記録
        %strong.learning-stat-card__value= "#{analytics_summary.progress_log_count}件"
        %p.learning-stat-card__sub= @analytics_report.period_label
      .learning-stat-card
        %span.learning-stat-card__label 未提出
        %strong.learning-stat-card__value= "#{analytics_summary.unsubmitted_count}名"
        %p.learning-stat-card__sub 未着手・進行中
      .learning-stat-card
        %span.learning-stat-card__label 7日以上未反応
        %strong.learning-stat-card__value= "#{analytics_summary.inactive_student_count}名"
        %p.learning-stat-card__sub 要フォロー候補

    .learning-analytics-grid
      .learning-analytics-panel
        .learning-section__header
          %h3 生徒別の状況
        - if @analytics_report.student_summaries.any?
          .learning-table-wrap
            %table.learning-table
              %thead
                %tr
                  %th 生徒
                  %th.text-right 消化率
                  %th.text-right 提出率
                  %th.text-right 反応率
                  %th 最終反応
                  %th 状態
              %tbody
                - @analytics_report.student_summaries.each do |item|
                  %tr
                    %td= link_to item.student.display_name, learning_student_path(item.student)
                    %td.text-right= "#{item.training_completion_rate}%"
                    %td.text-right= "#{item.submission_rate}%"
                    %td.text-right= "#{item.reaction_rate}%"
                    %td= item.last_reaction_at ? "#{time_ago_in_words(item.last_reaction_at)}前" : "反応なし"
                    %td
                      %span.learning-status-pill{ class: "learning-status-pill--#{item.status.to_s.dasherize}" }= item.status_label
        - else
          .learning-empty
            %strong 生徒データはまだありません
            %p 生徒を登録すると、提出率・反応率・フォロー対象がここに表示されます。

      .learning-analytics-panel
        .learning-section__header
          %h3 課題別の完了率
          = link_to "課題進捗を見る", learning_assignments_path, class: "learning-button learning-button--ghost learning-button--sm"
        - if @analytics_report.assignment_summaries.any?
          .learning-assignment-summary-list
            - @analytics_report.assignment_summaries.each do |item|
              .learning-assignment-summary
                .learning-assignment-summary__head
                  %strong= item.title
                  %span= "#{item.completion_rate}%"
                .learning-progress
                  .learning-progress__bar{ style: "width: #{learning_progress_bar_width(item.completion_rate)}%" }
                %small= "完了 #{item.completed_count} / 対象 #{item.total_count} ・ 未提出 #{item.unsubmitted_count}"
        - else
          .learning-empty
            %strong 課題データはまだありません
            %p 課題を配布すると、止まりやすい課題や反応の良い課題が見えてきます。

  .learning-section
    = form_with url: learning_followup_line_messages_path, method: :post, local: true, class: "learning-bulk-line-form", data: { bulk_line_form: true } do
      = hidden_field_tag :period, @analytics_report.period
      = hidden_field_tag :group_id, params[:group_id] if params[:group_id].present?
      .learning-section__header
        %div
          %h2 要フォロー生徒
          %p.learning-muted= "要フォロー対象：#{at_risk_students.size}名 / LINE連携済み：#{at_risk_connected_count}名 / 未連携：#{at_risk_unconnected_count}名"
        - if at_risk_students.any?
          .learning-section__actions
            %button.learning-button.learning-button--ghost.learning-button--sm{ type: "button", data: { bulk_line_select: "all" } } 全員選択
            %button.learning-button.learning-button--ghost.learning-button--sm{ type: "button", data: { bulk_line_select: "connected" } } LINE連携済みのみ選択
      - if at_risk_students.any?
        .learning-bulk-line-summary{ data: { bulk_line_summary: true } }
          選択中：0名 / LINE連携済み：0名 / 未連携：0名。送信対象はLINE連携済みの0名です。
        = render "learning/line_message_templates/selector", templates: @line_message_templates, target_id: "followup_line_message_message"
        .learning-form-group.learning-bulk-line-message
          = label_tag :followup_line_message_message, "フォローLINE文面"
          = text_area_tag "followup_line_message[message]", Learning::FollowupLineMessagesController::DEFAULT_MESSAGE, id: "followup_line_message_message", class: "learning-textarea", maxlength: 500, data: { bulk_line_message: true }
          %p.learning-muted
            %span{ data: { bulk_line_remaining: true } } 残り500文字
            %span  / 500文字以内
        .learning-section__actions.learning-bulk-line-actions
          = submit_tag "要フォロー生徒へ一括LINE", class: "learning-button", data: { confirm: "選択した要フォロー生徒にLINEメッセージを送信します。よろしいですか？" }
        .learning-table-wrap
          %table.learning-table
            %thead
              %tr
                %th 選択
                %th 生徒
                %th.text-right 提出率
                %th 最終反応
                %th 最終フォロー
                %th.text-right 未提出
                %th LINE
            %tbody
              - at_risk_students.each do |item|
                - duplicate_recently_sent = item.last_followup_sent_at.present? && item.last_followup_sent_at >= 24.hours.ago
                %tr
                  %td
                    = check_box_tag "student_ids[]", item.student.id, true, class: "learning-bulk-line-checkbox", data: { bulk_line_checkbox: true, line_connected: item.line_connected, duplicate_recently_sent: duplicate_recently_sent }
                  %td= link_to item.student.display_name, learning_student_path(item.student)
                  %td.text-right= "#{item.completion_rate}%"
                  %td= item.inactive_days ? "#{item.inactive_days}日未反応" : "反応なし"
                  %td
                    = "最終フォロー送信：#{learning_time_ago_label(item.last_followup_sent_at)}"
                    - if duplicate_recently_sent
                      %div.learning-line-duplicate-warning この生徒には24時間以内にフォローLINEを送っています
                  %td.text-right= "#{item.pending_assignments}件"
                  %td
                    - if item.line_connected
                      %span.learning-line-status.learning-line-status--connected 連携済み
                    - else
                      = link_to "QR発行", learning_student_line_connection_path(item.student), class: "learning-text-link"
                      %span.learning-line-status 未連携
      - else
        .learning-empty
          %strong 要フォロー生徒はいません
          %p 提出率30%以上、または直近7日以内にLINE反応がある生徒はフォロー対象から外れます。

  .learning-section
    .learning-section__header
      %h2 今、声かけしたい生徒
      .learning-section__actions
        %span.learning-notification-current= "通知設定：#{@notification_setting.delivery_channel_label}"
        %span.learning-notification-current= "今日の通知候補：#{@notification_candidates_count}件"
        %span.learning-notification-current= "保存済み履歴：#{@notification_logs_count}件"
        = link_to "通知設定を変更", edit_learning_notification_settings_path, class: "learning-button learning-button--ghost learning-button--sm"
        = link_to "自動リマインド確認", learning_auto_reminders_path, class: "learning-button learning-button--ghost learning-button--sm"
        = link_to "通知ログを見る", learning_notifications_path, class: "learning-button learning-button--ghost learning-button--sm"
        = link_to "生徒一覧を見る", learning_students_path, class: "learning-button learning-button--ghost learning-button--sm"
    .learning-safe-note
      %strong 自動リマインドは、いきなり送信されません。
      %p まずプレビューで対象者と文面を確認できます。ONにしない限り自動送信されないので安心です。
    - if @weekly_review.stagnant_students.any?
      .learning-voice-list
        - @weekly_review.stagnant_students.each do |item|
          .learning-voice-item
            .learning-voice-item__head
              .learning-voice-item__student
                %strong= item.student.display_name
                %span= item.last_practiced_on ? "最終実施日: #{l(item.last_practiced_on, format: :short)}" : "最終実施日: まだ記録なし"
              %span.learning-voice-item__status= item.status_label
            .learning-voice-item__template
              %label 声かけテンプレ
              %textarea.learning-copy-textarea{ readonly: true, rows: 2 }= item.template
            .learning-voice-item__actions
              %button.learning-button.learning-button--sm.learning-copy-button{ type: "button", data: { learning_copy_text: item.template } }
                コピー
              %span.learning-copy-status{ role: "status", aria: { live: "polite" } }
              .learning-send-links{ hidden: true }
                = link_to "LINEで送る", "https://line.me/R/msg/text/?#{u(item.template)}", class: "learning-button learning-button--ghost learning-button--sm", target: "_blank", rel: "noopener"
                = mail_to "", "メールで送る", subject: "練習の声かけ", body: item.template, class: "learning-button learning-button--ghost learning-button--sm"
              = link_to "詳細を見る", learning_student_path(item.student), class: "learning-button learning-button--ghost learning-button--sm"
    - else
      .learning-empty
        %strong 今すぐ声かけが必要な生徒はいません
        %p 3日以上止まった生徒や記録がない生徒が出ると、ここにテンプレ付きで表示されます。

  .learning-section
    .learning-section__header
      %h2 先生が確認するトレーニング
      %span.learning-notification-current= "対象：#{@teacher_check_assignments.size}件"
    - if @teacher_check_assignments.any?
      .learning-stack
        - @teacher_check_assignments.each do |assignment|
          - training = assignment.learning_student_training
          .learning-review-row
            %strong= "#{assignment.learning_student.display_name} / #{training.title}"
            %span
              先生確認が必要
              - if training.check_method.present?
                = " / 確認方法: #{training.check_method}"
              - if training.achievement_criteria.present?
                = " / 達成の目安: #{training.achievement_criteria}"
    - else
      .learning-empty
        %strong 先生確認が必要な未完了トレーニングはありません
        %p 先生が確認する設定の課題が出ると、ここに表示されます。

  .learning-section
    .learning-section__header
      %h2 最近リアクションした生徒
      = link_to "通知ログを見る", learning_notifications_path, class: "learning-button learning-button--ghost learning-button--sm"
    - if @recent_reaction_logs.any?
      .learning-stack
        - @recent_reaction_logs.each do |log|
          - student = log.learning_student
          - if student
            = link_to learning_student_path(student), class: "learning-review-row" do
              %strong= student.display_name
              %span= "#{time_ago_in_words(log.reacted_at)}前 / #{log.reaction_message}"
          - else
            .learning-review-row
              %strong 削除済みの生徒
              %span= "#{time_ago_in_words(log.reacted_at)}前 / #{log.reaction_message}"
    - else
      .learning-empty
        %strong まだLINE返信はありません
        %p 生徒が通知に「やった」「完了」などと返信すると、ここに最新の反応が表示されます。

  .learning-section
    .learning-section__header
      %h2 最近完了した課題
      .learning-section__actions
        = link_to "課題進捗を見る", learning_assignments_path, class: "learning-button learning-button--ghost learning-button--sm"
        = link_to "課題を配布", learning_students_path, class: "learning-button learning-button--ghost learning-button--sm"
    - if @recent_completed_assignments.any?
      .learning-stack
        - @recent_completed_assignments.each do |assignment|
          - student = assignment.learning_student
          - if student
            = link_to learning_student_path(student), class: "learning-review-row" do
              %strong= student.display_name
              %span= "#{assignment.title} / #{time_ago_in_words(assignment.completed_at || assignment.updated_at)}前"
          - else
            .learning-review-row
              %strong 削除済みの生徒
              %span= "#{assignment.title} / #{time_ago_in_words(assignment.completed_at || assignment.updated_at)}前"
    - else
      .learning-empty
        %strong 完了した課題はまだありません
        %p 生徒がLINEで「やった！」と返信すると、最新の未着手課題が完了になりここへ表示されます。

  .learning-section
    .learning-section__header
      %h2 今週の課題状況
      = link_to "課題進捗を見る", learning_assignments_path, class: "learning-button learning-button--ghost learning-button--sm"
    .learning-stat-grid.learning-stat-grid--compact
      .learning-stat-card
        %span.learning-stat-card__label 提出率
        %strong.learning-stat-card__value= "#{@weekly_assignment_status[:completion_rate]}%"
        %p.learning-stat-card__sub= "対象 #{@weekly_assignment_status[:total_count]}件"
      .learning-stat-card
        %span.learning-stat-card__label 完了
        %strong.learning-stat-card__value= "#{@weekly_assignment_status[:completed_count]}人"
        %p.learning-stat-card__sub LINE返信で自動完了
      .learning-stat-card
        %span.learning-stat-card__label 未提出
        %strong.learning-stat-card__value= "#{@weekly_assignment_status[:unsubmitted_count]}人"
        %p.learning-stat-card__sub 未着手・進行中
      .learning-stat-card
        %span.learning-stat-card__label 期限超過
        %strong.learning-stat-card__value= "#{@weekly_assignment_status[:overdue_count]}人"
        %p.learning-stat-card__sub 今日時点

  .learning-section
    .learning-section__header
      %h2 今週のまとめ
      = link_to "声かけしましょう", learning_students_path, class: "learning-button learning-button--ghost learning-button--sm"
    .learning-review-grid
      .learning-review-card
        %span.learning-review-card__label 今週の頑張った生徒
        - if @weekly_review.top_students.any?
          .learning-stack
            - @weekly_review.top_students.each do |item|
              = link_to learning_student_path(item.student), class: "learning-review-row" do
                %strong= item.student.display_name
                %span= item.label
        - else
          %p.learning-review-card__empty まだ今週の記録はありません。最初の記録が入ると上位3名が表示されます。
      .learning-review-card
        %span.learning-review-card__label 成長率上昇した生徒
        - if @weekly_review.growth_students.any?
          .learning-stack
            - @weekly_review.growth_students.each do |item|
              = link_to learning_student_path(item.student), class: "learning-review-row" do
                %strong= item.student.display_name
                %span= item.label
        - else
          %p.learning-review-card__empty 先週より記録が増えた生徒がここに表示されます。
      .learning-review-card
        %span.learning-review-card__label 停滞している生徒
        - if @weekly_review.stagnant_students.any?
          .learning-stack
            - @weekly_review.stagnant_students.each do |item|
              = link_to learning_student_path(item.student), class: "learning-review-row learning-review-row--alert" do
                %strong= item.student.display_name
                %span= item.last_practiced_on ? "#{item.days_idle}日未実施" : "記録なし"
        - else
          %p.learning-review-card__empty 3日以上止まっている生徒はいません。この調子で見守れます。

  .learning-section
    .learning-section__header
      %h2 今週の成長
      %small= "#{Date.current.beginning_of_week.strftime('%-m/%-d')} - #{Date.current.end_of_week.strftime('%-m/%-d')}"
    - if @weekly_growth[:progress_log_count].positive? || @weekly_growth[:completed_training_count].positive?
      .learning-stat-grid.learning-stat-grid--compact
        .learning-stat-card
          %span.learning-stat-card__label 今週取り組んだ生徒数
          %strong.learning-stat-card__value= "#{@weekly_growth[:active_student_count]}人"
          %p.learning-stat-card__sub 練習記録があった生徒
        .learning-stat-card
          %span.learning-stat-card__label 今週完了された練習数
          %strong.learning-stat-card__value= "#{@weekly_growth[:completed_training_count]}件"
          %p.learning-stat-card__sub 達成に更新された割当
        .learning-stat-card
          %span.learning-stat-card__label 平均達成率
          %strong.learning-stat-card__value= @weekly_growth[:average_achievement_rate] ? "#{@weekly_growth[:average_achievement_rate]}%" : "-"
          %p.learning-stat-card__sub 全割当から算出
        .learning-stat-card
          %span.learning-stat-card__label 先週比
          %strong.learning-stat-card__value= @weekly_growth[:log_count_delta].positive? ? "+#{@weekly_growth[:log_count_delta]}" : @weekly_growth[:log_count_delta]
          %p.learning-stat-card__sub 練習記録数の差分
      - max_count = @weekly_progress_points.map { |point| point[:count] }.max.to_i
      .learning-growth-chart{ role: "img", aria: { label: "直近7日の進捗数推移" } }
        - @weekly_progress_points.each do |point|
          - height = max_count.positive? ? [((point[:count].to_f / max_count) * 100).round, 8].max : 8
          .learning-growth-chart__item
            .learning-growth-chart__bar{ style: "height: #{height}%" }
              %span= point[:count]
            %small= point[:label]
    - else
      .learning-empty.learning-empty--action
        %strong 今週の成長はこれから表示されます
        %p 生徒がポータルを見て練習記録を残すと、取り組んだ人数や達成数がここにまとまります。
        = link_to "生徒にポータルURLを案内する", learning_students_path, class: "learning-button learning-button--ghost"

  -# グループフィルタ + CSVエクスポート
  .learning-section
    .learning-section__header
      %h2 生徒一覧
      = link_to "CSVエクスポート",
                export_csv_learning_teacher_dashboard_path,
                class: "learning-button learning-button--ghost",
                data: { turbo: false }

    - if @school_groups.any?
      .learning-filter-form
        %span.learning-filter-form__label グループで絞り込む:
        = link_to "全員",
                  learning_teacher_dashboard_path,
                  class: "learning-button #{'learning-button--ghost' unless params[:group_id].nil?}"
        - @school_groups.each do |group|
          = link_to group.name,
                    learning_teacher_dashboard_path(group_id: group.id),
                    class: "learning-button #{'learning-button--ghost' unless params[:group_id].to_s == group.id.to_s}"

    .learning-table-wrap
      %table.learning-table
        %thead
          %tr
            %th 名前
            %th ニックネーム
            %th パート
            %th 学年
            %th グループ
            %th.text-right 達成率
            %th.text-right 努力PT
            %th 最終練習日
            %th
        %tbody
          - if @students.any?
            - @students.each do |student|
              - last_log = @last_practiced_on_by_student[student.id]
              - achievement_rate = @achievement_rate_by_student[student.id] || 0
              %tr
                %td
                  = link_to student.name, learning_student_path(student)
                %td.text-muted= student.nickname.presence || "-"
                %td= learning_part_label(student.main_part)
                %td= student.grade.presence || "-"
                %td= student.learning_school_group&.name || "未所属"
                %td.text-right
                  .learning-progress.learning-progress--compact{ style: learning_progress_style(student.main_part) }
                    .learning-progress__bar{ style: "width: #{learning_progress_bar_width(achievement_rate)}%" }
                  %small= "#{achievement_rate}%"
                %td.text-right
                  %strong= student.total_effort_points
                  %small PT
                %td= last_log ? l(last_log, format: :short) : "-"
                %td
                  = link_to "詳細", learning_student_path(student), class: "learning-button learning-button--ghost learning-button--sm"
          - else
            %tr
              %td{ colspan: 9 }
                .learning-empty.learning-empty--action
                  %strong まずは生徒を1人登録しましょう
                  %p 生徒を登録すると、専用ポータルURL・課題割当・努力ポイントの運用を始められます。
                  = link_to "生徒を追加", new_learning_student_path, class: "learning-button"

  .learning-assurance
    %strong 安心して運用するために
    %p 生徒はニックネームで運用できます。ランキングは個人を責めるためではなく、努力・継続・成長を部活動全体で見守るための仕組みです。
